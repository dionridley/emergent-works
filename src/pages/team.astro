---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { staff, boardOfDirectors, advisoryBoard } from "../data/team";
---

<Layout title="Our Team">
  <Header currentPath="/team/" />

  <section class="team-hero">
    <div class="st-container">
      <div data-reveal>
        <span class="st-chapter">The People</span>
        <h1>The Faces<br />Behind the<br />Mission</h1>
        <p class="team-hero__sub">100% of our staff are program alumni. They don't just understand the journey — they've lived it.</p>
      </div>
    </div>
  </section>

  <!-- Staff as mini-profiles -->
  <section class="st-section">
    <div class="st-container">
      <div data-reveal>
        <span class="st-kicker">Staff</span>
        <h2>Our Team</h2>
        <div class="st-divider"></div>
      </div>
      <div class="staff-profiles">
        {staff.map((member, i) => (
          <div class="staff-profile" data-reveal={`delay-${Math.min(i + 1, 4)}`}>
            <div class="staff-profile__image">
              <img src={member.image} alt={member.name} />
            </div>
            <div class="staff-profile__text">
              <h3>{member.name}</h3>
              <span class="staff-profile__title">{member.title}</span>
              {member.bio && <p>{member.bio}</p>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Board -->
  <section class="st-section st-section--white">
    <div class="st-container">
      <div data-reveal>
        <span class="st-kicker">Governance</span>
        <h2>Board of Directors</h2>
        <div class="st-divider"></div>
      </div>
      <div class="board-grid" data-reveal="delay-1">
        {boardOfDirectors.map((m) => (
          <div class="board-member">
            <img src={m.image} alt={m.name} class="board-member__photo" />
            <h4>{m.name}</h4>
            <span class="board-member__title">{m.title}</span>
            {m.bio && <p class="board-member__bio">{m.bio}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Advisory -->
  <section class="st-section">
    <div class="st-container">
      <div data-reveal>
        <span class="st-kicker">Advisory</span>
        <h2>Advisory Board</h2>
      </div>
      <div class="board-grid" data-reveal="delay-1">
        {advisoryBoard.map((m) => (
          <div class="board-member">
            <img src={m.image} alt={m.name} class="board-member__photo" />
            <h4>{m.name}</h4>
            <span class="board-member__title">{m.title}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="st-section st-section--green" style="text-align:center;">
    <div class="st-container" data-reveal>
      <h2 style="color:var(--st-white);">Join Our Story</h2>
      <p style="color:var(--st-sage);max-width:420px;margin:var(--st-space-4) auto var(--st-space-7);">We're always looking for people who believe in the power of second chances.</p>
      <a href="/get-involved/" class="st-btn st-btn--gold">Get Involved <span class="st-btn-arrow">&rarr;</span></a>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .team-hero { padding:calc(var(--st-header-height) + var(--st-space-16)) 0 var(--st-space-10); }
  .team-hero h1 { color:var(--st-green); font-size:clamp(3rem,8vw,5.5rem); }
  .team-hero__sub { font-size:1.125rem; color:var(--st-text-secondary); max-width:480px; margin-top:var(--st-space-5); line-height:1.75; }

  .staff-profiles { display:flex; flex-direction:column; gap:var(--st-space-8); margin-top:var(--st-space-6); }

  .staff-profile {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: var(--st-space-7);
    align-items: start;
    padding-bottom: var(--st-space-7);
    border-bottom: 1px solid var(--st-border);
  }

  .staff-profile:last-child { border-bottom: none; }

  .staff-profile__image {
    aspect-ratio: 1;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--st-peach);
  }

  .staff-profile__image img { width:100%; height:100%; object-fit:cover; }

  .staff-profile__text h3 { color:var(--st-green); margin-bottom:0.125rem; }
  .staff-profile__title { font-family:var(--st-font-serif); font-size:0.9375rem; font-style:italic; color:var(--st-green-muted); display:block; margin-bottom:var(--st-space-3); }
  .staff-profile__text p { font-size:0.9375rem; line-height:1.75; color:var(--st-text-secondary); }

  .board-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(200px, 1fr)); gap:var(--st-space-6); margin-top:var(--st-space-6); }
  .board-member { text-align:center; }
  .board-member__photo { width:100px; height:100px; border-radius:50%; object-fit:cover; margin:0 auto var(--st-space-3); border:2px solid var(--st-peach); }
  .board-member h4 { color:var(--st-green); font-size:1rem; margin-bottom:0.125rem; }
  .board-member__title { font-family:var(--st-font-serif); font-size:0.8125rem; font-style:italic; color:var(--st-green-muted); display:block; margin-bottom:var(--st-space-2); }
  .board-member__bio { font-size:0.8125rem; line-height:1.6; color:var(--st-text-secondary); }

  @media (max-width: 768px) {
    .staff-profile { grid-template-columns:1fr; text-align:center; }
    .staff-profile__image { width:160px; margin:0 auto; }
  }
</style>