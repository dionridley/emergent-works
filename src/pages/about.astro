---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { organization } from "../data/organization";
import { programApproach } from "../data/programs";

const staffStatItems = [
  { value: "100%", label: "Alumni Staff", desc: "Every team member has completed an EW program" },
  { value: "80%", label: "System-Impacted", desc: "Staff who have navigated the justice system" },
  { value: "80%", label: "BIPOC", desc: "Staff who identify as Black, Indigenous, or People of Color" },
  { value: "40%", label: "Female-Identifying", desc: "Staff who identify as female" },
];

// PLACEHOLDER: Awaiting Army's real milestones
const milestones = [
  { year: "2020", title: "Founded", desc: "Army Armstead Co-founds Emergent Works in New York City" },
  { year: "2021", title: "First Cohort", desc: "Inaugural program cohort graduates, launching the mentorship model" },
  { year: "2022", title: "Growing Impact", desc: "Programs expand to serve more system-impacted communities" },
  { year: "2023", title: "Community Recognition", desc: "Emergent Works recognized for measurable reentry outcomes" },
  { year: "2024", title: "Scaling Programs", desc: "T.RAP and TECK programs formalized, partner programs launched" },
];
---

<Layout title="About">
  <Header currentPath="/about/" />

  <section class="about-hero">
    <div class="st-container">
      <div class="about-hero__content" data-reveal>
        <span class="st-chapter">Our Story</span>
        <h1>From One<br />Belief to a<br />Movement</h1>
      </div>
    </div>
  </section>

  <!-- Origin Story — 2-column grid -->
  <section class="st-section">
    <div class="st-container">
      <div class="origin-grid" data-reveal>
        <div class="origin-image">
          <img src="/images/about/mission-group.jpg" alt="Emergent Works community" loading="lazy" />
        </div>
        <div class="origin-content">
          <span class="st-kicker">Our Story</span>
          <h2>From Personal<br />Experience to<br />Collective Power</h2>
          <p>
            In 2020, Army Armstead Co-founded Emergent Works with a conviction born from lived experience:
            the people most affected by mass incarceration deserved more than a second chance — they
            deserved the tools to build entirely new futures. Having navigated the criminal justice
            system himself, Army understood that the gap between release and reentry wasn't just about
            skills. It was about dignity, community, and belief.
          </p>
          <p>
            What began as a small mentorship initiative in New York City has grown into a comprehensive
            organization offering two distinct programs that address the full spectrum of needs — from
            digital literacy and music production to career development and community engagement.
          </p>
        </div>
      </div>

      <blockquote class="st-pullquote" data-reveal>
        "We don't just talk about reentry — we live it, we build it, and we prove it works."
        <cite>— The Emergent Works Team</cite>
      </blockquote>
    </div>
  </section>

  <!-- Mission -->
  <section class="st-section">
    <div class="st-container">
      <div class="st-grid-40-60" data-reveal>
        <div>
          <span class="st-kicker">Our Mission</span>
          <h2>Breaking Cycles<br />Through Technology</h2>
        </div>
        <div>
          <p style="font-size:1.0625rem;line-height:1.8;color:var(--st-text-secondary);">
            {organization.extendedMission}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Staff Composition -->
  <section class="st-section staff-section">
    <div class="st-container">
      <div class="staff-header" data-reveal>
        <span class="st-kicker staff-kicker">Who We Are</span>
        <h2>Led by Those<br />Who've Lived It</h2>
        <p class="staff-sub">
          Our team is our greatest proof of concept. The people leading our programs
          have walked the same path as our participants.
        </p>
      </div>

      <div class="staff-grid">
        {staffStatItems.map((item, i) => (
          <div class="staff-stat" data-reveal={`delay-${i + 1}`}>
            <div class="staff-stat__value">{item.value}</div>
            <div class="staff-stat__label">{item.label}</div>
            <p class="staff-stat__desc">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Our Journey Timeline -->
  <!-- PLACEHOLDER: Awaiting Army's real milestones -->
  <section class="st-section timeline-section">
    <div class="st-container">
      <div class="timeline-header" data-reveal>
        <span class="st-kicker" style="justify-content:center;">Our Journey</span>
        <h2>Five Years of<br />Proven Impact</h2>
      </div>

      <div class="timeline">
        {milestones.map((m, i) => (
          <div class="timeline__item" data-reveal={`delay-${Math.min(i + 1, 4)}`}>
            <div class="timeline__year">{m.year}</div>
            <div class="timeline__dot" />
            <div class="timeline__content">
              <h3 class="timeline__title">{m.title}</h3>
              <p class="timeline__desc">{m.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Four Pillars -->
  <section class="st-section st-section--white">
    <div class="st-container">
      <div style="text-align:center;" data-reveal>
        <span class="st-kicker">Our Approach</span>
        <h2>Four Pillars of Change</h2>
        <div class="st-divider st-divider--center"></div>
      </div>
      <div class="pillars-grid">
        {programApproach.map((pillar, i) => (
          <div class="pillar-card" data-reveal={`delay-${i + 1}`}>
            <figure class="st-editorial-image">
              <img src={pillar.image} alt={pillar.title} style="aspect-ratio:4/3;object-fit:cover;border-radius:2px;" />
            </figure>
            <h3>{pillar.title}</h3>
            <p>{pillar.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="st-section st-section--green" style="text-align:center;">
    <div class="st-container" data-reveal>
      <span class="st-chapter" style="justify-content:center;color:var(--st-gold);">What's next</span>
      <h2 style="color:var(--st-white);">This Story<br />Needs You</h2>
      <p style="color:var(--st-sage);max-width:460px;margin:var(--st-space-4) auto var(--st-space-7);font-size:1.0625rem;">
        Whether you mentor, donate, or partner — you become part of the next chapter.
      </p>
      <a href="/get-involved/" class="st-btn st-btn--gold">Get Involved <span class="st-btn-arrow">&rarr;</span></a>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .about-hero {
    padding: calc(var(--st-header-height) + var(--st-space-16)) 0 var(--st-space-10);
    background: var(--st-cream);
  }

  .about-hero h1 {
    color: var(--st-green);
    font-size: clamp(3rem, 8vw, 6rem);
  }

  /* ============================================
     ORIGIN STORY — 2-column grid
     ============================================ */
  .origin-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--st-space-9);
    align-items: center;
  }

  .origin-image {
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 4 / 5;
  }

  .origin-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .origin-content h2 {
    color: var(--st-green);
    margin-bottom: var(--st-space-5);
  }

  .origin-content p {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--st-text-secondary);
    margin-bottom: var(--st-space-4);
  }

  .origin-content p:last-child {
    margin-bottom: 0;
  }

  /* ============================================
     STAFF COMPOSITION
     ============================================ */
  .staff-section {
    background: var(--st-green-dark);
  }

  .staff-header {
    margin-bottom: var(--st-space-9);
  }

  .staff-header h2 {
    color: var(--st-white);
    margin-bottom: var(--st-space-4);
  }

  .staff-kicker {
    color: var(--st-gold);
  }

  .staff-sub {
    color: var(--st-sage);
    font-size: 1.0625rem;
    max-width: 480px;
    line-height: 1.7;
  }

  .staff-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--st-space-5);
  }

  .staff-stat {
    text-align: center;
    padding: var(--st-space-7) var(--st-space-4);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(177, 211, 187, 0.1);
    border-radius: 12px;
  }

  .staff-stat__value {
    font-family: var(--st-font-heading);
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    color: var(--st-gold);
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: var(--st-space-2);
  }

  .staff-stat__label {
    font-family: var(--st-font-heading);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--st-white);
    margin-bottom: var(--st-space-2);
  }

  .staff-stat__desc {
    font-size: 0.8125rem;
    color: var(--st-sage);
    line-height: 1.5;
  }

  /* ============================================
     TIMELINE
     ============================================ */
  .timeline-section {
    background: var(--st-cream);
  }

  .timeline-header {
    text-align: center;
    margin-bottom: var(--st-space-9);
  }

  .timeline-header h2 {
    color: var(--st-green);
  }

  .timeline {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 80px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--st-green);
    opacity: 0.2;
  }

  .timeline__item {
    display: grid;
    grid-template-columns: 60px 40px 1fr;
    gap: 0;
    align-items: start;
    margin-bottom: var(--st-space-6);
  }

  .timeline__item:last-child {
    margin-bottom: 0;
  }

  .timeline__year {
    font-family: var(--st-font-serif);
    font-size: 1rem;
    font-weight: 700;
    color: var(--st-gold);
    text-align: right;
    padding-top: 0.375rem;
    padding-right: var(--st-space-3);
  }

  .timeline__dot {
    width: 12px;
    height: 12px;
    background: var(--st-green);
    border: 3px solid var(--st-cream);
    border-radius: 50%;
    justify-self: center;
    margin-top: 0.5rem;
    position: relative;
    z-index: 1;
  }

  .timeline__content {
    padding-left: var(--st-space-4);
    padding-bottom: var(--st-space-4);
  }

  .timeline__title {
    font-family: var(--st-font-heading);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--st-green);
    margin-bottom: var(--st-space-2);
  }

  .timeline__desc {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--st-text-secondary);
  }

  /* ============================================
     FOUR PILLARS (unchanged)
     ============================================ */
  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--st-space-7);
    margin-top: var(--st-space-8);
  }

  .pillar-card h3 {
    color: var(--st-green);
    margin: var(--st-space-4) 0 var(--st-space-2);
  }

  .pillar-card p {
    font-size: 0.9375rem;
    color: var(--st-text-secondary);
    line-height: 1.7;
  }

  /* ============================================
     RESPONSIVE
     ============================================ */
  @media (max-width: 768px) {
    .origin-grid {
      grid-template-columns: 1fr;
      gap: var(--st-space-6);
    }

    .origin-image {
      aspect-ratio: 16 / 9;
      max-height: 300px;
    }

    .staff-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .timeline::before {
      left: 20px;
    }

    .timeline__item {
      grid-template-columns: 0 40px 1fr;
    }

    .timeline__year {
      position: absolute;
      font-size: 0.75rem;
      padding: 0;
      margin-bottom: 0;
    }

    .pillars-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 480px) {
    .staff-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
