---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import { organization } from "../data/organization";
import { programApproach } from "../data/programs";
import missionGroup from "../assets/about/mission-group.jpg";
import heroImage from "../assets/heroes/about.jpg";

const staffStatItems = [
  {
    value: "100%",
    label: "Alumni Staff",
    desc: "Every team member has completed an EW program",
    icon: `<svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
      <polygon points="18,7 32,14 18,21 4,14" fill="#FFCB70"/>
      <path d="M10 17 L10 25 C10 25 14 29 18 29 C22 29 26 25 26 25 L26 17" stroke="#FFCB70" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      <line x1="32" y1="14" x2="32" y2="22" stroke="#FFCB70" stroke-width="2.2" stroke-linecap="round"/>
      <circle cx="32" cy="23" r="2" fill="#FFF8ED"/>
    </svg>`,
  },
  {
    value: "80%",
    label: "System-Impacted",
    desc: "Staff who have navigated the justice system",
    icon: `<svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M10 22 L6 26 C4 28 4 31 6 33 C8 35 11 35 13 33 L17 29" stroke="#FFCB70" stroke-width="2.5" stroke-linecap="round" fill="none"/>
      <path d="M19 17 L23 13 C25 11 25 8 23 6 C21 4 18 4 16 6 L12 10" stroke="#FFCB70" stroke-width="2.5" stroke-linecap="round" fill="none"/>
      <line x1="14" y1="22" x2="22" y2="14" stroke="#FFF8ED" stroke-width="2.2" stroke-linecap="round"/>
      <circle cx="26" cy="26" r="6" fill="rgba(255,203,112,0.15)" stroke="#FFCB70" stroke-width="1.8"/>
      <path d="M23.5 26 L25.2 27.8 L28.5 24" stroke="#FFCB70" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    </svg>`,
  },
  {
    value: "80%",
    label: "BIPOC",
    desc: "Staff who identify as Black, Indigenous, or People of Color",
    icon: `<svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="12" cy="11" r="4.5" fill="#FFCB70"/>
      <circle cx="24" cy="11" r="4.5" fill="#FFCB70" opacity="0.7"/>
      <path d="M4 28 C4 22 20 22 20 28" stroke="#FFCB70" stroke-width="2.2" stroke-linecap="round" fill="none"/>
      <path d="M18 26 C18 21 32 21 32 27" stroke="#FFCB70" stroke-width="2.2" stroke-linecap="round" fill="none" opacity="0.7"/>
      <path d="M18 17 C18 15.5 19.5 14 21 15.5 C22.5 14 24 15.5 24 17 L21 20 Z" fill="#FFF8ED" opacity="0.6"/>
    </svg>`,
  },
  {
    value: "40%",
    label: "Female-Identifying",
    desc: "Staff who identify as female",
    icon: `<svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="18" cy="14" r="8" stroke="#FFCB70" stroke-width="2.5" fill="none"/>
      <line x1="18" y1="22" x2="18" y2="31" stroke="#FFCB70" stroke-width="2.5" stroke-linecap="round"/>
      <line x1="14" y1="27" x2="22" y2="27" stroke="#FFCB70" stroke-width="2.5" stroke-linecap="round"/>
      <circle cx="26" cy="8" r="1.5" fill="#FFF8ED"/>
      <circle cx="29" cy="13" r="1" fill="#FFF8ED" opacity="0.6"/>
    </svg>`,
  },
];

const milestones = [
  {
    year: "2021",
    title: "Creative Workforce Model Takes Shape",
    items: [
      "Expansion of technology and creative programming, including early development of the T.R.A.P model combining digital literacy, music production, and social-emotional learning.",
      "Strengthened partnerships with community organizations serving justice-impacted youth.",
    ],
  },
  {
    year: "2022",
    title: "Major Funding Validation",
    items: [
      `Emergent Works secures significant philanthropic support, including funding connected to <a href="https://startsmall.llc/" target="_blank" rel="noopener">Jack Dorsey's <strong>StartSmall Fund</strong></a>.`,
      "Growth in program reach and formalization of digital skills curriculum pathways.",
    ],
  },
  {
    year: "2023",
    title: "Workforce Outcomes & Alumni Leadership",
    items: [
      "Graduates begin securing employment, internships, and paid contract roles connected to program participation.",
      "Alumni step into teaching, mentorship, and facilitation roles within Emergent Works programs.",
    ],
  },
  {
    year: "2024",
    title: "Scaling Strategy & National Relevance",
    items: [
      "Emergent Works strengthens partnerships with ecosystem leaders including <strong>Chan Zuckerberg Initiative and Community Justice Exchange</strong>.",
      "Launch of strategic planning focused on scaling digital workforce pathways and earned revenue models.",
      "Expansion of programming and alumni engagement structures.",
    ],
  },
  {
    year: "2025",
    title: "Training the Next Generation & Fee-for-Service Launch",
    items: [
      "Launched our Train the Trainer initiative, empowering alumni to become instructors within our curriculum.",
      "Introduced official Fee-for-Service programs, providing our programs directly to partner organizations.",
      "Continued expansion of alumni leadership and workforce impact through paid teaching, mentorship, and facilitation roles.",
    ],
  },
];
---

<Layout title="About">
  <Header currentPath="/about/" />

  <PageHero
    image={heroImage}
    imageAlt="Emergent Works community"
    kicker="Our Story"
    title="From One<br />Belief to a<br />Movement"
  />

  <!-- Origin Story — 2-column grid -->
  <section class="st-section">
    <div class="st-container">
      <div class="origin-grid" data-reveal>
        <div class="origin-image">
          <Image src={missionGroup} alt="Emergent Works community" layout="constrained" loading="lazy" />
        </div>
        <div class="origin-content">
          <span class="st-kicker">Our Story</span>
          <h2>From Personal<br />Experience to<br />Collective Power</h2>
          <p>
            In 2020, Army Armstead Co-founded Emergent Works with a conviction born from lived experience:
            the people most affected by mass incarceration deserved more than a second chance — they
            deserved the tools to build entirely new futures. Having navigated the criminal justice
            system himself, Army understood that the gap between release and reentry wasn't just about
            skills. It was about dignity, community, and belief.
          </p>
          <p>
            What began as a small mentorship initiative in New York City has grown into a comprehensive
            organization offering two distinct programs that address the full spectrum of needs — from
            digital literacy and music production to career development and community engagement.
          </p>
        </div>
      </div>

      <blockquote class="st-pullquote" data-reveal>
        “Digital and AI fluency isn’t optional anymore. It’s the new gateway to freedom, employment and dignity. And that’s what tech for liberation looks like.”
        <cite>— Army Armstead</cite>
      </blockquote>
    </div>
  </section>

  <!-- Mission -->
  <section class="st-section">
    <div class="st-container">
      <div class="st-grid-40-60" data-reveal>
        <div>
          <span class="st-kicker">Our Mission</span>
          <h2>Breaking Cycles<br />Through Technology</h2>
        </div>
        <div>
          <p style="font-size:1.0625rem;line-height:1.8;color:var(--st-text-secondary);">
            {organization.extendedMission}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Staff Composition -->
  <section class="st-section staff-section">
    <div class="st-container">
      <div class="staff-header" data-reveal>
        <span class="st-kicker staff-kicker">Who We Are</span>
        <h2>Led by Those <span class="staff-heading-accent">Who've Lived It</span></h2>
        <p class="staff-sub">
          Our team is our greatest proof of concept. The people leading our programs
          have walked the same path as our participants.
        </p>
      </div>

      <div class="staff-grid">
        {staffStatItems.map((item, i) => (
          <div class="staff-stat" data-reveal={`delay-${i + 1}`}>
            <div class="staff-stat__icon" set:html={item.icon} />
            <div class="staff-stat__value">{item.value}</div>
            <div class="staff-stat__label">{item.label}</div>
            <div class="staff-stat__divider" />
            <p class="staff-stat__desc">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Our Journey Timeline -->
  <section class="st-section timeline-section">
    <div class="st-container">
      <div class="timeline-header" data-reveal>
        <span class="st-kicker" style="justify-content:center;">Our Journey</span>
        <h2>Five Years of<br />Proven Impact</h2>
      </div>

      <div class="timeline">
        {milestones.map((m, i) => (
          <div class="timeline__item" data-reveal={`delay-${Math.min(i + 1, 4)}`}>
            <div class="timeline__year">{m.year}</div>
            <div class="timeline__dot" />
            <div class="timeline__content">
              <h3 class="timeline__title">{m.title}</h3>
              <ul class="timeline__list">
                {m.items.map((item) => (
                  <li set:html={item}></li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Four Pillars -->
  <section class="st-section st-section--white">
    <div class="st-container">
      <div style="text-align:center;" data-reveal>
        <span class="st-kicker">Our Approach</span>
        <h2>Four Pillars of Change</h2>
        <div class="st-divider st-divider--center"></div>
      </div>
      <div class="pillars-grid">
        {programApproach.map((pillar, i) => (
          <div class="pillar-card" data-reveal={`delay-${i + 1}`}>
            <figure class="st-editorial-image">
              <Image src={pillar.image} alt={pillar.title} layout="constrained" style="aspect-ratio:4/3;object-fit:cover;border-radius:2px;" />
            </figure>
            <h3>{pillar.title}</h3>
            <p>{pillar.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="st-section st-section--green" style="text-align:center;">
    <div class="st-container" data-reveal>
      <span class="st-chapter" style="justify-content:center;color:var(--st-gold);">What's next</span>
      <h2 style="color:var(--st-white);">This Story<br />Needs You</h2>
      <p style="color:var(--st-sage);max-width:460px;margin:var(--st-space-4) auto var(--st-space-7);font-size:1.0625rem;">
        Whether you mentor, donate, or partner — you become part of the next chapter.
      </p>
      <a href="/get-involved/" class="st-btn st-btn--gold">Get Involved <span class="st-btn-arrow">&rarr;</span></a>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* ============================================
     ORIGIN STORY — 2-column grid
     ============================================ */
  .origin-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--st-space-9);
    align-items: center;
  }

  .origin-image {
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 4 / 5;
  }

  .origin-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .origin-content h2 {
    color: var(--st-green);
    margin-bottom: var(--st-space-5);
  }

  .origin-content p {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--st-text-secondary);
    margin-bottom: var(--st-space-4);
  }

  .origin-content p:last-child {
    margin-bottom: 0;
  }

  /* ============================================
     STAFF COMPOSITION
     ============================================ */
  .staff-section {
    background: var(--st-green);
  }

  .staff-header {
    text-align: center;
    margin-bottom: var(--st-space-9);
  }

  .staff-header h2 {
    color: var(--st-cream);
    margin-bottom: var(--st-space-4);
  }

  .staff-heading-accent {
    color: var(--st-gold);
  }

  .staff-kicker {
    color: rgba(255, 248, 237, 0.5);
    justify-content: center;
  }

  .staff-sub {
    color: var(--st-sage);
    font-size: 1.0625rem;
    max-width: 480px;
    line-height: 1.7;
    margin: 0 auto;
  }

  .staff-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--st-space-5);
  }

  .staff-stat {
    position: relative;
    overflow: hidden;
    text-align: center;
    padding: var(--st-space-8) var(--st-space-5) var(--st-space-7);
    background: var(--st-green-dark);
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .staff-stat::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--st-gold), rgba(255, 203, 112, 0.3));
  }

  .staff-stat__icon {
    width: 64px;
    height: 64px;
    background: rgba(255, 203, 112, 0.08);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--st-space-5);
  }

  .staff-stat__value {
    font-family: var(--st-font-heading);
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    color: var(--st-gold);
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: var(--st-space-2);
  }

  .staff-stat__label {
    font-family: var(--st-font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--st-gold);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin-bottom: var(--st-space-3);
  }

  .staff-stat__divider {
    width: 28px;
    height: 2px;
    background: rgba(255, 203, 112, 0.3);
    border-radius: 2px;
    margin-bottom: var(--st-space-3);
  }

  .staff-stat__desc {
    font-size: 0.8125rem;
    color: rgba(255, 248, 237, 0.65);
    line-height: 1.6;
    max-width: 22ch;
  }

  /* ============================================
     TIMELINE
     ============================================ */
  .timeline-section {
    background: var(--st-cream);
  }

  .timeline-header {
    text-align: center;
    margin-bottom: var(--st-space-9);
  }

  .timeline-header h2 {
    color: var(--st-green);
  }

  .timeline {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 80px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--st-green);
    opacity: 0.2;
  }

  .timeline__item {
    display: grid;
    grid-template-columns: 60px 40px 1fr;
    gap: 0;
    align-items: start;
    margin-bottom: var(--st-space-6);
  }

  .timeline__item:last-child {
    margin-bottom: 0;
  }

  .timeline__year {
    font-family: var(--st-font-serif);
    font-size: 1rem;
    font-weight: 700;
    color: var(--st-gold);
    text-align: right;
    padding-top: 0.375rem;
    padding-right: var(--st-space-3);
  }

  .timeline__dot {
    width: 12px;
    height: 12px;
    background: var(--st-green);
    border: 3px solid var(--st-cream);
    border-radius: 50%;
    justify-self: center;
    margin-top: 0.5rem;
    position: relative;
    z-index: 1;
  }

  .timeline__content {
    padding-left: var(--st-space-4);
    padding-bottom: var(--st-space-4);
  }

  .timeline__title {
    font-family: var(--st-font-heading);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--st-green);
    margin-bottom: var(--st-space-2);
  }

  .timeline__list {
    list-style: disc;
    padding-left: 1.25rem;
    margin: 0;
  }

  .timeline__list li {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--st-text-secondary);
    margin-bottom: var(--st-space-2);
  }

  .timeline__list li:last-child {
    margin-bottom: 0;
  }

  .timeline__list a {
    color: var(--st-green);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .timeline__list a:hover {
    color: var(--st-gold);
  }

  /* ============================================
     FOUR PILLARS (unchanged)
     ============================================ */
  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--st-space-7);
    margin-top: var(--st-space-8);
  }

  .pillar-card h3 {
    color: var(--st-green);
    margin: var(--st-space-4) 0 var(--st-space-2);
  }

  .pillar-card p {
    font-size: 0.9375rem;
    color: var(--st-text-secondary);
    line-height: 1.7;
  }

  /* ============================================
     RESPONSIVE
     ============================================ */
  @media (max-width: 768px) {
    .origin-grid {
      grid-template-columns: 1fr;
      gap: var(--st-space-6);
    }

    .origin-image {
      aspect-ratio: 16 / 9;
      max-height: 300px;
    }

    .staff-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .timeline {
      max-width: 100%;
    }

    .timeline::before {
      left: 19px;
    }

    .timeline__item {
      grid-template-columns: 40px 1fr;
      column-gap: 0;
      row-gap: var(--st-space-1);
      margin-bottom: var(--st-space-7);
    }

    .timeline__year {
      grid-column: 2;
      grid-row: 1;
      text-align: left;
      padding: 0;
      font-size: 0.875rem;
      line-height: 1.2;
    }

    .timeline__dot {
      grid-column: 1;
      grid-row: 1 / span 2;
      margin-top: 0.375rem;
    }

    .timeline__content {
      grid-column: 2;
      grid-row: 2;
      padding-left: 0;
    }

    .pillars-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 480px) {
    .staff-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
