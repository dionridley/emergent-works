---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { programs, directPrograms, partnerPrograms } from "../../data/programs";
import { testimonials } from "../../data/testimonials";
import { partnerTestimonials } from "../../data/partners";

const blueberry = testimonials.find((t) => t.name === "Blueberry")!;
const julius = testimonials.find((t) => t.name === "Julius")!;
const terrence = testimonials.find((t) => t.name === "Terrence")!;
---

<Layout title="Programs">
  <Header currentPath="/programs/" />

  <section class="prog-hero">
    <div class="st-container">
      <div data-reveal>
        <span class="st-chapter">Our Programs</span>
        <h1>Every Program<br />Begins a Story</h1>
        <p class="prog-hero__sub">Two distinct pathways, each designed to meet participants where they are and equip them with the tools to write their own next chapter.</p>
      </div>
    </div>
  </section>

  <!-- How Our Programs Work -->
  <section class="st-section--compact" style="background:var(--st-white);">
    <div class="st-container">
      <div data-reveal>
        <span class="st-kicker">How Our Programs Work</span>
        <p style="font-size:1.0625rem;line-height:1.85;color:var(--st-text-secondary);max-width:var(--st-max-width-text);">Our programs support system-impacted youth and adults in building the digital skills, confidence, and community needed to thrive in today's world. Led by instructors and mentors who reflect our participants' lived experiences, our programs blend creative expression, technical training, and social-emotional learning. We offer programming in person at our location as well as across New York City and virtual upon request, creating safe, inclusive, and culturally responsive spaces where participants can explore their interests, develop new skills, and prepare for meaningful careers. Every program is designed to restore dignity, build agency, and open doors to long-term opportunity.</p>
      </div>
    </div>
  </section>

  <!-- Direct Programs as editorial features -->
  {directPrograms.map((program, i) => {
    const quote = program.id === "trap" ? julius : terrence;
    return (
      <section class="st-section" style={i % 2 === 1 ? "background:var(--st-white);" : ""}>
        <div class="st-container">
          <div class:list={["prog-feature", { "prog-feature--reverse": i % 2 === 1 }]} data-reveal>
            <figure class="st-editorial-image">
              <img src={program.image} alt={program.title} style="aspect-ratio:4/3;object-fit:cover;" />
              <figcaption>{program.title} — {program.type === "direct" ? "Direct Program" : "Partner Program"}</figcaption>
            </figure>
            <div class="prog-feature__text">
              <span class="st-kicker">{program.type === "direct" ? "Direct Program" : "Partner Program"}</span>
              <h2>{program.title}</h2>
              <p class="prog-feature__meta"><strong>Duration:</strong> {program.duration} &middot; <strong>Eligibility:</strong> {program.eligibility}</p>
              <p>{program.description}</p>
              <blockquote class="st-pullquote" style="margin-top:var(--st-space-6);font-size:1.25rem;">
                "{quote.quote}"
                <cite>— {quote.name}, {program.title} Graduate</cite>
              </blockquote>
              <a href={`/programs/${program.id === "trap" ? "trap" : "teck"}/`} class="st-btn st-btn--primary" style="margin-top:var(--st-space-5);">
                Read Full Story <span class="st-btn-arrow">&rarr;</span>
              </a>
              <a href="/get-involved/" class="st-btn st-btn--outline" style="margin-top:var(--st-space-3);margin-left:var(--st-space-3);">
                Apply
              </a>
            </div>
          </div>
        </div>
      </section>
    );
  })}

  <!-- Partner Programs -->
  <section class="st-section st-section--green">
    <div class="st-container">
      <div data-reveal>
        <span class="st-kicker">Partner Programs</span>
        <h2 style="color:var(--st-white);">Bringing Stories<br />to Communities</h2>
        <div class="st-divider" style="background:var(--st-gold);"></div>
      </div>
      <p style="color:var(--st-sage);font-size:1rem;line-height:1.8;max-width:var(--st-max-width-text);margin-bottom:var(--st-space-8);" data-reveal="delay-1">Non-profit organizations can book our T.RAP and TECK programs as well as customized programs to serve their communities. T.RAP centers social-emotional learning, therapeutic writing, and music production, while TECK builds digital literacy skills including Google Suite, AI, Canva, website development, and entrepreneurial foundations. We tailor each cohort to the specific needs of our partners — blending creative expression, workforce readiness, digital skills, and entrepreneurship as well as other themes requested to equip participants with hands-on learning, mentorship, and real-world opportunities. Empower your participants with hands-on learning, mentorship, and real-world opportunities.</p>
      <div class="partner-grid" data-reveal="delay-2">
        <div class="partner-card">
          <h3 style="color:var(--st-white);">TECK</h3>
          <p style="font-size:0.8125rem;color:var(--st-gold);margin-bottom:var(--st-space-3);">4, 8, or 12 weeks</p>
          <p style="color:var(--st-sage);font-size:0.9375rem;line-height:1.7;">Our TECK program offers flexible digital literacy training exclusively for partner organizations through a fee-for-service model that also integrates alumni workforce development. Cohorts run 4, 8, or 12 weeks and provide participants with hands-on experience in Google Suite, AI tools, Canva, and basic website building. In addition to being led by Emergent Works' proven curriculum and instructors, alumni are trained and engaged as teaching assistants and cohort facilitators—creating paid leadership opportunities that expand our impact beyond a single cohort. TECK not only equips communities with essential technical skills, confidence, and workforce readiness, but also reinvests in alumni by developing them as educators and industry-ready professionals.</p>
        </div>
        <div class="partner-card">
          <h3 style="color:var(--st-white);">T.RAP</h3>
          <p style="font-size:0.8125rem;color:var(--st-gold);margin-bottom:var(--st-space-3);">8–12+ weeks</p>
          <p style="color:var(--st-sage);font-size:0.9375rem;line-height:1.7;">Our T.RAP program offers immersive social-emotional learning and creative skills training exclusively for partner organizations through a fee-for-service model that also supports alumni workforce development. Cohorts run 8–12+ weeks, guiding participants through therapeutic writing, music production, and leadership development. In addition to being led by Emergent Works' experienced instructors, alumni are intentionally trained and engaged as mentors and teaching facilitators when partner organizations book a cohort—creating paid leadership opportunities that expand our impact. T.RAP not only empowers communities with emotional resilience and creative expression, but also empowers alumni by developing them as educators, leaders, and creative professionals.</p>
        </div>
      </div>
      <div class="partner-testimonials" data-reveal="delay-3">
        <h3 style="color:var(--st-gold);font-size:1rem;text-transform:uppercase;letter-spacing:0.1em;margin-top:var(--st-space-8);margin-bottom:var(--st-space-5);">What Our Partners Say</h3>
        <div class="partner-quote-grid">
          {partnerTestimonials.map((pt) => (
            <div class="partner-quote-card">
              <blockquote style="font-size:0.9375rem;font-style:italic;line-height:1.7;color:var(--st-sage);margin:0;">
                "{pt.quote}"
              </blockquote>
              <cite style="display:block;font-style:normal;font-size:0.8125rem;font-weight:600;color:var(--st-gold);margin-top:var(--st-space-4);">— {pt.organization}</cite>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="st-section" style="text-align:center;">
    <div class="st-container" data-reveal>
      <blockquote class="st-pullquote" style="border-left:none;text-align:center;max-width:640px;margin:0 auto var(--st-space-6);">
        "Overall, the Program at Emergent Works has been a life-changing experience, equipping me with the skills, knowledge, and support needed to advance my career and personal growth."
        <cite>— Blueberry</cite>
      </blockquote>
      <div style="display:flex;gap:var(--st-space-4);justify-content:center;flex-wrap:wrap;">
        <a href="/get-involved/" class="st-btn st-btn--primary">Get Involved <span class="st-btn-arrow">&rarr;</span></a>
        <a href="/impact/" class="st-btn st-btn--outline">Explore Impact <span class="st-btn-arrow">&rarr;</span></a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .prog-hero {
    padding: calc(var(--st-header-height) + var(--st-space-16)) 0 var(--st-space-10);
    background: var(--st-cream);
  }

  .prog-hero h1 { color: var(--st-green); }

  .prog-hero__sub {
    font-size: 1.125rem;
    color: var(--st-text-secondary);
    max-width: 520px;
    margin-top: var(--st-space-5);
    line-height: 1.75;
  }

  .prog-feature {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--st-space-8);
    align-items: start;
  }

  .prog-feature--reverse {
    direction: rtl;
  }

  .prog-feature--reverse > * {
    direction: ltr;
  }

  .prog-feature__text h2 {
    color: var(--st-green);
    margin-bottom: var(--st-space-3);
  }

  .prog-feature__meta {
    font-size: 0.875rem;
    color: var(--st-text-light);
    margin-bottom: var(--st-space-4);
  }

  .prog-feature__meta strong {
    color: var(--st-text-secondary);
  }

  .prog-feature__text p {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--st-text-secondary);
  }

  .partner-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--st-space-6);
  }

  .partner-card {
    padding: var(--st-space-6);
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(177,211,187,0.1);
    border-radius: 4px;
  }

  .partner-quote-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--st-space-5);
  }

  .partner-quote-card {
    padding: var(--st-space-5);
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(177,211,187,0.1);
    border-radius: 4px;
  }

  @media (max-width: 768px) {
    .prog-feature, .prog-feature--reverse {
      grid-template-columns: 1fr;
      direction: ltr;
    }
    .partner-grid { grid-template-columns: 1fr; }
    .partner-quote-grid { grid-template-columns: 1fr; }
  }
</style>