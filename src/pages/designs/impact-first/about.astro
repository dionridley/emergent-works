---
/**
 * Impact First — About Page
 * Organization origin story, mission, staff composition, timeline.
 */

import ImpactFirstLayout from "../../../layouts/designs/ImpactFirstLayout.astro";
import Header from "../../../components/designs/impact-first/Header.astro";
import Footer from "../../../components/designs/impact-first/Footer.astro";

import { organization } from "../../../data/organization";
import { programApproach } from "../../../data/programs";

const currentPath = "/designs/impact-first/about/";

const milestones = [
  { year: "2020", title: "Founded", desc: "Army Armstead launches Emergent Works from personal experience with the justice system, determined to create pathways for others." },
  { year: "2021", title: "First Cohort", desc: "Our inaugural Technical Mentorship cohort graduates 12 participants, with 9 finding employment within 3 months." },
  { year: "2022", title: "T.RAP Launches", desc: "We expand beyond tech to launch T.RAP, blending music production with workforce readiness for NYC youth ages 16-24." },
  { year: "2023", title: "TECK for Partners", desc: "The TECK program launches, bringing digital literacy training to partner organizations serving system-impacted communities." },
  { year: "2024", title: "261 Graduates", desc: "We surpass 260 graduates with a 98%+ no re-offense rate and 73% employment rate — redefining what reentry outcomes can look like." },
  { year: "2025", title: "Scaling Impact", desc: "Expanding partnerships and program capacity to reach more system-impacted individuals across New York and beyond." },
];

const staffStatItems = [
  { value: organization.staffStats.alumni, label: "Program Alumni", desc: "of our staff are program graduates" },
  { value: organization.staffStats.systemImpacted, label: "System-Impacted", desc: "have direct experience with the justice system" },
  { value: organization.staffStats.bipoc, label: "BIPOC", desc: "identify as Black, Indigenous, or people of color" },
  { value: organization.staffStats.femaleIdentifying, label: "Female-Identifying", desc: "identify as female" },
];
---

<ImpactFirstLayout title="About Us" description="Learn about Emergent Works' mission to empower system-impacted individuals through technology and creativity.">
  <Header currentPath={currentPath} />

  <!-- Page Hero -->
  <section class="about-hero">
    <div class="if-container">
      <div class="about-hero__content" data-reveal>
        <span class="if-eyebrow">About Emergent Works</span>
        <h1>Breaking Cycles,<br />Building Futures</h1>
        <p class="about-hero__sub">
          {organization.extendedMission}
        </p>
      </div>
    </div>
  </section>

  <!-- Origin Story -->
  <section class="if-section origin-section">
    <div class="if-container">
      <div class="origin-grid" data-reveal>
        <div class="origin-image">
          <img src="/images/about/ourstory-portrait.jpg" alt="Emergent Works origin" loading="lazy" />
        </div>
        <div class="origin-content">
          <span class="if-eyebrow">Our Story</span>
          <h2>From Personal<br />Experience to<br />Collective Power</h2>
          <p>
            Emergent Works was founded in 2020 by Army Armstead, who experienced the
            criminal justice system firsthand and saw a profound gap: the people most
            affected by incarceration were the least served by reentry programs.
          </p>
          <p>
            What began as a small mentorship initiative has grown into a comprehensive
            organization offering three distinct programs that address the full spectrum
            of needs — from digital literacy and music production to career development
            and community engagement.
          </p>
          <p>
            Today, 100% of our staff are program alumni. We don't just talk about
            reentry — we live it, we build it, and we prove it works.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Staff Composition -->
  <section class="if-section if-section--dark staff-section">
    <div class="if-container">
      <div class="staff-header" data-reveal>
        <span class="if-eyebrow">Who We Are</span>
        <h2>Led by Those<br />Who've Lived It</h2>
        <p class="staff-sub">
          Our team is our greatest proof of concept. The people leading our programs
          have walked the same path as our participants.
        </p>
      </div>

      <div class="staff-grid">
        {staffStatItems.map((item, i) => (
          <div class="staff-stat" data-reveal={`delay-${i + 1}`}>
            <div class="staff-stat__value">{item.value}</div>
            <div class="staff-stat__label">{item.label}</div>
            <p class="staff-stat__desc">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="if-section timeline-section">
    <div class="if-container">
      <div class="timeline-header" data-reveal>
        <span class="if-eyebrow">Our Journey</span>
        <h2>Five Years of<br />Proven Impact</h2>
      </div>

      <div class="timeline">
        {milestones.map((m, i) => (
          <div class="timeline__item" data-reveal={`delay-${Math.min(i + 1, 4)}`}>
            <div class="timeline__year">{m.year}</div>
            <div class="timeline__dot" />
            <div class="timeline__content">
              <h3 class="timeline__title">{m.title}</h3>
              <p class="timeline__desc">{m.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Our Approach -->
  <section class="if-section if-section--white approach-section">
    <div class="if-container">
      <div class="approach-header" data-reveal>
        <span class="if-eyebrow">Our Approach</span>
        <h2>Four Pillars of<br />Transformation</h2>
        <p class="approach-sub">
          Every program we run is built on these interconnected pillars — because
          lasting change requires more than a single skill.
        </p>
      </div>

      <div class="approach-grid">
        {programApproach.map((pillar, i) => (
          <div class="approach-card" data-reveal={`delay-${i + 1}`}>
            <div class="approach-card__image">
              <img src={pillar.image} alt={pillar.title} loading="lazy" />
            </div>
            <div class="approach-card__body">
              <h3 class="approach-card__title">{pillar.title}</h3>
              <p class="approach-card__desc">{pillar.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="if-section if-section--green about-cta">
    <div class="if-container" style="text-align: center;">
      <div data-reveal>
        <h2 style="color: var(--if-white); margin-bottom: var(--if-space-4);">Ready to Make<br />a Difference?</h2>
        <p style="color: var(--if-sage); max-width: 480px; margin: 0 auto var(--if-space-7); font-size: 1.0625rem; line-height: 1.7;">
          Whether you want to donate, mentor, partner, or volunteer — there's a
          place for you in our community.
        </p>
        <a href="/designs/impact-first/get-involved/" class="if-btn if-btn--gold">
          Get Involved <span class="if-btn-arrow">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <Footer />
</ImpactFirstLayout>

<style>
  /* ============================================
     PAGE HERO
     ============================================ */
  .about-hero {
    padding: calc(var(--if-header-height) + var(--if-space-12)) 0 var(--if-space-10);
    background: var(--if-cream);
    position: relative;
  }

  .about-hero__content {
    max-width: 680px;
  }

  .about-hero h1 {
    color: var(--if-green);
    margin-bottom: var(--if-space-5);
  }

  .about-hero__sub {
    font-size: 1.125rem;
    line-height: 1.75;
    color: var(--if-text-secondary);
  }

  /* ============================================
     ORIGIN STORY
     ============================================ */
  .origin-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--if-space-9);
    align-items: center;
  }

  .origin-image {
    border-radius: var(--if-radius-lg);
    overflow: hidden;
    aspect-ratio: 4 / 5;
  }

  .origin-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .origin-content h2 {
    color: var(--if-green);
    margin-bottom: var(--if-space-5);
  }

  .origin-content p {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--if-text-secondary);
    margin-bottom: var(--if-space-4);
  }

  .origin-content p:last-child {
    margin-bottom: 0;
    color: var(--if-text);
    font-weight: 500;
  }

  /* ============================================
     STAFF COMPOSITION
     ============================================ */
  .staff-header {
    margin-bottom: var(--if-space-9);
  }

  .staff-header h2 {
    color: var(--if-white);
    margin-bottom: var(--if-space-4);
  }

  .staff-sub {
    color: var(--if-sage);
    font-size: 1.0625rem;
    max-width: 480px;
    line-height: 1.7;
  }

  .staff-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--if-space-5);
  }

  .staff-stat {
    text-align: center;
    padding: var(--if-space-7) var(--if-space-4);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(177, 211, 187, 0.1);
    border-radius: var(--if-radius-md);
  }

  .staff-stat__value {
    font-family: var(--if-font-heading);
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    color: var(--if-gold);
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: var(--if-space-2);
  }

  .staff-stat__label {
    font-family: var(--if-font-heading);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--if-white);
    margin-bottom: var(--if-space-2);
  }

  .staff-stat__desc {
    font-size: 0.8125rem;
    color: var(--if-sage);
    line-height: 1.5;
  }

  /* ============================================
     TIMELINE
     ============================================ */
  .timeline-header {
    text-align: center;
    margin-bottom: var(--if-space-9);
  }

  .timeline-header h2 {
    color: var(--if-green);
  }

  .timeline {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 80px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--if-border);
  }

  .timeline__item {
    display: grid;
    grid-template-columns: 60px 40px 1fr;
    gap: 0;
    align-items: start;
    margin-bottom: var(--if-space-6);
  }

  .timeline__item:last-child {
    margin-bottom: 0;
  }

  .timeline__year {
    font-family: var(--if-font-heading);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--if-gold);
    text-align: right;
    padding-top: 0.375rem;
    padding-right: var(--if-space-3);
  }

  .timeline__dot {
    width: 12px;
    height: 12px;
    background: var(--if-green);
    border: 3px solid var(--if-cream);
    border-radius: 50%;
    justify-self: center;
    margin-top: 0.5rem;
    position: relative;
    z-index: 1;
  }

  .timeline__content {
    padding-left: var(--if-space-4);
    padding-bottom: var(--if-space-4);
  }

  .timeline__title {
    font-family: var(--if-font-heading);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--if-green);
    margin-bottom: var(--if-space-2);
  }

  .timeline__desc {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--if-text-secondary);
  }

  /* ============================================
     OUR APPROACH
     ============================================ */
  .approach-header {
    text-align: center;
    margin-bottom: var(--if-space-9);
  }

  .approach-header h2 {
    color: var(--if-green);
    margin-bottom: var(--if-space-4);
  }

  .approach-header .if-eyebrow {
    justify-content: center;
  }

  .approach-header .if-eyebrow::before {
    display: none;
  }

  .approach-sub {
    font-size: 1rem;
    color: var(--if-text-secondary);
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .approach-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--if-space-5);
  }

  .approach-card {
    display: flex;
    gap: var(--if-space-5);
    padding: var(--if-space-5);
    border-radius: var(--if-radius-md);
    border: 1px solid var(--if-border-light);
    transition: transform var(--if-duration) var(--if-ease),
                box-shadow var(--if-duration) var(--if-ease);
  }

  .approach-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--if-shadow-md);
  }

  .approach-card__image {
    width: 80px;
    height: 80px;
    border-radius: var(--if-radius-sm);
    overflow: hidden;
    flex-shrink: 0;
  }

  .approach-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .approach-card__title {
    font-size: 1rem;
    color: var(--if-green);
    margin-bottom: var(--if-space-2);
  }

  .approach-card__desc {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--if-text-secondary);
  }

  /* ============================================
     RESPONSIVE
     ============================================ */
  @media (max-width: 768px) {
    .origin-grid {
      grid-template-columns: 1fr;
      gap: var(--if-space-6);
    }

    .origin-image {
      aspect-ratio: 16 / 9;
      max-height: 300px;
    }

    .staff-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .timeline::before {
      left: 20px;
    }

    .timeline__item {
      grid-template-columns: 0 40px 1fr;
    }

    .timeline__year {
      position: absolute;
      font-size: 0.75rem;
      padding: 0;
      margin-bottom: 0;
    }

    .approach-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .staff-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
