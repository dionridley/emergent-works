---
/**
 * Impact First — Team Page
 * Staff grid, board of directors, advisory board, staff composition infographic.
 */

import ImpactFirstLayout from "../../../layouts/designs/ImpactFirstLayout.astro";
import Header from "../../../components/designs/impact-first/Header.astro";
import Footer from "../../../components/designs/impact-first/Footer.astro";

import { staff, boardOfDirectors, advisoryBoard } from "../../../data/team";
import { organization } from "../../../data/organization";

const currentPath = "/designs/impact-first/team/";
---

<ImpactFirstLayout title="Our Team" description="Meet the people behind Emergent Works — 100% program alumni leading the mission.">
  <Header currentPath={currentPath} />

  <section class="team-hero">
    <div class="if-container">
      <div class="team-hero__content" data-reveal>
        <span class="if-eyebrow">Our Team</span>
        <h1>Led by Those<br />Who've Lived It</h1>
        <p class="team-hero__sub">
          100% of our staff are program alumni. They don't just understand our
          participants' journeys — they've walked the same path.
        </p>
      </div>
    </div>
  </section>

  <!-- Staff -->
  <section class="if-section">
    <div class="if-container">
      <div data-reveal>
        <span class="if-eyebrow">Staff</span>
        <h2>Our Team</h2>
      </div>
      <div class="team-grid" data-reveal="delay-1">
        {staff.map((member) => (
          <div class="team-card">
            <div class="team-card__image">
              <img src={member.image} alt={member.name} loading="lazy" />
            </div>
            <div class="team-card__info">
              <h3 class="team-card__name">{member.name}</h3>
              <span class="team-card__title">{member.title}</span>
              {member.bio && <p class="team-card__bio">{member.bio}</p>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Staff Composition Infographic -->
  <section class="if-section if-section--dark composition-section">
    <div class="if-container">
      <div class="composition-grid" data-reveal>
        <div>
          <span class="if-eyebrow">Staff Composition</span>
          <h2 style="color: var(--if-white);">Our Team<br />Reflects Our Mission</h2>
          <p style="color: var(--if-sage); max-width: 380px; line-height: 1.7; margin-top: var(--if-space-4);">
            The people leading our programs have walked the same path as our participants.
            This isn't just representation — it's the foundation of our effectiveness.
          </p>
        </div>
        <div class="composition-bars">
          {[
            { label: "Program Alumni", value: organization.staffStats.alumni, pct: 100 },
            { label: "System-Impacted", value: organization.staffStats.systemImpacted, pct: 80 },
            { label: "BIPOC", value: organization.staffStats.bipoc, pct: 80 },
            { label: "Female-Identifying", value: organization.staffStats.femaleIdentifying, pct: 40 },
          ].map((item) => (
            <div class="composition-bar-item">
              <div class="composition-bar-header">
                <span class="composition-bar-label">{item.label}</span>
                <span class="composition-bar-value">{item.value}</span>
              </div>
              <div class="composition-bar-track">
                <div class="composition-bar-fill" style={`width: ${item.pct}%`} />
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Board of Directors -->
  <section class="if-section">
    <div class="if-container">
      <div data-reveal>
        <span class="if-eyebrow">Governance</span>
        <h2>Board of Directors</h2>
      </div>
      <div class="board-grid" data-reveal="delay-1">
        {boardOfDirectors.map((member) => (
          <div class="board-card">
            <div class="board-card__image">
              <img src={member.image} alt={member.name} loading="lazy" />
            </div>
            <h4 class="board-card__name">{member.name}</h4>
            <span class="board-card__title">{member.title}</span>
            {member.bio && <p class="board-card__bio">{member.bio}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Advisory Board -->
  <section class="if-section if-section--white">
    <div class="if-container">
      <div data-reveal>
        <span class="if-eyebrow">Advisory</span>
        <h2>Advisory Board</h2>
      </div>
      <div class="board-grid board-grid--advisory" data-reveal="delay-1">
        {advisoryBoard.map((member) => (
          <div class="board-card">
            <div class="board-card__image">
              <img src={member.image} alt={member.name} loading="lazy" />
            </div>
            <h4 class="board-card__name">{member.name}</h4>
            <span class="board-card__title">{member.title}</span>
            {member.bio && <p class="board-card__bio">{member.bio}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="if-section if-section--green" style="text-align: center;">
    <div class="if-container" data-reveal>
      <h2 style="color: var(--if-white); margin-bottom: var(--if-space-4);">Join Our Team</h2>
      <p style="color: var(--if-sage); max-width: 480px; margin: 0 auto var(--if-space-7); line-height: 1.7;">
        Whether as a mentor, volunteer, or team member — we're always looking for
        people who believe in our mission.
      </p>
      <a href="/designs/impact-first/get-involved/" class="if-btn if-btn--gold">
        Get Involved <span class="if-btn-arrow">&rarr;</span>
      </a>
    </div>
  </section>

  <Footer />
</ImpactFirstLayout>

<style>
  .team-hero {
    padding: calc(var(--if-header-height) + var(--if-space-12)) 0 var(--if-space-10);
    background: var(--if-cream);
  }

  .team-hero__content {
    max-width: 640px;
  }

  .team-hero h1 {
    color: var(--if-green);
    margin-bottom: var(--if-space-5);
  }

  .team-hero__sub {
    font-size: 1.125rem;
    line-height: 1.75;
    color: var(--if-text-secondary);
  }

  /* Staff Grid */
  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--if-space-5);
    margin-top: var(--if-space-6);
  }

  .team-card {
    display: flex;
    gap: var(--if-space-5);
    padding: var(--if-space-5);
    background: var(--if-white);
    border-radius: var(--if-radius-md);
    border: 1px solid var(--if-border-light);
    transition: transform var(--if-duration) var(--if-ease),
                box-shadow var(--if-duration) var(--if-ease);
  }

  .team-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--if-shadow-md);
  }

  .team-card__image {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    border: 3px solid var(--if-sage);
  }

  .team-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .team-card__name {
    font-family: var(--if-font-heading);
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--if-green);
    margin-bottom: 0.125rem;
  }

  .team-card__title {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--if-gold);
    display: block;
    margin-bottom: var(--if-space-2);
  }

  .team-card__bio {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--if-text-secondary);
  }

  /* Composition Infographic */
  .composition-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--if-space-9);
    align-items: center;
  }

  .composition-bars {
    display: flex;
    flex-direction: column;
    gap: var(--if-space-5);
  }

  .composition-bar-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: var(--if-space-2);
  }

  .composition-bar-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--if-sage);
  }

  .composition-bar-value {
    font-family: var(--if-font-heading);
    font-size: 1rem;
    font-weight: 800;
    color: var(--if-gold);
  }

  .composition-bar-track {
    height: 8px;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 4px;
    overflow: hidden;
  }

  .composition-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--if-gold), var(--if-gold-light));
    border-radius: 4px;
    transition: width 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Board Grid */
  .board-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--if-space-5);
    margin-top: var(--if-space-6);
  }

  .board-card {
    text-align: center;
    padding: var(--if-space-6) var(--if-space-4);
  }

  .board-card__image {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    overflow: hidden;
    margin: 0 auto var(--if-space-4);
    border: 3px solid var(--if-sage);
  }

  .board-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .board-card__name {
    font-family: var(--if-font-heading);
    font-size: 1rem;
    font-weight: 700;
    color: var(--if-green);
    margin-bottom: 0.125rem;
  }

  .board-card__title {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--if-gold);
    display: block;
    margin-bottom: var(--if-space-3);
  }

  .board-card__bio {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--if-text-secondary);
  }

  @media (max-width: 768px) {
    .team-grid {
      grid-template-columns: 1fr;
    }

    .composition-grid {
      grid-template-columns: 1fr;
    }

    .board-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .board-grid {
      grid-template-columns: 1fr;
    }

    .team-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }
</style>
