---
/**
 * Impact First — T.RAP Program Detail
 */

import ImpactFirstLayout from "../../../../layouts/designs/ImpactFirstLayout.astro";
import Header from "../../../../components/designs/impact-first/Header.astro";
import Footer from "../../../../components/designs/impact-first/Footer.astro";

import { programs } from "../../../../data/programs";
import { testimonials } from "../../../../data/testimonials";
import { expandedProgramDetails } from "../../../../data/fabricated";

const currentPath = "/designs/impact-first/programs/";

const trap = programs.find((p) => p.id === "trap")!;
const trapDetails = expandedProgramDetails.find((d) => d.programId === "trap")!;
const julius = testimonials.find((t) => t.name === "Julius")!;
const sheisty = testimonials.find((t) => t.name === "Sheisty")!;
---

<ImpactFirstLayout title="T.RAP Program" description={trap.description}>
  <Header currentPath={currentPath} />

  <section class="trap-hero">
    <div class="trap-hero__image">
      <img src={trap.image} alt="T.RAP studio session" />
      <div class="trap-hero__overlay" />
    </div>
    <div class="if-container">
      <div class="trap-hero__content" data-reveal>
        <span class="if-eyebrow">Direct Program</span>
        <h1>T.RAP</h1>
        <p class="trap-hero__tagline">
          Creative workforce development through music production,
          songwriting, and social-emotional learning.
        </p>
        <div class="trap-hero__meta">
          <div class="trap-hero__meta-item">
            <span class="trap-hero__meta-label">Duration</span>
            <span class="trap-hero__meta-value">{trap.duration}</span>
          </div>
          <div class="trap-hero__meta-item">
            <span class="trap-hero__meta-label">Eligibility</span>
            <span class="trap-hero__meta-value">{trap.eligibility}</span>
          </div>
          <div class="trap-hero__meta-item">
            <span class="trap-hero__meta-label">Enrollment</span>
            <span class="trap-hero__meta-value">{trap.applyBy}</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="if-section">
    <div class="if-container">
      <div class="trap-overview" data-reveal>
        <div class="trap-overview__text">
          <span class="if-eyebrow">Program Overview</span>
          <h2>More Than Music</h2>
          <p>{trap.description}</p>
          <div class="trap-features">
            {trap.features.map((f) => (
              <span class="trap-feature-tag">{f}</span>
            ))}
          </div>
        </div>
        <div class="trap-overview__schedule">
          <h3>Weekly Schedule</h3>
          <ul class="trap-schedule-list">
            {trapDetails.weeklySchedule?.map((s) => (
              <li>{s}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="if-section if-section--white">
    <div class="if-container">
      <div data-reveal>
        <span class="if-eyebrow">Curriculum</span>
        <h2>The Journey</h2>
      </div>
      <div class="trap-curriculum" data-reveal="delay-1">
        {trapDetails.curriculumOutline?.map((phase, i) => {
          const [title, ...descParts] = phase.split(' — ');
          return (
            <div class="trap-curriculum__phase">
              <div class="trap-curriculum__number">{String(i + 1).padStart(2, '0')}</div>
              <div>
                <h4 class="trap-curriculum__title">{title}</h4>
                {descParts.length > 0 && <p class="trap-curriculum__desc">{descParts.join(' — ')}</p>}
              </div>
            </div>
          );
        })}
      </div>
      <div class="trap-tools" data-reveal="delay-2">
        <h3>Tools You'll Learn</h3>
        <div class="trap-tools__grid">
          {trapDetails.toolsCovered?.map((tool) => (
            <span class="trap-tool-badge">{tool}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="if-section if-section--green">
    <div class="if-container">
      <div data-reveal>
        <span class="if-eyebrow">Participant Voices</span>
        <h2 style="color: var(--if-white);">Hear From T.RAP Alumni</h2>
      </div>
      <div class="trap-testimonials" data-reveal="delay-1">
        {[sheisty, julius].map((t) => (
          <div class="trap-testimonial-card">
            {t.sectionTitle && <h4 class="trap-testimonial-card__title">{t.sectionTitle}</h4>}
            <blockquote>"{t.quote}"</blockquote>
            <cite>— {t.name}</cite>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="if-section" style="text-align: center;">
    <div class="if-container" data-reveal>
      <h2 style="color: var(--if-green); margin-bottom: var(--if-space-4);">Ready to Find Your Voice?</h2>
      <p style="color: var(--if-text-secondary); max-width: 480px; margin: 0 auto var(--if-space-7); font-size: 1.0625rem; line-height: 1.7;">
        Applications are open on a rolling basis. T.RAP is free for all eligible participants,
        with milestone-based stipends available.
      </p>
      <a href="/designs/impact-first/get-involved/" class="if-btn if-btn--primary">
        Apply Now <span class="if-btn-arrow">&rarr;</span>
      </a>
    </div>
  </section>

  <Footer />
</ImpactFirstLayout>

<style>
  .trap-hero {
    position: relative;
    min-height: 480px;
    display: flex;
    align-items: flex-end;
    padding: calc(var(--if-header-height) + var(--if-space-9)) 0 var(--if-space-9);
  }

  .trap-hero__image {
    position: absolute;
    inset: 0;
  }

  .trap-hero__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .trap-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(5, 40, 18, 0.95) 0%, rgba(5, 40, 18, 0.6) 50%, rgba(5, 40, 18, 0.3) 100%);
  }

  .trap-hero__content {
    position: relative;
    z-index: 1;
  }

  .trap-hero h1 {
    font-size: clamp(3rem, 8vw, 5rem);
    color: var(--if-white);
    margin-bottom: var(--if-space-4);
  }

  .trap-hero__tagline {
    font-size: 1.125rem;
    color: var(--if-sage);
    max-width: 500px;
    margin-bottom: var(--if-space-6);
    line-height: 1.7;
  }

  .trap-hero__meta {
    display: flex;
    gap: var(--if-space-6);
    flex-wrap: wrap;
  }

  .trap-hero__meta-label {
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--if-gold);
    font-weight: 700;
    display: block;
    margin-bottom: 0.125rem;
  }

  .trap-hero__meta-value {
    font-size: 0.875rem;
    color: var(--if-white);
  }

  .trap-overview {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--if-space-8);
    align-items: start;
  }

  .trap-overview__text h2 {
    color: var(--if-green);
    margin-bottom: var(--if-space-4);
  }

  .trap-overview__text p {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--if-text-secondary);
    margin-bottom: var(--if-space-5);
  }

  .trap-features {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .trap-feature-tag {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.375rem 0.75rem;
    border-radius: 999px;
    background: rgba(32, 73, 60, 0.06);
    color: var(--if-green-muted);
  }

  .trap-overview__schedule {
    padding: var(--if-space-6);
    background: var(--if-white);
    border: 1px solid var(--if-border-light);
    border-radius: var(--if-radius-md);
  }

  .trap-overview__schedule h3 {
    font-size: 1rem;
    color: var(--if-green);
    margin-bottom: var(--if-space-4);
  }

  .trap-schedule-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--if-space-3);
  }

  .trap-schedule-list li {
    font-size: 0.875rem;
    color: var(--if-text-secondary);
    padding-left: 1.25rem;
    position: relative;
    line-height: 1.5;
  }

  .trap-schedule-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--if-gold);
  }

  .trap-curriculum {
    display: flex;
    flex-direction: column;
    gap: var(--if-space-5);
    margin-top: var(--if-space-6);
    margin-bottom: var(--if-space-8);
  }

  .trap-curriculum__phase {
    display: flex;
    gap: var(--if-space-5);
    align-items: start;
    padding: var(--if-space-5);
    background: var(--if-cream);
    border-radius: var(--if-radius-md);
    border: 1px solid var(--if-border-light);
  }

  .trap-curriculum__number {
    font-family: var(--if-font-heading);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--if-gold);
    flex-shrink: 0;
    width: 48px;
  }

  .trap-curriculum__title {
    font-size: 1rem;
    color: var(--if-green);
    margin-bottom: var(--if-space-1);
  }

  .trap-curriculum__desc {
    font-size: 0.875rem;
    color: var(--if-text-secondary);
    line-height: 1.6;
  }

  .trap-tools {
    padding: var(--if-space-6);
    background: var(--if-cream);
    border-radius: var(--if-radius-md);
  }

  .trap-tools h3 {
    font-size: 1rem;
    color: var(--if-green);
    margin-bottom: var(--if-space-4);
  }

  .trap-tools__grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--if-space-3);
  }

  .trap-tool-badge {
    font-size: 0.875rem;
    font-weight: 600;
    padding: 0.5rem 1rem;
    border-radius: var(--if-radius-sm);
    background: var(--if-green);
    color: var(--if-gold);
  }

  .trap-testimonials {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--if-space-5);
    margin-top: var(--if-space-6);
  }

  .trap-testimonial-card {
    padding: var(--if-space-6);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(177, 211, 187, 0.1);
    border-radius: var(--if-radius-md);
  }

  .trap-testimonial-card__title {
    font-family: var(--if-font-heading);
    font-size: 1rem;
    color: var(--if-gold);
    margin-bottom: var(--if-space-3);
  }

  .trap-testimonial-card blockquote {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--if-sage);
    margin-bottom: var(--if-space-4);
  }

  .trap-testimonial-card cite {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--if-white);
    font-style: normal;
  }

  @media (max-width: 768px) {
    .trap-overview {
      grid-template-columns: 1fr;
    }

    .trap-testimonials {
      grid-template-columns: 1fr;
    }

    .trap-hero__meta {
      flex-direction: column;
      gap: var(--if-space-3);
    }
  }
</style>
