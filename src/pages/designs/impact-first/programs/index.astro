---
/**
 * Impact First — Programs Overview
 * Programs presented as pathways with clear outcomes data.
 */

import ImpactFirstLayout from "../../../../layouts/designs/ImpactFirstLayout.astro";
import Header from "../../../../components/designs/impact-first/Header.astro";
import Footer from "../../../../components/designs/impact-first/Footer.astro";
import ProgramPathway from "../../../../components/designs/impact-first/ProgramPathway.astro";

import { programs, directPrograms, partnerPrograms, programApproach } from "../../../../data/programs";
import { primaryStats } from "../../../../data/stats";

const currentPath = "/designs/impact-first/programs/";

const trapPathway = [
  { number: 1, title: "Apply & Enroll", description: "NYC youth ages 16-24 who identify as Black, Brown and system-impacted. Applications accepted on a rolling basis." },
  { number: 2, title: "Foundation Building", description: "Songwriting basics, DAW introduction, studio etiquette, and social-emotional learning groundwork." },
  { number: 3, title: "Production & Recording", description: "Beat making, arrangement, recording techniques — paired with civic engagement and digital literacy." },
  { number: 4, title: "Showcase & Career Prep", description: "Final project recording, live performance, career readiness planning, and milestone-based stipend completion." },
];

const mentorshipPathway = [
  { number: 1, title: "Apply & Match", description: "System-impacted individuals 18+ apply and are matched with an industry professional mentor." },
  { number: 2, title: "Foundations (Weeks 1-3)", description: "Digital literacy foundations, development environment setup, goal setting with your mentor." },
  { number: 3, title: "Skill Building (Weeks 4-9)", description: "Core skills in your chosen track — HTML/CSS/JS, UI/UX, data literacy — with weekly 1-on-1 sessions." },
  { number: 4, title: "Capstone & Graduate (Weeks 10-12)", description: "Build a portfolio-ready capstone project, prep for job search, and graduate with industry connections." },
];

const teckPathway = [
  { number: 1, title: "Partner Organization Onboard", description: "We work with your organization to customize a cohort — 4, 8, or 12 weeks based on your community's needs." },
  { number: 2, title: "Digital Literacy Mastery", description: "Google Workspace, Canva, AI tools — hands-on experience with the digital tools needed for today's workforce." },
  { number: 3, title: "Professional Presence", description: "Basic website building, LinkedIn profiles, and professional digital communication skills." },
  { number: 4, title: "Graduation & Continued Support", description: "Participants graduate with certifiable skills, a professional digital presence, and ongoing community access." },
];
---

<ImpactFirstLayout title="Programs" description="Explore Emergent Works' programs: T.RAP, Technical Mentorship, and TECK.">
  <Header currentPath={currentPath} />

  <!-- Page Hero -->
  <section class="programs-hero">
    <div class="if-container">
      <div class="programs-hero__content" data-reveal>
        <span class="if-eyebrow">Our Programs</span>
        <h1>Three Pathways.<br />One Mission.</h1>
        <p class="programs-hero__sub">
          Each program is designed to meet participants where they are — whether that's
          building digital literacy, finding a voice through music, or launching a tech career.
        </p>
      </div>

      <div class="programs-hero__stats" data-reveal="delay-1">
        {primaryStats.map((stat) => (
          <div class="programs-hero__stat">
            <div class="programs-hero__stat-value">{stat.value}</div>
            <div class="programs-hero__stat-label">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Direct Programs -->
  <section class="if-section programs-direct">
    <div class="if-container">
      <div data-reveal>
        <span class="if-eyebrow">Direct Programs</span>
        <h2>Programs We Run</h2>
        <p class="section-sub">
          Open enrollment programs that serve individuals directly through creative
          workforce development and technical mentorship.
        </p>
      </div>

      <div class="pathways-grid">
        {directPrograms.map((program) => {
          const pathway = program.id === "trap" ? trapPathway : mentorshipPathway;
          return (
            <div class="pathway-wrapper" data-reveal="delay-1">
              <div class="pathway-intro">
                <div class="pathway-intro__image">
                  <img src={program.image} alt={program.title} loading="lazy" />
                </div>
                <h3>{program.title}</h3>
                <p class="pathway-intro__meta">
                  <strong>Duration:</strong> {program.duration}<br />
                  <strong>Eligibility:</strong> {program.eligibility}
                </p>
                <p class="pathway-intro__desc">{program.description}</p>
                {program.id === "trap" && (
                  <a href="/designs/impact-first/programs/trap/" class="if-btn if-btn--primary if-btn--sm" style="margin-top: 1rem;">
                    Program Details <span class="if-btn-arrow">&rarr;</span>
                  </a>
                )}
              </div>
              <ProgramPathway programName={program.title} steps={pathway} />
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Partner Programs -->
  <section class="if-section if-section--white programs-partner">
    <div class="if-container">
      <div data-reveal>
        <span class="if-eyebrow">Partner Programs</span>
        <h2>Programs for Organizations</h2>
        <p class="section-sub">
          Customized programs delivered through partner organizations, bringing our
          proven curriculum to communities across NYC and beyond.
        </p>
      </div>

      <div class="partner-programs-grid">
        {partnerPrograms.map((program, i) => (
          <div class="partner-program-card if-card" data-reveal={`delay-${i + 1}`}>
            <div class="partner-program-card__image">
              <img src={program.image} alt={program.title} loading="lazy" />
            </div>
            <h3>{program.title}</h3>
            <p class="partner-program-card__meta">
              Duration: {program.duration}
            </p>
            <p class="partner-program-card__desc">{program.description}</p>
            <div class="partner-program-card__features">
              {program.features.map((f) => (
                <span class="partner-program-card__tag">{f}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TECK Pathway -->
  <section class="if-section programs-teck-pathway">
    <div class="if-container">
      <div class="teck-pathway-wrapper" data-reveal>
        <div>
          <span class="if-eyebrow">How TECK Works</span>
          <h2>The TECK Program<br />Journey</h2>
          <p class="section-sub" style="margin-bottom: var(--if-space-6);">
            Flexible digital literacy training designed to work within your
            organization's existing programs and timeline.
          </p>
          <a href="/designs/impact-first/programs/teck/" class="if-btn if-btn--primary if-btn--sm">
            Learn About TECK <span class="if-btn-arrow">&rarr;</span>
          </a>
        </div>
        <ProgramPathway programName="TECK" steps={teckPathway} />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="if-section if-section--green" style="text-align: center;">
    <div class="if-container" data-reveal>
      <h2 style="color: var(--if-white); margin-bottom: var(--if-space-4);">Ready to Get Started?</h2>
      <p style="color: var(--if-sage); max-width: 480px; margin: 0 auto var(--if-space-7); font-size: 1.0625rem; line-height: 1.7;">
        Whether you're an individual looking to build skills or an organization
        looking to partner — we'd love to hear from you.
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/designs/impact-first/get-involved/" class="if-btn if-btn--gold">
          Get Involved <span class="if-btn-arrow">&rarr;</span>
        </a>
        <a href="/designs/impact-first/get-involved/" class="if-btn if-btn--outline-white">
          Partner With Us
        </a>
      </div>
    </div>
  </section>

  <Footer />
</ImpactFirstLayout>

<style>
  .programs-hero {
    padding: calc(var(--if-header-height) + var(--if-space-12)) 0 var(--if-space-10);
    background: var(--if-cream);
  }

  .programs-hero__content {
    max-width: 640px;
    margin-bottom: var(--if-space-8);
  }

  .programs-hero h1 {
    color: var(--if-green);
    margin-bottom: var(--if-space-5);
  }

  .programs-hero__sub {
    font-size: 1.125rem;
    line-height: 1.75;
    color: var(--if-text-secondary);
  }

  .programs-hero__stats {
    display: flex;
    gap: var(--if-space-8);
    padding: var(--if-space-6) var(--if-space-7);
    background: var(--if-green);
    border-radius: var(--if-radius-lg);
    max-width: 560px;
  }

  .programs-hero__stat-value {
    font-family: var(--if-font-heading);
    font-size: 2rem;
    font-weight: 800;
    color: var(--if-gold);
    letter-spacing: -0.02em;
  }

  .programs-hero__stat-label {
    font-size: 0.8125rem;
    color: var(--if-sage);
    font-weight: 500;
  }

  .section-sub {
    font-size: 1.0625rem;
    color: var(--if-text-secondary);
    max-width: 520px;
    line-height: 1.7;
    margin-top: var(--if-space-4);
  }

  .pathways-grid {
    display: flex;
    flex-direction: column;
    gap: var(--if-space-10);
    margin-top: var(--if-space-8);
  }

  .pathway-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--if-space-8);
    align-items: start;
  }

  .pathway-intro__image {
    border-radius: var(--if-radius-md);
    overflow: hidden;
    height: 200px;
    margin-bottom: var(--if-space-5);
  }

  .pathway-intro__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pathway-intro h3 {
    font-family: var(--if-font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--if-green);
    margin-bottom: var(--if-space-3);
  }

  .pathway-intro__meta {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--if-text-secondary);
    margin-bottom: var(--if-space-3);
  }

  .pathway-intro__meta strong {
    color: var(--if-text);
  }

  .pathway-intro__desc {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--if-text-secondary);
  }

  .partner-programs-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--if-space-5);
    margin-top: var(--if-space-8);
  }

  .partner-program-card__image {
    height: 160px;
    border-radius: var(--if-radius-sm);
    overflow: hidden;
    margin-bottom: var(--if-space-4);
  }

  .partner-program-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .partner-program-card h3 {
    font-family: var(--if-font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--if-green);
    margin-bottom: var(--if-space-2);
  }

  .partner-program-card__meta {
    font-size: 0.8125rem;
    color: var(--if-text-light);
    margin-bottom: var(--if-space-3);
  }

  .partner-program-card__desc {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--if-text-secondary);
    margin-bottom: var(--if-space-4);
  }

  .partner-program-card__features {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .partner-program-card__tag {
    font-size: 0.6875rem;
    font-weight: 600;
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
    background: rgba(32, 73, 60, 0.06);
    color: var(--if-green-muted);
  }

  .teck-pathway-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--if-space-8);
    align-items: start;
  }

  .teck-pathway-wrapper h2 {
    color: var(--if-green);
  }

  @media (max-width: 768px) {
    .programs-hero__stats {
      flex-direction: column;
      gap: var(--if-space-4);
    }

    .pathway-wrapper,
    .teck-pathway-wrapper {
      grid-template-columns: 1fr;
    }

    .partner-programs-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
