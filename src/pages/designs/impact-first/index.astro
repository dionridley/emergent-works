---
/**
 * Impact First — Homepage
 * Data-driven, institutional-credibility design.
 * The numbers are the hero. Every section leads with data.
 */

import ImpactFirstLayout from "../../../layouts/designs/ImpactFirstLayout.astro";
import Header from "../../../components/designs/impact-first/Header.astro";
import Footer from "../../../components/designs/impact-first/Footer.astro";
import ImpactHero from "../../../components/designs/impact-first/ImpactHero.astro";
import StatComparison from "../../../components/designs/impact-first/StatComparison.astro";
import PartnerGrid from "../../../components/designs/impact-first/PartnerGrid.astro";
import DonationImpact from "../../../components/designs/impact-first/DonationImpact.astro";

import { organization } from "../../../data/organization";
import { programs } from "../../../data/programs";
import { testimonials } from "../../../data/testimonials";
import { nationalComparisons } from "../../../data/stats";

const currentPath = "/designs/impact-first/";

const nashid = testimonials.find((t) => t.name === "Nashid")!;
const dontay = testimonials.find((t) => t.name === "Dontay")!;
const zeek = testimonials.find((t) => t.name === "Zeek")!;

const programLinks: Record<string, string> = {
  trap: "/designs/impact-first/programs/trap/",
  "technical-mentorship": "/designs/impact-first/programs/",
  teck: "/designs/impact-first/programs/teck/",
  "trap-partner": "/designs/impact-first/programs/trap/",
};
---

<ImpactFirstLayout title="Home" description={organization.mission}>
  <Header currentPath={currentPath} />
  <ImpactHero />

  <!-- ================================================
       BY THE NUMBERS — EW vs National Averages
       ================================================ -->
  <section class="if-section if-section--dark numbers-section">
    <div class="if-container">
      <div class="numbers-header" data-reveal>
        <span class="if-eyebrow">By The Numbers</span>
        <h2>Measurable Impact,<br />Undeniable Results</h2>
        <p class="numbers-sub">
          Our outcomes speak for themselves. Here's how Emergent Works graduates
          compare to national averages for formerly incarcerated individuals.
        </p>
      </div>
      <StatComparison comparisons={nationalComparisons as any} />
    </div>
  </section>

  <!-- ================================================
       OUR PROGRAMS
       ================================================ -->
  <section class="if-section programs-section">
    <div class="if-container">
      <div class="programs-header" data-reveal>
        <span class="if-eyebrow">Our Programs</span>
        <h2>Pathways to<br />New Futures</h2>
        <p class="programs-sub">
          Three distinct programs — each designed to meet participants where they
          are and equip them with the skills to thrive.
        </p>
      </div>

      <div class="programs-grid">
        {programs.map((program, i) => (
          <a
            href={programLinks[program.id] || "/designs/impact-first/programs/"}
            class="program-card"
            data-reveal={`delay-${i + 1}`}
          >
            <div class="program-card__image">
              <img src={program.image} alt={program.title} loading="lazy" />
              <span class="program-card__type">
                {program.type === "direct" ? "Direct Program" : "Partner Program"}
              </span>
            </div>
            <div class="program-card__body">
              <h3 class="program-card__title">{program.title}</h3>
              <div class="program-card__meta">
                <span class="program-card__duration">{program.duration}</span>
              </div>
              <p class="program-card__desc">
                {program.description.slice(0, 160)}...
              </p>
              <div class="program-card__features">
                {program.features.slice(0, 3).map((f) => (
                  <span class="program-card__tag">{f}</span>
                ))}
              </div>
              <span class="program-card__link">
                Learn more <span class="if-btn-arrow">&rarr;</span>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ================================================
       COMMUNITY VOICES
       ================================================ -->
  <section class="if-section if-section--green voices-section">
    <div class="if-container">
      <div class="voices-header" data-reveal>
        <span class="if-eyebrow">Community Voices</span>
        <h2>In Their Own Words</h2>
      </div>

      <!-- Featured: Nashid -->
      <div class="voice-featured" data-reveal="delay-1">
        <div class="voice-featured__image">
          <img src={nashid.image} alt={nashid.name} loading="lazy" />
        </div>
        <div class="voice-featured__content">
          <svg class="voice-featured__quote-mark" width="48" height="36" viewBox="0 0 48 36" fill="none">
            <path d="M0 36V20.4C0 14.4 1.2 9.6 3.6 6C6.12 2.4 10.2 0 15.84 0L17.28 5.76C14.16 6.24 11.88 7.56 10.44 9.72C9.12 11.76 8.4 14.28 8.28 17.28H14.4V36H0ZM27.36 36V20.4C27.36 14.4 28.56 9.6 30.96 6C33.48 2.4 37.56 0 43.2 0L44.64 5.76C41.52 6.24 39.24 7.56 37.8 9.72C36.48 11.76 35.76 14.28 35.64 17.28H41.76V36H27.36Z" fill="currentColor" />
          </svg>
          <blockquote class="voice-featured__quote">
            {nashid.quote}
          </blockquote>
          {nashid.extendedQuote && (
            <p class="voice-featured__extended">{nashid.extendedQuote}</p>
          )}
          <cite class="voice-featured__name">— {nashid.name}</cite>
        </div>
      </div>

      <!-- Secondary testimonials -->
      <div class="voice-cards" data-reveal="delay-2">
        {[dontay, zeek].map((t) => (
          <div class="voice-card">
            <div class="voice-card__top">
              {t.image && (
                <img class="voice-card__avatar" src={t.image} alt={t.name} loading="lazy" />
              )}
              <cite class="voice-card__name">{t.name}</cite>
            </div>
            <blockquote class="voice-card__quote">
              "{t.quote.slice(0, 200)}{t.quote.length > 200 ? '...' : ''}"
            </blockquote>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ================================================
       OUR PARTNERS
       ================================================ -->
  <section class="if-section partners-section">
    <div class="if-container">
      <div class="partners-header" data-reveal>
        <span class="if-eyebrow">Our Partners</span>
        <h2>Building Together</h2>
        <p class="partners-sub">
          We collaborate with foundations, corporations, government agencies, and
          community organizations to maximize our collective impact.
        </p>
      </div>
      <PartnerGrid />
    </div>
  </section>

  <!-- ================================================
       DONATION IMPACT
       ================================================ -->
  <DonationImpact />

  <Footer />
</ImpactFirstLayout>

<style>
  /* ============================================
     BY THE NUMBERS
     ============================================ */

  .numbers-section {
    position: relative;
    overflow: hidden;
  }

  .numbers-section::before {
    content: '';
    position: absolute;
    top: -120px;
    right: -80px;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 203, 112, 0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  .numbers-header {
    margin-bottom: var(--if-space-9);
  }

  .numbers-header h2 {
    color: var(--if-white);
    margin-bottom: var(--if-space-4);
  }

  .numbers-sub {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--if-sage);
    max-width: 540px;
  }

  /* ============================================
     PROGRAMS
     ============================================ */

  .programs-header {
    text-align: center;
    margin-bottom: var(--if-space-9);
  }

  .programs-header h2 {
    color: var(--if-green);
    margin-bottom: var(--if-space-4);
  }

  .programs-header .if-eyebrow {
    justify-content: center;
  }

  .programs-header .if-eyebrow::before {
    display: none;
  }

  .programs-sub {
    font-size: 1.0625rem;
    color: var(--if-text-secondary);
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .programs-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--if-space-5);
  }

  .program-card {
    display: flex;
    flex-direction: column;
    background: var(--if-white);
    border-radius: var(--if-radius-lg);
    overflow: hidden;
    border: 1px solid var(--if-border-light);
    text-decoration: none;
    color: inherit;
    transition: transform var(--if-duration) var(--if-ease),
                box-shadow var(--if-duration) var(--if-ease);
  }

  .program-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--if-shadow-lg);
  }

  .program-card__image {
    position: relative;
    height: 200px;
    overflow: hidden;
  }

  .program-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--if-ease);
  }

  .program-card:hover .program-card__image img {
    transform: scale(1.04);
  }

  .program-card__type {
    position: absolute;
    top: var(--if-space-3);
    left: var(--if-space-3);
    background: var(--if-green);
    color: var(--if-gold);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.25rem 0.625rem;
    border-radius: 4px;
  }

  .program-card__body {
    padding: var(--if-space-5) var(--if-space-6) var(--if-space-6);
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .program-card__title {
    font-family: var(--if-font-heading);
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--if-green);
    margin-bottom: var(--if-space-2);
  }

  .program-card__meta {
    display: flex;
    gap: var(--if-space-3);
    margin-bottom: var(--if-space-3);
  }

  .program-card__duration {
    font-size: 0.8125rem;
    color: var(--if-text-light);
    font-weight: 500;
  }

  .program-card__desc {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--if-text-secondary);
    margin-bottom: var(--if-space-4);
  }

  .program-card__features {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: var(--if-space-4);
  }

  .program-card__tag {
    font-size: 0.6875rem;
    font-weight: 600;
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
    background: rgba(32, 73, 60, 0.06);
    color: var(--if-green-muted);
  }

  .program-card__link {
    margin-top: auto;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--if-green);
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
  }

  .program-card:hover .program-card__link .if-btn-arrow {
    transform: translateX(3px);
  }

  /* ============================================
     COMMUNITY VOICES
     ============================================ */

  .voices-header {
    margin-bottom: var(--if-space-8);
  }

  .voices-header h2 {
    color: var(--if-white);
  }

  .voice-featured {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--if-space-8);
    align-items: start;
    margin-bottom: var(--if-space-8);
    padding: var(--if-space-7);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(177, 211, 187, 0.1);
    border-radius: var(--if-radius-lg);
  }

  .voice-featured__image {
    border-radius: var(--if-radius-md);
    overflow: hidden;
    aspect-ratio: 3 / 4;
  }

  .voice-featured__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .voice-featured__content {
    padding-top: var(--if-space-2);
  }

  .voice-featured__quote-mark {
    color: var(--if-gold);
    opacity: 0.3;
    margin-bottom: var(--if-space-4);
  }

  .voice-featured__quote {
    font-family: var(--if-font-heading);
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    font-weight: 400;
    line-height: 1.6;
    color: var(--if-white);
    margin-bottom: var(--if-space-4);
  }

  .voice-featured__extended {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--if-sage);
    font-style: italic;
    margin-bottom: var(--if-space-5);
  }

  .voice-featured__name {
    font-family: var(--if-font-body);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--if-gold);
    font-style: normal;
  }

  .voice-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--if-space-5);
  }

  .voice-card {
    padding: var(--if-space-6);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(177, 211, 187, 0.1);
    border-radius: var(--if-radius-md);
  }

  .voice-card__top {
    display: flex;
    align-items: center;
    gap: var(--if-space-3);
    margin-bottom: var(--if-space-4);
  }

  .voice-card__avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(255, 203, 112, 0.3);
  }

  .voice-card__name {
    font-family: var(--if-font-body);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--if-white);
    font-style: normal;
  }

  .voice-card__quote {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--if-sage);
  }

  /* ============================================
     PARTNERS
     ============================================ */

  .partners-header {
    text-align: center;
    margin-bottom: var(--if-space-8);
  }

  .partners-header h2 {
    color: var(--if-green);
    margin-bottom: var(--if-space-4);
  }

  .partners-header .if-eyebrow {
    justify-content: center;
  }

  .partners-header .if-eyebrow::before {
    display: none;
  }

  .partners-sub {
    font-size: 1rem;
    color: var(--if-text-secondary);
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* ============================================
     RESPONSIVE
     ============================================ */

  @media (max-width: 768px) {
    .programs-grid {
      grid-template-columns: 1fr;
    }

    .voice-featured {
      grid-template-columns: 1fr;
      padding: var(--if-space-5);
    }

    .voice-featured__image {
      aspect-ratio: 16 / 9;
      max-height: 240px;
    }

    .voice-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
