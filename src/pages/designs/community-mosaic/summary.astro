---
/**
 * Community Mosaic — Content Summary
 * Documents all real vs fabricated content, stock images, and typography deviations.
 */

import CommunityMosaicLayout from "../../../layouts/designs/CommunityMosaicLayout.astro";
import ContentSummaryTable from "../../../components/designs/shared/ContentSummaryTable.astro";
import type { ContentItem, StockImage, TypographyDeviation } from "../../../components/designs/shared/ContentSummaryTable.astro";

const contentItems: ContentItem[] = [
  { item: "Organization name, EIN, address", source: "Real", page: "All pages (footer)", notes: "From existing site" },
  { item: "Mission statement", source: "Real", page: "Home, About", notes: "From existing site" },
  { item: "Extended mission statement", source: "Real", page: "About", notes: "From existing site" },
  { item: "Social media links", source: "Real", page: "All pages (footer), Get Involved", notes: "From existing site" },

  { item: "261 graduates stat", source: "Real", page: "Home (stat cards)", notes: "From existing impact page" },
  { item: "73% employed stat", source: "Real", page: "Home (stat cards)", notes: "From existing impact page" },
  { item: "98%+ no re-offense stat", source: "Real", page: "Home (stat cards)", notes: "From existing impact page" },
  { item: "$2+ above min wage stat", source: "Real", page: "Home (stat cards)", notes: "From existing impact page" },

  { item: "T.RAP program description, eligibility, duration", source: "Real", page: "Programs, T.RAP detail", notes: "From existing programs page" },
  { item: "Technical Mentorship description", source: "Real", page: "Programs", notes: "From existing programs page" },
  { item: "TECK description", source: "Real", page: "Programs, TECK detail", notes: "From existing programs page" },
  { item: "T.RAP curriculum outline (4 phases)", source: "Fabricated", page: "T.RAP detail", notes: "Plausible progression — needs verification" },
  { item: "TECK curriculum modules", source: "Fabricated", page: "TECK detail", notes: "Based on tools listed in real description — needs verification" },

  { item: "Nashid testimonial + image", source: "Real", page: "Home (quote card)", notes: "From existing site" },
  { item: "Dontay testimonial + image", source: "Real", page: "Home (quote card)", notes: "From existing site" },
  { item: "Zeek testimonial + image", source: "Real", page: "Home (quote card)", notes: "From existing site" },
  { item: "Sheisty testimonial", source: "Real", page: "T.RAP detail", notes: "From existing site" },
  { item: "Julius testimonial", source: "Real", page: "T.RAP detail", notes: "From existing site" },

  { item: "Aisha — alumni story (T.RAP)", source: "Fabricated", page: "T.RAP detail", notes: "Fabricated alumni — replace with real alumni" },
  { item: "DeShawn — alumni story (TECK)", source: "Fabricated", page: "TECK detail", notes: "Fabricated alumni — replace with real alumni" },
  { item: "Priya — fabricated mentor quote", source: "Fabricated", page: "Get Involved", notes: "Fabricated mentor — replace with real mentor testimonial" },
  { item: "Fabricated events (3)", source: "Fabricated", page: "Home (event cards)", notes: "Replace with real upcoming events" },

  { item: "Staff names and titles (5 people)", source: "Real", page: "Team", notes: "From existing team page" },
  { item: "Board names and titles (5 people)", source: "Real", page: "Team", notes: "From existing team page" },
  { item: "Advisory board names and titles (3 people)", source: "Real", page: "Team", notes: "From existing team page" },
  { item: "All team member bios", source: "Fabricated", page: "Team", notes: "Plausible bios — replace with real bios" },
  { item: "Staff composition stats", source: "Real", page: "About", notes: "From existing site" },

  { item: "Partner organization names and logos (13)", source: "Real", page: "Home (partner grid)", notes: "From existing partner page" },
  { item: "Donation tiers ($50, $100, $200, $1,000)", source: "Real", page: "Get Involved, Home", notes: "From existing donation page" },
  { item: "Tax deductibility notice", source: "Real", page: "Get Involved", notes: "From existing donation page" },

  { item: "Origin story narrative", source: "Fabricated", page: "About", notes: "Based on real founder info — verify details" },
  { item: "Program approach pillars", source: "Real", page: "About", notes: "From existing site" },

  { item: "Team placeholder photos (4 images)", source: "Real", page: "Team", notes: "Existing placeholder images" },
  { item: "Testimonial photos (Dontay, Zeek, Nashid)", source: "Real", page: "Home", notes: "From existing site" },
  { item: "Program photos (trap-studio, teck-library)", source: "Real", page: "Programs, T.RAP, TECK", notes: "From existing site" },
  { item: "Hero photo (community.jpg)", source: "Real", page: "Home", notes: "From existing site" },
  { item: "About photo (ourstory-portrait)", source: "Real", page: "About", notes: "From existing site" },

  { item: "Stock: portrait-5.jpg (mentor)", source: "Stock Photo", page: "Get Involved", notes: "Replace with real mentor photo" },
  { item: "Stock: music-studio-2.jpg (T.RAP)", source: "Stock Photo", page: "T.RAP detail", notes: "Replace with real studio photo" },
  { item: "Stock: tech-coding-4.jpg (TECK)", source: "Stock Photo", page: "TECK detail", notes: "Replace with real program photo" },
];

const stockImages: StockImage[] = [
  { filename: "portrait-5.jpg", sourceUrl: "https://unsplash.com", usedOn: "Get Involved (Mentor story)", description: "Portrait for fabricated mentor Priya" },
  { filename: "music-studio-2.jpg", sourceUrl: "https://unsplash.com", usedOn: "T.RAP detail (Alumni story)", description: "Music studio scene" },
  { filename: "tech-coding-4.jpg", sourceUrl: "https://unsplash.com", usedOn: "TECK detail (Alumni story)", description: "Coding scene" },
];

const typographyDeviations: TypographyDeviation[] = [];
---

<CommunityMosaicLayout title="Content Summary">
  <div style="padding-top: calc(var(--cm-header-height) + var(--cm-space-8));">
    <div class="cm-container">
      <div style="margin-bottom: var(--cm-space-6);">
        <a href="/designs/community-mosaic/" style="font-size: 0.875rem; color: var(--cm-green); font-weight: 500;">
          &larr; Back to Community Mosaic
        </a>
      </div>
    </div>
    <ContentSummaryTable
      designName="Community Mosaic"
      contentItems={contentItems}
      stockImages={stockImages}
      typographyDeviations={typographyDeviations}
    />
  </div>
</CommunityMosaicLayout>
