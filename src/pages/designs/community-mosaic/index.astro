---
import CommunityMosaicLayout from "../../../layouts/designs/CommunityMosaicLayout.astro";
import Header from "../../../components/designs/community-mosaic/Header.astro";
import Footer from "../../../components/designs/community-mosaic/Footer.astro";
import { organization } from "../../../data/organization";
import { programs } from "../../../data/programs";
import { primaryStats } from "../../../data/stats";
import { testimonials } from "../../../data/testimonials";
import { partners } from "../../../data/partners";
import { donationTiers } from "../../../data/donation";
import { fabricatedEvents } from "../../../data/fabricated";

const nashid = testimonials.find((t) => t.name === "Nashid")!;
const dontay = testimonials.find((t) => t.name === "Dontay")!;
const zeek = testimonials.find((t) => t.name === "Zeek")!;
const directPrograms = programs.filter((p) => p.type === "direct");
const upcomingEvents = fabricatedEvents.slice(0, 3);
---

<CommunityMosaicLayout title="Home" description={organization.mission}>
  <Header currentPath="/designs/community-mosaic/" />

  <!-- Hero Section -->
  <section class="cm-hero">
    <div class="cm-container">
      <div class="cm-bento">
        <!-- Hero text card -->
        <div class="cm-card cm-card--green cm-card--static cm-span-2 cm-span-row-2" data-card-reveal data-card-delay="0">
          <div class="hero-content">
            <span class="cm-kicker">Emergent Works</span>
            <h1>Building Futures<br />Through Tech</h1>
            <p style="margin-top:var(--cm-space-4);margin-bottom:var(--cm-space-6);color:var(--cm-sage);font-size:var(--cm-text-md);max-width:400px;line-height:1.7;">{organization.mission}</p>
            <div style="display:flex;gap:var(--cm-space-3);flex-wrap:wrap;">
              <a href="/designs/community-mosaic/programs/" class="cm-btn cm-btn--gold">Explore Programs <span class="cm-btn-arrow">&rarr;</span></a>
              <a href="/designs/community-mosaic/get-involved/" class="cm-btn cm-btn--outline-white">Get Involved</a>
            </div>
          </div>
        </div>

        <!-- Stat cards -->
        {primaryStats.slice(0, 2).map((stat, i) => (
          <div class:list={["cm-card cm-card--stat", i === 0 ? "cm-card--gold" : "cm-card--peach"]} data-card-reveal data-card-delay={String(i + 1)}>
            <div class="cm-stat__value">{stat.value}</div>
            <div class="cm-stat__label">{stat.label}</div>
            <p class="cm-stat__desc">{stat.description}</p>
          </div>
        ))}

        <!-- Photo card -->
        <div class="cm-card cm-card--photo" style="min-height:220px;" data-card-reveal data-card-delay="3">
          <img src="/images/hero/community.jpg" alt="Emergent Works community" />
          <div class="cm-card__photo-overlay">
            <h4>Our Community</h4>
            <p>261+ graduates and counting</p>
          </div>
        </div>

        <!-- Featured quote -->
        <div class="cm-card cm-card--quote cm-card--cream cm-span-2" data-card-reveal data-card-delay="4">
          <p class="cm-quote__text">"{nashid.quote}"</p>
          <div class="cm-quote__cite">
            {nashid.image && <img src={nashid.image} alt={nashid.name} class="cm-quote__avatar" />}
            <div>
              <div class="cm-quote__name">{nashid.name}</div>
              <div class="cm-quote__role">Program Graduate</div>
            </div>
          </div>
        </div>

        <!-- More stats -->
        {primaryStats.slice(2, 4).map((stat, i) => (
          <div class="cm-card cm-card--stat cm-card--sage" data-card-reveal data-card-delay={String(i + 5)}>
            <div class="cm-stat__value" style="color:var(--cm-green);">{stat.value}</div>
            <div class="cm-stat__label" style="color:var(--cm-green);">{stat.label}</div>
            <p class="cm-stat__desc">{stat.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Programs -->
  <section class="cm-section">
    <div class="cm-container">
      <div class="cm-section-header" data-reveal>
        <span class="cm-kicker">Programs</span>
        <h2>Three Pathways<br />to Transformation</h2>
        <div class="cm-divider"></div>
      </div>
      <div class="cm-bento cm-bento--2col">
        {directPrograms.map((program, i) => (
          <div class="cm-card cm-card--program" data-card-reveal data-card-delay={String(i)}>
            <div class="cm-card__program-image">
              <img src={program.image} alt={program.title} />
            </div>
            <span class="cm-tag cm-tag--green">{program.type === "direct" ? "Direct Program" : "Partner"}</span>
            <h3 style="color:var(--cm-green);margin:var(--cm-space-3) 0 var(--cm-space-2);">{program.title}</h3>
            <p style="color:var(--cm-text-secondary);font-size:var(--cm-text-sm);line-height:1.7;flex:1;">{program.description.slice(0, 180)}...</p>
            <div class="cm-card__program-meta">
              <span><strong>Duration:</strong> {program.duration}</span>
            </div>
            <a href={`/designs/community-mosaic/programs/${program.id === "trap" ? "trap" : "teck"}/`} class="cm-btn cm-btn--outline" style="margin-top:var(--cm-space-4);align-self:flex-start;">
              Learn More <span class="cm-btn-arrow">&rarr;</span>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Voices -->
  <section class="cm-section cm-section--white">
    <div class="cm-container">
      <div class="cm-section-header" data-reveal>
        <span class="cm-kicker">Voices</span>
        <h2>Community Stories</h2>
        <div class="cm-divider"></div>
      </div>
      <div class="cm-bento cm-bento--3col">
        {[nashid, dontay, zeek].map((t, i) => (
          <div class:list={["cm-card cm-card--quote", i === 0 ? "cm-card--cream" : ""]} data-card-reveal data-card-delay={String(i)}>
            <p class="cm-quote__text">"{t.quote.slice(0, 200)}{t.quote.length > 200 ? '...' : ''}"</p>
            <div class="cm-quote__cite">
              {t.image && <img src={t.image} alt={t.name} class="cm-quote__avatar" />}
              <div>
                <div class="cm-quote__name">{t.name}</div>
                <div class="cm-quote__role">{t.sectionTitle || "Program Graduate"}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Events -->
  <section class="cm-section">
    <div class="cm-container">
      <div class="cm-section-header" data-reveal>
        <span class="cm-kicker">Upcoming</span>
        <h2>Events &amp; Workshops</h2>
        <div class="cm-divider"></div>
      </div>
      <div class="cm-bento cm-bento--3col">
        {upcomingEvents.map((event, i) => (
          <div class="cm-card cm-card--event" data-card-reveal data-card-delay={String(i)}>
            <div class="cm-card__event-date">
              <span class="cm-card__event-month">{event.date.split(" ")[0].slice(0, 3)}</span>
              <span class="cm-card__event-day">{event.date.split(" ")[1]?.replace(",", "") || ""}</span>
            </div>
            <div>
              <h4 style="color:var(--cm-green);font-size:var(--cm-text-base);margin-bottom:var(--cm-space-1);">{event.title}</h4>
              <p style="font-size:var(--cm-text-sm);color:var(--cm-text-secondary);line-height:1.6;">{event.description.slice(0, 120)}...</p>
              <span class="cm-tag cm-tag--peach" style="margin-top:var(--cm-space-2);">{event.type}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Partners -->
  <section class="cm-section cm-section--green">
    <div class="cm-container">
      <div class="cm-section-header" data-reveal>
        <span class="cm-kicker">Partners</span>
        <h2 style="color:var(--cm-white);">Our Partners</h2>
        <div class="cm-divider"></div>
      </div>
      <div class="partners-grid" data-reveal>
        {partners.slice(0, 10).map((partner) => (
          <div class="partner-logo">
            <img src={partner.logo} alt={partner.name} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Donation CTA -->
  <section class="cm-section">
    <div class="cm-container">
      <div class="cm-bento">
        <div class="cm-card cm-card--dark cm-card--cta cm-span-2" data-card-reveal data-card-delay="0">
          <div>
            <span class="cm-kicker">Support</span>
            <h2 style="color:var(--cm-white);margin-bottom:var(--cm-space-3);">Add Your Card<br />to the Mosaic</h2>
            <p style="color:var(--cm-sage);max-width:360px;">Every contribution helps build the complete picture of community transformation.</p>
          </div>
          <a href="/designs/community-mosaic/get-involved/" class="cm-card__cta-arrow" aria-label="Get involved">&rarr;</a>
        </div>
        {donationTiers.slice(0, 2).map((tier, i) => (
          <div class:list={["cm-card cm-card--stat", i === 0 ? "cm-card--gold" : "cm-card--peach"]} data-card-reveal data-card-delay={String(i + 1)}>
            <div class="cm-stat__value">{tier.label}</div>
            <div class="cm-stat__label">Donation</div>
            <p class="cm-stat__desc">{tier.impact}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</CommunityMosaicLayout>

<style>
  .cm-hero {
    padding: calc(var(--cm-header-height) + var(--cm-space-8)) 0 var(--cm-space-6);
  }

  .hero-content h1 {
    color: var(--cm-white);
    font-size: var(--cm-text-5xl);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.05;
  }

  .partners-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--cm-space-5);
    margin-top: var(--cm-space-4);
  }

  .partner-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--cm-space-4);
    background: rgba(255,255,255,0.06);
    border-radius: var(--cm-radius-sm);
    transition: background var(--cm-duration);
  }

  .partner-logo:hover {
    background: rgba(255,255,255,0.12);
  }

  .partner-logo img {
    max-height: 40px;
    width: auto;
    filter: brightness(0) invert(1);
    opacity: 0.7;
    transition: opacity var(--cm-duration);
  }

  .partner-logo:hover img {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .partners-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 480px) {
    .partners-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
