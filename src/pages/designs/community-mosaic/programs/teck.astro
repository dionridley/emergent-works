---
import CommunityMosaicLayout from "../../../../layouts/designs/CommunityMosaicLayout.astro";
import Header from "../../../../components/designs/community-mosaic/Header.astro";
import Footer from "../../../../components/designs/community-mosaic/Footer.astro";
import { programs } from "../../../../data/programs";
import { expandedProgramDetails, alumniStories } from "../../../../data/fabricated";
import { partners } from "../../../../data/partners";

const teck = programs.find((p) => p.id === "teck")!;
const teckDetails = expandedProgramDetails.find((d) => d.programId === "teck")!;
const deshawn = alumniStories.find((s) => s.program === "TECK")!;
---

<CommunityMosaicLayout title="TECK Program">
  <Header currentPath="/designs/community-mosaic/programs/" />

  <section class="cm-hero-simple">
    <div class="cm-container">
      <div data-reveal>
        <span class="cm-kicker">Program</span>
        <h1>TECK</h1>
        <p class="hero-sub">Digital literacy training that transforms confusion into confidence, one skill at a time.</p>
      </div>
    </div>
  </section>

  <!-- Program Info Cards -->
  <section class="cm-section">
    <div class="cm-container">
      <div class="cm-bento">
        <div class="cm-card cm-card--photo cm-span-2 cm-span-row-2" style="min-height:360px;" data-card-reveal data-card-delay="0">
          <img src={teck.image} alt="TECK workshop" />
          <div class="cm-card__photo-overlay">
            <h3>Digital Literacy. Real Impact.</h3>
          </div>
        </div>
        <div class="cm-card cm-card--gold cm-card--stat" data-card-reveal data-card-delay="1">
          <div class="cm-stat__value">{teck.duration}</div>
          <div class="cm-stat__label">Program Length</div>
        </div>
        <div class="cm-card cm-card--green" data-card-reveal data-card-delay="2">
          <strong style="font-size:var(--cm-text-xs);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:var(--cm-space-2);color:var(--cm-gold);">Format</strong>
          <p style="font-size:var(--cm-text-sm);line-height:1.6;color:var(--cm-sage);">Partner-customized cohorts tailored to community needs</p>
        </div>
        <div class="cm-card cm-card--cream" data-card-reveal data-card-delay="3">
          <p style="font-size:var(--cm-text-sm);line-height:1.7;color:var(--cm-text-secondary);">{teck.description.slice(0, 160)}...</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Alumni Story -->
  <section class="cm-section cm-section--white">
    <div class="cm-container">
      <div class="cm-section-header" data-reveal>
        <span class="cm-kicker">Alumni Story</span>
        <h2>{deshawn.name}'s<br />Transformation</h2>
        <div class="cm-divider"></div>
      </div>
      <div class="cm-bento cm-bento--2col">
        <div class="cm-card cm-card--cream cm-card--static" data-card-reveal data-card-delay="0">
          <p style="color:var(--cm-text-secondary);line-height:1.8;margin-bottom:var(--cm-space-4);">{deshawn.beforeSummary} {deshawn.journey}</p>
          <blockquote style="font-size:var(--cm-text-md);font-weight:500;color:var(--cm-green);line-height:1.7;padding-left:var(--cm-space-4);border-left:3px solid var(--cm-gold);margin-bottom:var(--cm-space-3);">
            "{deshawn.quote}"
          </blockquote>
          <p style="font-size:var(--cm-text-sm);color:var(--cm-text-light);">— {deshawn.name}, {deshawn.currentRole}</p>
          <p style="color:var(--cm-text-secondary);line-height:1.8;margin-top:var(--cm-space-4);">{deshawn.outcome}</p>
        </div>
        <div class="cm-card cm-card--photo" style="min-height:300px;" data-card-reveal data-card-delay="1">
          <img src="/images/designs/stock/tech-coding-4.jpg" alt="TECK participant" />
        </div>
      </div>
    </div>
  </section>

  <!-- Curriculum -->
  <section class="cm-section">
    <div class="cm-container">
      <div class="cm-section-header" data-reveal>
        <span class="cm-kicker">Curriculum</span>
        <h2>From Basics<br />to Mastery</h2>
        <div class="cm-divider"></div>
      </div>
      <div class="cm-bento">
        {teckDetails.curriculumOutline?.map((mod, i) => (
          <div class:list={["cm-card", i === 0 ? "cm-card--sage" : i === 1 ? "cm-card--cream" : ""]} data-card-reveal data-card-delay={String(i)}>
            <span class="cm-tag cm-tag--green" style="margin-bottom:var(--cm-space-3);">Module {String(i + 1).padStart(2, '0')}</span>
            <p style="color:var(--cm-text-secondary);font-size:var(--cm-text-sm);line-height:1.7;">{mod}</p>
          </div>
        ))}
      </div>
      <div style="margin-top:var(--cm-space-6);" data-reveal>
        <h3 style="color:var(--cm-green);margin-bottom:var(--cm-space-4);">Tools Covered</h3>
        <div style="display:flex;flex-wrap:wrap;gap:var(--cm-space-2);">
          {teckDetails.toolsCovered?.map((t) => <span class="cm-tag cm-tag--gold">{t}</span>)}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cm-section cm-section--green" style="text-align:center;">
    <div class="cm-container" data-reveal>
      <h2 style="color:var(--cm-white);">Bring TECK to<br />Your Organization</h2>
      <p style="color:var(--cm-sage);max-width:440px;margin:var(--cm-space-4) auto var(--cm-space-6);">We customize every cohort. Let's design one together.</p>
      <a href="/designs/community-mosaic/get-involved/" class="cm-btn cm-btn--gold">Partner With Us <span class="cm-btn-arrow">&rarr;</span></a>
    </div>
  </section>

  <Footer />
</CommunityMosaicLayout>

<style>
  .cm-hero-simple {
    padding: calc(var(--cm-header-height) + var(--cm-space-16)) 0 var(--cm-space-10);
  }

  .cm-hero-simple h1 {
    color: var(--cm-green);
    font-size: clamp(3.5rem, 10vw, 7rem);
    font-weight: 900;
  }

  .hero-sub {
    font-size: var(--cm-text-md);
    color: var(--cm-text-secondary);
    max-width: 520px;
    margin-top: var(--cm-space-4);
    line-height: 1.75;
  }
</style>
