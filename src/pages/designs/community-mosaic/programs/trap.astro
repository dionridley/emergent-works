---
import CommunityMosaicLayout from "../../../../layouts/designs/CommunityMosaicLayout.astro";
import Header from "../../../../components/designs/community-mosaic/Header.astro";
import Footer from "../../../../components/designs/community-mosaic/Footer.astro";
import { programs } from "../../../../data/programs";
import { testimonials } from "../../../../data/testimonials";
import { expandedProgramDetails, alumniStories } from "../../../../data/fabricated";

const trap = programs.find((p) => p.id === "trap")!;
const trapDetails = expandedProgramDetails.find((d) => d.programId === "trap")!;
const sheisty = testimonials.find((t) => t.name === "Sheisty")!;
const julius = testimonials.find((t) => t.name === "Julius")!;
const aisha = alumniStories.find((s) => s.program === "T.RAP")!;
---

<CommunityMosaicLayout title="T.RAP Program">
  <Header currentPath="/designs/community-mosaic/programs/" />

  <section class="cm-hero-simple">
    <div class="cm-container">
      <div data-reveal>
        <span class="cm-kicker">Program</span>
        <h1>T.RAP</h1>
        <p class="hero-sub">{trap.description.slice(0, 160)}...</p>
      </div>
    </div>
  </section>

  <!-- Program Info Cards -->
  <section class="cm-section">
    <div class="cm-container">
      <div class="cm-bento">
        <div class="cm-card cm-card--photo cm-span-2 cm-span-row-2" style="min-height:360px;" data-card-reveal data-card-delay="0">
          <img src={trap.image} alt="T.RAP studio" />
          <div class="cm-card__photo-overlay">
            <h3>Music. Production. Community.</h3>
          </div>
        </div>
        <div class="cm-card cm-card--green cm-card--stat" data-card-reveal data-card-delay="1">
          <div class="cm-stat__value">{trap.duration}</div>
          <div class="cm-stat__label">Program Length</div>
        </div>
        <div class="cm-card cm-card--gold" data-card-reveal data-card-delay="2">
          <strong style="font-size:var(--cm-text-xs);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:var(--cm-space-2);">Eligibility</strong>
          <p style="font-size:var(--cm-text-sm);line-height:1.6;">{trap.eligibility}</p>
        </div>
        <div class="cm-card cm-card--peach" data-card-reveal data-card-delay="3">
          <strong style="font-size:var(--cm-text-xs);text-transform:uppercase;letter-spacing:0.08em;display:block;margin-bottom:var(--cm-space-2);">Enrollment</strong>
          <p style="font-size:var(--cm-text-sm);line-height:1.6;">{trap.applyBy}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Alumni Story -->
  <section class="cm-section cm-section--white">
    <div class="cm-container">
      <div class="cm-section-header" data-reveal>
        <span class="cm-kicker">Alumni Story</span>
        <h2>{aisha.name}'s Journey</h2>
        <div class="cm-divider"></div>
      </div>
      <div class="cm-bento cm-bento--2col">
        <div class="cm-card cm-card--photo" style="min-height:300px;" data-card-reveal data-card-delay="0">
          <img src="/images/designs/stock/music-studio-2.jpg" alt="T.RAP studio session" />
        </div>
        <div class="cm-card cm-card--cream cm-card--static" data-card-reveal data-card-delay="1">
          <p style="color:var(--cm-text-secondary);line-height:1.8;margin-bottom:var(--cm-space-4);">{aisha.beforeSummary} {aisha.journey}</p>
          <blockquote style="font-size:var(--cm-text-md);font-weight:500;color:var(--cm-green);line-height:1.7;padding-left:var(--cm-space-4);border-left:3px solid var(--cm-gold);margin-bottom:var(--cm-space-3);">
            "{aisha.quote}"
          </blockquote>
          <p style="font-size:var(--cm-text-sm);color:var(--cm-text-light);">— {aisha.name}, {aisha.currentRole}</p>
          <p style="color:var(--cm-text-secondary);line-height:1.8;margin-top:var(--cm-space-4);">{aisha.outcome}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Curriculum -->
  <section class="cm-section">
    <div class="cm-container">
      <div class="cm-section-header" data-reveal>
        <span class="cm-kicker">Curriculum</span>
        <h2>The Journey</h2>
        <div class="cm-divider"></div>
      </div>
      <div class="cm-bento cm-bento--2col">
        {trapDetails.curriculumOutline?.map((phase, i) => (
          <div class:list={["cm-card", i === 0 ? "cm-card--sage" : ""]} data-card-reveal data-card-delay={String(i)}>
            <span class="cm-tag cm-tag--green" style="margin-bottom:var(--cm-space-3);">Phase {String(i + 1).padStart(2, '0')}</span>
            <p style="color:var(--cm-text-secondary);font-size:var(--cm-text-sm);line-height:1.7;">{phase}</p>
          </div>
        ))}
      </div>
      <div style="margin-top:var(--cm-space-6);" data-reveal>
        <h3 style="color:var(--cm-green);margin-bottom:var(--cm-space-4);">Tools & Technologies</h3>
        <div style="display:flex;flex-wrap:wrap;gap:var(--cm-space-2);">
          {trapDetails.toolsCovered?.map((t) => <span class="cm-tag cm-tag--gold">{t}</span>)}
        </div>
      </div>
    </div>
  </section>

  <!-- Voices -->
  <section class="cm-section cm-section--green">
    <div class="cm-container">
      <div class="cm-section-header" data-reveal>
        <span class="cm-kicker">Voices</span>
        <h2 style="color:var(--cm-white);">From the Studio</h2>
        <div class="cm-divider"></div>
      </div>
      <div class="cm-bento cm-bento--2col">
        {[sheisty, julius].map((t, i) => (
          <div class="cm-card cm-card--dark cm-card--quote" data-card-reveal data-card-delay={String(i)}>
            <p class="cm-quote__text" style="color:var(--cm-sage);">"{t.quote}"</p>
            <div class="cm-quote__cite">
              <div>
                <div class="cm-quote__name" style="color:var(--cm-white);">{t.name}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cm-section" style="text-align:center;">
    <div class="cm-container" data-reveal>
      <h2 style="color:var(--cm-green);">Find Your Voice</h2>
      <p style="color:var(--cm-text-secondary);max-width:440px;margin:var(--cm-space-4) auto var(--cm-space-6);">T.RAP is free for all eligible participants with milestone-based stipends.</p>
      <a href="/designs/community-mosaic/get-involved/" class="cm-btn cm-btn--primary">Apply Now <span class="cm-btn-arrow">&rarr;</span></a>
    </div>
  </section>

  <Footer />
</CommunityMosaicLayout>

<style>
  .cm-hero-simple {
    padding: calc(var(--cm-header-height) + var(--cm-space-16)) 0 var(--cm-space-10);
  }

  .cm-hero-simple h1 {
    color: var(--cm-green);
    font-size: clamp(3.5rem, 10vw, 7rem);
    font-weight: 900;
  }

  .hero-sub {
    font-size: var(--cm-text-md);
    color: var(--cm-text-secondary);
    max-width: 520px;
    margin-top: var(--cm-space-4);
    line-height: 1.75;
  }
</style>
