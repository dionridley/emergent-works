---
import CommunityMosaicLayout from "../../../../layouts/designs/CommunityMosaicLayout.astro";
import Header from "../../../../components/designs/community-mosaic/Header.astro";
import Footer from "../../../../components/designs/community-mosaic/Footer.astro";
import { programs, directPrograms, partnerPrograms } from "../../../../data/programs";
import { testimonials } from "../../../../data/testimonials";
import { alumniStories } from "../../../../data/fabricated";

const blueberry = testimonials.find((t) => t.name === "Blueberry")!;
---

<CommunityMosaicLayout title="Programs">
  <Header currentPath="/designs/community-mosaic/programs/" />

  <section class="cm-hero-simple">
    <div class="cm-container">
      <div data-reveal>
        <span class="cm-kicker">Programs</span>
        <h1>Each Card a<br />Different Path</h1>
        <p class="hero-sub">Three distinct pathways, each designed to meet participants where they are and equip them with the tools to write their own next chapter.</p>
      </div>
    </div>
  </section>

  <!-- Direct Programs as feature cards -->
  <section class="cm-section">
    <div class="cm-container">
      <div class="cm-section-header" data-reveal>
        <span class="cm-kicker">Direct Programs</span>
        <h2>Our Core Programs</h2>
        <div class="cm-divider"></div>
      </div>
      {directPrograms.map((program, i) => {
        const story = alumniStories.find((s) => s.program === program.title) || alumniStories[i];
        return (
          <div class="program-feature" data-card-reveal data-card-delay={String(i)}>
            <div class="cm-card cm-card--photo program-feature__image">
              <img src={program.image} alt={program.title} />
              <div class="cm-card__photo-overlay">
                <span class="cm-tag cm-tag--gold">{program.type === "direct" ? "Direct" : "Partner"}</span>
              </div>
            </div>
            <div class="cm-card program-feature__info">
              <h3 style="color:var(--cm-green);margin-bottom:var(--cm-space-3);font-size:var(--cm-text-2xl);">{program.title}</h3>
              <p style="color:var(--cm-text-secondary);line-height:1.8;margin-bottom:var(--cm-space-4);">{program.description}</p>
              <div style="display:flex;gap:var(--cm-space-5);margin-bottom:var(--cm-space-5);font-size:var(--cm-text-sm);">
                <div><strong style="color:var(--cm-green);">Duration</strong><br/><span style="color:var(--cm-text-secondary);">{program.duration}</span></div>
                <div><strong style="color:var(--cm-green);">Eligibility</strong><br/><span style="color:var(--cm-text-secondary);">{program.eligibility}</span></div>
              </div>
              {story && (
                <div style="padding-top:var(--cm-space-4);border-top:1px solid var(--cm-border-light);">
                  <p style="font-size:var(--cm-text-sm);color:var(--cm-text-secondary);font-style:italic;line-height:1.7;">"{story.quote}"</p>
                  <p style="font-size:var(--cm-text-xs);color:var(--cm-text-light);margin-top:var(--cm-space-2);">— {story.name}, {story.program}</p>
                </div>
              )}
              <a href={`/designs/community-mosaic/programs/${program.id === "trap" ? "trap" : "teck"}/`} class="cm-btn cm-btn--primary" style="margin-top:var(--cm-space-5);align-self:flex-start;">
                Explore Program <span class="cm-btn-arrow">&rarr;</span>
              </a>
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Partner Programs -->
  <section class="cm-section cm-section--green">
    <div class="cm-container">
      <div class="cm-section-header" data-reveal>
        <span class="cm-kicker">Partner Programs</span>
        <h2 style="color:var(--cm-white);">Community<br />Partnerships</h2>
        <div class="cm-divider"></div>
      </div>
      <div class="cm-bento cm-bento--2col">
        {partnerPrograms.map((program, i) => (
          <div class="cm-card cm-card--dark" data-card-reveal data-card-delay={String(i)}>
            <span class="cm-tag cm-tag--gold" style="margin-bottom:var(--cm-space-3);">{program.duration}</span>
            <h3 style="color:var(--cm-white);margin-bottom:var(--cm-space-3);">{program.title}</h3>
            <p style="color:var(--cm-sage);font-size:var(--cm-text-sm);line-height:1.7;">{program.description.slice(0, 200)}...</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cm-section" style="text-align:center;">
    <div class="cm-container" data-reveal>
      <h2 style="color:var(--cm-green);">Ready to Start?</h2>
      <p style="color:var(--cm-text-secondary);max-width:440px;margin:var(--cm-space-4) auto var(--cm-space-6);">Applications are open on a rolling basis for all programs.</p>
      <a href="/designs/community-mosaic/get-involved/" class="cm-btn cm-btn--primary">Get Involved <span class="cm-btn-arrow">&rarr;</span></a>
    </div>
  </section>

  <Footer />
</CommunityMosaicLayout>

<style>
  .cm-hero-simple {
    padding: calc(var(--cm-header-height) + var(--cm-space-16)) 0 var(--cm-space-10);
  }

  .cm-hero-simple h1 {
    color: var(--cm-green);
    font-size: var(--cm-text-5xl);
    font-weight: 900;
  }

  .hero-sub {
    font-size: var(--cm-text-md);
    color: var(--cm-text-secondary);
    max-width: 520px;
    margin-top: var(--cm-space-4);
    line-height: 1.75;
  }

  .program-feature {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--cm-grid-gap);
    margin-bottom: var(--cm-space-7);
  }

  .program-feature__image {
    min-height: 360px;
  }

  .program-feature__info {
    display: flex;
    flex-direction: column;
  }

  @media (max-width: 768px) {
    .program-feature {
      grid-template-columns: 1fr;
    }

    .program-feature__image {
      min-height: 240px;
    }
  }
</style>
