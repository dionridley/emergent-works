---
import CommunityMosaicLayout from "../../../layouts/designs/CommunityMosaicLayout.astro";
import Header from "../../../components/designs/community-mosaic/Header.astro";
import Footer from "../../../components/designs/community-mosaic/Footer.astro";
import { organization } from "../../../data/organization";
import { programApproach } from "../../../data/programs";
---

<CommunityMosaicLayout title="About">
  <Header currentPath="/designs/community-mosaic/about/" />

  <section class="cm-hero-simple">
    <div class="cm-container">
      <div data-reveal>
        <span class="cm-kicker">About Us</span>
        <h1>Every Piece of<br />the Mosaic Matters</h1>
        <p class="hero-sub">Emergent Works is a 501(c)(3) nonprofit combating mass incarceration through education, mentorship, and technology.</p>
      </div>
    </div>
  </section>

  <!-- Origin Story -->
  <section class="cm-section">
    <div class="cm-container">
      <div class="cm-bento cm-bento--2col">
        <div class="cm-card cm-card--cream cm-card--static" data-card-reveal data-card-delay="0">
          <span class="cm-kicker">Our Story</span>
          <h3 style="color:var(--cm-green);margin:var(--cm-space-3) 0 var(--cm-space-4);">Founded on Lived Experience</h3>
          <p style="color:var(--cm-text-secondary);line-height:1.8;">
            In 2020, Army Armstead founded Emergent Works with a conviction born from lived experience:
            the people most affected by mass incarceration deserved more than a second chance — they
            deserved the tools to build entirely new futures. Having navigated the criminal justice system
            himself, Army understood that the gap between release and reentry wasn't just about skills.
            It was about dignity, community, and belief.
          </p>
        </div>
        <div class="cm-card cm-card--photo" style="min-height:320px;" data-card-reveal data-card-delay="1">
          <img src="/images/about/ourstory-portrait.jpg" alt="Emergent Works" />
        </div>
      </div>
    </div>
  </section>

  <!-- Mission -->
  <section class="cm-section cm-section--white">
    <div class="cm-container">
      <div class="cm-section-header" style="text-align:center;" data-reveal>
        <span class="cm-kicker" style="justify-content:center;">Mission</span>
        <h2>Our Mission</h2>
        <div class="cm-divider cm-divider--center"></div>
        <p style="margin:0 auto;">{organization.extendedMission}</p>
      </div>
    </div>
  </section>

  <!-- Staff Composition Stats -->
  <section class="cm-section">
    <div class="cm-container">
      <div class="cm-section-header" data-reveal>
        <span class="cm-kicker">Our People</span>
        <h2>Who We Are</h2>
        <div class="cm-divider"></div>
      </div>
      <div class="cm-bento">
        {[
          { value: organization.staffStats.alumni, label: "Staff Are Alumni", color: "cm-card--green" },
          { value: organization.staffStats.systemImpacted, label: "System-Impacted", color: "cm-card--gold" },
          { value: organization.staffStats.bipoc, label: "BIPOC", color: "cm-card--peach" },
          { value: organization.staffStats.femaleIdentifying, label: "Female-Identifying", color: "cm-card--sage" },
        ].map((stat, i) => (
          <div class:list={["cm-card cm-card--stat", stat.color]} data-card-reveal data-card-delay={String(i)}>
            <div class="cm-stat__value">{stat.value}</div>
            <div class="cm-stat__label">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Approach Pillars -->
  <section class="cm-section cm-section--white">
    <div class="cm-container">
      <div class="cm-section-header" data-reveal>
        <span class="cm-kicker">Approach</span>
        <h2>Four Pillars of Change</h2>
        <div class="cm-divider"></div>
      </div>
      <div class="cm-bento cm-bento--2col">
        {programApproach.map((pillar, i) => (
          <div class="cm-card cm-card--program" data-card-reveal data-card-delay={String(i)}>
            <div class="cm-card__program-image">
              <img src={pillar.image} alt={pillar.title} />
            </div>
            <h3 style="color:var(--cm-green);margin-bottom:var(--cm-space-2);">{pillar.title}</h3>
            <p style="color:var(--cm-text-secondary);font-size:var(--cm-text-sm);line-height:1.7;">{pillar.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cm-section">
    <div class="cm-container">
      <div class="cm-card cm-card--dark cm-card--cta cm-card--static" style="text-align:center;padding:var(--cm-space-10);" data-card-reveal>
        <div>
          <h2 style="color:var(--cm-white);">Join the Mosaic</h2>
          <p style="color:var(--cm-sage);max-width:440px;margin:var(--cm-space-4) auto var(--cm-space-6);">Every person who contributes adds a new piece to the picture of community transformation.</p>
          <a href="/designs/community-mosaic/get-involved/" class="cm-btn cm-btn--gold">Get Involved <span class="cm-btn-arrow">&rarr;</span></a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</CommunityMosaicLayout>

<style>
  .cm-hero-simple {
    padding: calc(var(--cm-header-height) + var(--cm-space-16)) 0 var(--cm-space-10);
  }

  .cm-hero-simple h1 {
    color: var(--cm-green);
    font-size: var(--cm-text-5xl);
    font-weight: 900;
  }

  .hero-sub {
    font-size: var(--cm-text-md);
    color: var(--cm-text-secondary);
    max-width: 520px;
    margin-top: var(--cm-space-4);
    line-height: 1.75;
  }
</style>
