---
import TheJourneyLayout from "../../../../layouts/designs/TheJourneyLayout.astro";
import Header from "../../../../components/designs/the-journey/Header.astro";
import Footer from "../../../../components/designs/the-journey/Footer.astro";
import { directPrograms, partnerPrograms, programApproach } from "../../../../data/programs";
import { primaryStats } from "../../../../data/stats";
---

<TheJourneyLayout title="Programs">
  <Header currentPath="/designs/the-journey/programs/" />

  <section class="tj-section tj-section--dark" style="padding-top:calc(var(--tj-header-height) + var(--tj-space-16) + 3px);">
    <div class="tj-container" data-reveal>
      <div class="tj-kicker">Programs</div>
      <h1 style="font-size:var(--tj-text-5xl);font-weight:900;color:var(--tj-white);">Pathways<br />Forward</h1>
      <p style="font-size:var(--tj-text-md);color:rgba(255,255,255,0.55);max-width:520px;margin-top:var(--tj-space-5);line-height:1.8;">Every program is a journey — from enrollment to graduation, from learning to employment, from potential to impact.</p>
    </div>
  </section>

  <!-- Direct Programs -->
  <section class="tj-section tj-section--cream">
    <div class="tj-container">
      <div class="tj-section-header" data-reveal>
        <div class="tj-kicker">Direct Programs</div>
        <h2>Open Enrollment</h2>
        <div class="tj-divider"></div>
        <p>Programs directly serving system-impacted individuals with mentorship, skills, and career support.</p>
      </div>

      <div class="tj-grid-2" data-stagger>
        {directPrograms.map((program) => (
          <div class="tj-card" style="display:flex;flex-direction:column;gap:var(--tj-space-3);" data-stagger-child>
            <div style="font-family:var(--tj-font-heading);font-size:var(--tj-text-xs);font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:var(--tj-gold);">Direct Program</div>
            <h3 style="font-size:var(--tj-text-2xl);color:var(--tj-green);">{program.title}</h3>
            <p style="font-size:var(--tj-text-sm);color:var(--tj-text-secondary);line-height:1.8;">{program.description}</p>

            <div class="tj-pathway" style="margin-top:var(--tj-space-3);padding-left:var(--tj-space-7);">
              <div class="tj-waypoint" style="padding:var(--tj-space-3) 0;">
                <div style="font-size:var(--tj-text-xs);font-weight:700;color:var(--tj-green);">Duration: {program.duration}</div>
              </div>
              <div class="tj-waypoint" style="padding:var(--tj-space-3) 0;">
                <div style="font-size:var(--tj-text-xs);font-weight:700;color:var(--tj-green);">Eligibility: {program.eligibility}</div>
              </div>
            </div>

            <a href={`/designs/the-journey/programs/${program.id === "technical-mentorship" ? "trap" : program.id}/`} class="tj-btn tj-btn--primary" style="align-self:flex-start;margin-top:auto;">
              Explore this Path <span class="tj-btn-arrow">&rarr;</span>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Partner Programs -->
  <section class="tj-section tj-section--sage">
    <div class="tj-container">
      <div class="tj-section-header" data-reveal>
        <div class="tj-kicker">Partner Programs</div>
        <h2>For Organizations</h2>
        <div class="tj-divider"></div>
        <p>Custom cohorts designed for partner organizations serving system-impacted communities.</p>
      </div>

      <div class="tj-grid-2" data-stagger>
        {partnerPrograms.map((program) => (
          <div class="tj-card" style="display:flex;flex-direction:column;gap:var(--tj-space-3);" data-stagger-child>
            <div style="font-family:var(--tj-font-heading);font-size:var(--tj-text-xs);font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:var(--tj-peach);">Partner Program</div>
            <h3 style="font-size:var(--tj-text-xl);color:var(--tj-green);">{program.title}</h3>
            <p style="font-size:var(--tj-text-sm);color:var(--tj-text-secondary);line-height:1.8;">{program.description}</p>
            <div style="display:flex;flex-wrap:wrap;gap:var(--tj-space-2);margin-top:var(--tj-space-2);">
              {program.features.slice(0, 4).map((feat) => (
                <span style="font-size:var(--tj-text-xs);background:var(--tj-sage-light);color:var(--tj-green);padding:0.2rem 0.6rem;border-radius:6px;font-weight:600;">{feat}</span>
              ))}
            </div>
            <p style="font-size:var(--tj-text-xs);color:var(--tj-text-light);margin-top:auto;padding-top:var(--tj-space-3);">Duration: {program.duration}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Impact Quick Stats -->
  <section class="tj-section tj-section--green" style="text-align:center;">
    <div class="tj-container" data-reveal>
      <h2 style="margin-bottom:var(--tj-space-7);">Where the Journey Leads</h2>
      <div class="tj-grid-3">
        {primaryStats.map((stat) => (
          <div style="padding:var(--tj-space-4);">
            <div style="font-family:var(--tj-font-heading);font-size:var(--tj-text-4xl);font-weight:900;color:var(--tj-gold);line-height:1;">{stat.value}</div>
            <div style="font-family:var(--tj-font-heading);font-size:var(--tj-text-sm);font-weight:700;color:var(--tj-white);margin-top:var(--tj-space-2);">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="tj-section" style="text-align:center;">
    <div class="tj-container" data-reveal>
      <h2 style="color:var(--tj-green);margin-bottom:var(--tj-space-4);">Start Your Path</h2>
      <p style="color:var(--tj-text-secondary);max-width:420px;margin:0 auto var(--tj-space-6);">Whether you're looking to grow your skills or share your expertise — there's a pathway for you.</p>
      <a href="/designs/the-journey/get-involved/" class="tj-btn tj-btn--primary">Get Involved <span class="tj-btn-arrow">&rarr;</span></a>
    </div>
  </section>

  <Footer />
</TheJourneyLayout>
