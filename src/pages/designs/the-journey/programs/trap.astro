---
import TheJourneyLayout from "../../../../layouts/designs/TheJourneyLayout.astro";
import Header from "../../../../components/designs/the-journey/Header.astro";
import Footer from "../../../../components/designs/the-journey/Footer.astro";
import { programs } from "../../../../data/programs";
import { expandedProgramDetails, alumniStories } from "../../../../data/fabricated";
import { testimonials } from "../../../../data/testimonials";

const trap = programs.find((p) => p.id === "trap")!;
const details = expandedProgramDetails.find((d) => d.programId === "trap")!;
const julius = testimonials.find((t) => t.name === "Julius")!;
const aisha = alumniStories.find((a) => a.program === "T.RAP")!;
---

<TheJourneyLayout title="T.RAP Program">
  <Header currentPath="/designs/the-journey/programs/" />

  <section class="tj-section tj-section--dark" style="padding-top:calc(var(--tj-header-height) + var(--tj-space-16) + 3px);">
    <div class="tj-container" data-reveal>
      <div class="tj-kicker">Program</div>
      <h1 style="font-size:var(--tj-text-5xl);font-weight:900;color:var(--tj-white);">T.RAP</h1>
      <p style="font-size:var(--tj-text-md);color:rgba(255,255,255,0.55);max-width:560px;margin-top:var(--tj-space-5);line-height:1.8;">{trap.description}</p>
    </div>
  </section>

  <!-- Program Details -->
  <section class="tj-section tj-section--cream">
    <div class="tj-container">
      <div class="tj-split">
        <div data-reveal>
          <div class="tj-kicker">Details</div>
          <h2 style="font-size:var(--tj-text-3xl);color:var(--tj-green);margin-bottom:var(--tj-space-5);">Program Overview</h2>
          <div style="display:flex;flex-direction:column;gap:var(--tj-space-4);">
            <div>
              <div style="font-size:var(--tj-text-xs);text-transform:uppercase;letter-spacing:0.12em;color:var(--tj-gold);font-weight:700;margin-bottom:var(--tj-space-1);">Duration</div>
              <div style="font-weight:600;">{trap.duration}</div>
            </div>
            <div>
              <div style="font-size:var(--tj-text-xs);text-transform:uppercase;letter-spacing:0.12em;color:var(--tj-gold);font-weight:700;margin-bottom:var(--tj-space-1);">Eligibility</div>
              <div style="color:var(--tj-text-secondary);">{trap.eligibility}</div>
            </div>
            <div>
              <div style="font-size:var(--tj-text-xs);text-transform:uppercase;letter-spacing:0.12em;color:var(--tj-gold);font-weight:700;margin-bottom:var(--tj-space-1);">Applications</div>
              <div style="font-weight:600;">{trap.applyBy}</div>
            </div>
          </div>
        </div>
        <div data-reveal="delay-1">
          <h3 style="font-size:var(--tj-text-xl);color:var(--tj-green);margin-bottom:var(--tj-space-4);">Skills You'll Build</h3>
          <div style="display:flex;flex-wrap:wrap;gap:var(--tj-space-2);">
            {trap.features.map((feat) => (
              <span style="font-size:var(--tj-text-sm);background:var(--tj-gold-light);color:var(--tj-green);padding:0.4rem 1rem;border-radius:8px;font-weight:600;">{feat}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Curriculum Journey -->
  <section class="tj-section tj-section--white">
    <div class="tj-container">
      <div class="tj-section-header" data-reveal>
        <div class="tj-kicker">Curriculum</div>
        <h2>The Journey</h2>
        <div class="tj-divider"></div>
      </div>
      <div class="tj-pathway" data-stagger>
        {details.curriculumOutline?.map((phase) => {
          const [title, ...descParts] = phase.split(" — ");
          return (
            <div class="tj-waypoint" data-stagger-child>
              <div class="tj-waypoint__title" style="color:var(--tj-green);">{title}</div>
              <p class="tj-waypoint__desc">{descParts.join(" — ")}</p>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Weekly Schedule -->
  <section class="tj-section tj-section--sage">
    <div class="tj-container">
      <div class="tj-section-header" style="text-align:center;" data-reveal>
        <div class="tj-kicker" style="justify-content:center;">Schedule</div>
        <h2>A Typical Week</h2>
        <div class="tj-divider tj-divider--center"></div>
      </div>
      <div class="tj-grid-2" data-stagger>
        {details.weeklySchedule?.map((day) => {
          const [label, ...rest] = day.split(": ");
          return (
            <div class="tj-card" data-stagger-child>
              <div style="font-family:var(--tj-font-heading);font-weight:700;font-size:var(--tj-text-base);color:var(--tj-green);margin-bottom:var(--tj-space-2);">{label}</div>
              <p style="font-size:var(--tj-text-sm);color:var(--tj-text-secondary);">{rest.join(": ")}</p>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Participant Voice -->
  <section class="tj-section tj-section--green">
    <div class="tj-container" data-reveal>
      <div class="tj-quote" style="color:var(--tj-white);max-width:600px;margin:0 auto;">
        "{julius.quote}"
        <cite>— {julius.name}, T.RAP Participant</cite>
      </div>
    </div>
  </section>

  <!-- Alumni Story -->
  <section class="tj-section tj-section--cream">
    <div class="tj-container">
      <div class="tj-section-header" data-reveal>
        <div class="tj-kicker">Alumni</div>
        <h2>{aisha.name}'s Journey</h2>
        <div class="tj-divider"></div>
      </div>
      <div class="tj-split">
        <div data-reveal>
          <h3 style="font-size:var(--tj-text-lg);color:var(--tj-green);margin-bottom:var(--tj-space-3);">Before</h3>
          <p style="color:var(--tj-text-secondary);line-height:1.8;">{aisha.beforeSummary}</p>
          <h3 style="font-size:var(--tj-text-lg);color:var(--tj-green);margin-top:var(--tj-space-5);margin-bottom:var(--tj-space-3);">The Journey</h3>
          <p style="color:var(--tj-text-secondary);line-height:1.8;">{aisha.journey}</p>
        </div>
        <div data-reveal="delay-1">
          <div class="tj-card tj-card--gold" style="border-left:3px solid var(--tj-green);">
            <h3 style="font-size:var(--tj-text-lg);color:var(--tj-green);margin-bottom:var(--tj-space-3);">After</h3>
            <p style="color:var(--tj-text);line-height:1.8;margin-bottom:var(--tj-space-3);">{aisha.outcome}</p>
            <p style="font-family:var(--tj-font-heading);font-weight:700;color:var(--tj-green);">{aisha.currentRole}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="tj-section tj-section--deep" style="text-align:center;">
    <div class="tj-container" data-reveal>
      <h2 style="color:var(--tj-white);margin-bottom:var(--tj-space-4);">Start Your Creative Journey</h2>
      <p style="color:rgba(255,255,255,0.5);max-width:420px;margin:0 auto var(--tj-space-6);">T.RAP transforms creative potential into real-world skills and professional opportunity.</p>
      <a href="/designs/the-journey/get-involved/" class="tj-btn tj-btn--gold">Apply Now <span class="tj-btn-arrow">&rarr;</span></a>
    </div>
  </section>

  <Footer />
</TheJourneyLayout>
