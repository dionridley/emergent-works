---
import TheJourneyLayout from "../../../layouts/designs/TheJourneyLayout.astro";
import Header from "../../../components/designs/the-journey/Header.astro";
import Footer from "../../../components/designs/the-journey/Footer.astro";
import ContentSummaryTable from "../../../components/designs/shared/ContentSummaryTable.astro";
import type { ContentItem, StockImage, TypographyDeviation } from "../../../components/designs/shared/ContentSummaryTable.astro";

const contentItems: ContentItem[] = [
  // Real content
  { item: "Organization mission & extended mission", source: "Real", page: "Home (Ch. 2), About, Footer", notes: "From organization.ts" },
  { item: "Primary stats (261 graduates, 73% employed, $2+ above min wage)", source: "Real", page: "Home (Ch. 5), Programs", notes: "From stats.ts" },
  { item: "Secondary stats (98%+ no re-offense, 8 contracted graduates)", source: "Real", page: "Home (Ch. 5)", notes: "From stats.ts" },
  { item: "Staff stats (100% alumni, 80% system-impacted, etc.)", source: "Real", page: "About", notes: "From organization.ts" },
  { item: "Program descriptions (T.RAP, Technical Mentorship, TECK)", source: "Real", page: "Programs, T.RAP, TECK", notes: "From programs.ts" },
  { item: "Program approach / four pillars", source: "Real", page: "Home (Ch. 3), About", notes: "From programs.ts" },
  { item: "Testimonials (Nashid, Sheisty, Julius)", source: "Real", page: "Home (Ch. 3, Ch. 5), T.RAP", notes: "From testimonials.ts" },
  { item: "Partner organizations & logos", source: "Real", page: "TECK", notes: "From partners.ts" },
  { item: "Donation tiers & trust statement", source: "Real", page: "Get Involved", notes: "From donation.ts" },
  { item: "Partnership types", source: "Real", page: "Get Involved", notes: "From partners.ts" },
  { item: "Social links & contact info", source: "Real", page: "Footer, Get Involved", notes: "From organization.ts" },

  // Fabricated content
  { item: "Staff bios", source: "Fabricated", page: "Team", notes: "Replace with real staff bios" },
  { item: "Board of Directors bios", source: "Fabricated", page: "Team", notes: "Replace with real board bios" },
  { item: "Advisory Board bios", source: "Fabricated", page: "Team", notes: "Replace with real advisory bios" },
  { item: "Mentor profiles (Priya, James, Lisa, David)", source: "Fabricated", page: "Team", notes: "Replace with real mentor profiles" },
  { item: "Alumni stories (Marcus, Aisha, DeShawn)", source: "Fabricated", page: "Home (Ch. 4), T.RAP, TECK", notes: "Replace with real alumni stories" },
  { item: "Expanded program details (schedules, curriculum)", source: "Fabricated", page: "T.RAP, TECK", notes: "Replace with real schedules" },
  { item: "Upcoming events", source: "Fabricated", page: "Get Involved", notes: "Replace with real events" },
  { item: "National recidivism statistics (44%, 60%)", source: "Fabricated", page: "Home (Ch. 1)", notes: "Verify sources — stats are approximate" },
  { item: "Organization timeline (2020-today)", source: "Fabricated", page: "About", notes: "Verify milestone dates with org" },
];

const stockImages: StockImage[] = [];

const typographyDeviations: TypographyDeviation[] = [];
---

<TheJourneyLayout title="Content Summary">
  <Header currentPath="" />

  <section class="tj-section" style="padding-top:calc(var(--tj-header-height) + var(--tj-space-16) + 3px);">
    <div class="tj-container" data-reveal>
      <div class="tj-kicker">Internal</div>
      <h1 style="font-size:var(--tj-text-3xl);font-weight:900;color:var(--tj-green);">Content Summary</h1>
      <p style="font-size:var(--tj-text-md);color:var(--tj-text-secondary);max-width:560px;margin-top:var(--tj-space-4);line-height:1.8;">Audit of real vs. fabricated content used in The Journey design variation. Use this to identify what needs to be replaced before production.</p>
    </div>
  </section>

  <section class="tj-section tj-section--white">
    <ContentSummaryTable
      designName="The Journey (Scroll Documentary)"
      contentItems={contentItems}
      stockImages={stockImages}
      typographyDeviations={typographyDeviations}
    />
  </section>

  <Footer />
</TheJourneyLayout>
