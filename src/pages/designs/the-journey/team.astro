---
import TheJourneyLayout from "../../../layouts/designs/TheJourneyLayout.astro";
import Header from "../../../components/designs/the-journey/Header.astro";
import Footer from "../../../components/designs/the-journey/Footer.astro";
import { staff, boardOfDirectors, advisoryBoard } from "../../../data/team";
import { mentorProfiles } from "../../../data/fabricated";
import { organization } from "../../../data/organization";
---

<TheJourneyLayout title="Team">
  <Header currentPath="/designs/the-journey/team/" />

  <section class="tj-section tj-section--dark" style="padding-top:calc(var(--tj-header-height) + var(--tj-space-16) + 3px);">
    <div class="tj-container" data-reveal>
      <div class="tj-kicker">Team</div>
      <h1 style="font-size:var(--tj-text-5xl);font-weight:900;color:var(--tj-white);">The<br />Guides</h1>
      <p style="font-size:var(--tj-text-md);color:rgba(255,255,255,0.55);max-width:520px;margin-top:var(--tj-space-5);line-height:1.8;">Every journey needs guides. Our team is built on lived experience — {organization.staffStats.alumni} of our staff are program alumni.</p>
    </div>
  </section>

  <!-- Staff -->
  <section class="tj-section tj-section--cream">
    <div class="tj-container">
      <div class="tj-section-header" data-reveal>
        <div class="tj-kicker">Staff</div>
        <h2>Our Team</h2>
        <div class="tj-divider"></div>
      </div>
      <div class="team-grid" data-stagger>
        {staff.map((member) => (
          <div class="team-card" data-stagger-child>
            <img src={member.image} alt={member.name} class="team-card__photo" />
            <h3 style="font-size:var(--tj-text-base);color:var(--tj-green);margin-top:var(--tj-space-4);margin-bottom:var(--tj-space-1);">{member.name}</h3>
            <p style="font-size:var(--tj-text-xs);color:var(--tj-gold);font-weight:600;margin-bottom:var(--tj-space-3);">{member.title}</p>
            {member.bio && <p style="font-size:var(--tj-text-sm);color:var(--tj-text-secondary);line-height:1.65;">{member.bio}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Board -->
  <section class="tj-section tj-section--white">
    <div class="tj-container">
      <div class="tj-section-header" data-reveal>
        <div class="tj-kicker">Governance</div>
        <h2>Board of Directors</h2>
        <div class="tj-divider"></div>
      </div>
      <div class="tj-grid-3" data-stagger>
        {boardOfDirectors.map((member) => (
          <div class="tj-card tj-card--cream" style="text-align:center;" data-stagger-child>
            <img src={member.image} alt={member.name} class="team-card__photo team-card__photo--sm" style="margin:0 auto var(--tj-space-3);" />
            <h3 style="font-size:var(--tj-text-base);color:var(--tj-green);margin-bottom:var(--tj-space-1);">{member.name}</h3>
            <p style="font-size:var(--tj-text-xs);color:var(--tj-gold);font-weight:600;">{member.title}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Advisory -->
  <section class="tj-section tj-section--sage">
    <div class="tj-container">
      <div class="tj-section-header" data-reveal>
        <div class="tj-kicker">Advisory</div>
        <h2>Advisory Board</h2>
        <div class="tj-divider"></div>
      </div>
      <div class="tj-grid-3" data-stagger>
        {advisoryBoard.map((member) => (
          <div class="tj-card" style="text-align:center;" data-stagger-child>
            <img src={member.image} alt={member.name} class="team-card__photo team-card__photo--sm" style="margin:0 auto var(--tj-space-3);" />
            <h3 style="font-size:var(--tj-text-base);color:var(--tj-green);margin-bottom:var(--tj-space-1);">{member.name}</h3>
            <p style="font-size:var(--tj-text-xs);color:var(--tj-gold);font-weight:600;">{member.title}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Mentors -->
  <section class="tj-section tj-section--cream">
    <div class="tj-container">
      <div class="tj-section-header" style="text-align:center;" data-reveal>
        <div class="tj-kicker" style="justify-content:center;">Mentors</div>
        <h2>Volunteer Guides</h2>
        <div class="tj-divider tj-divider--center"></div>
        <p style="max-width:480px;margin:0 auto;">Industry professionals who share their expertise and time to guide others on their journey.</p>
      </div>
      <div class="tj-grid-2" data-stagger>
        {mentorProfiles.slice(0, 4).map((mentor) => (
          <div class="tj-card" data-stagger-child>
            <div style="display:flex;align-items:flex-start;gap:var(--tj-space-4);">
              <div style="width:48px;height:48px;min-width:48px;border-radius:50%;background:var(--tj-gold-light);display:flex;align-items:center;justify-content:center;font-family:var(--tj-font-heading);font-weight:800;font-size:var(--tj-text-lg);color:var(--tj-green);">{mentor.name.charAt(0)}</div>
              <div>
                <h3 style="font-size:var(--tj-text-base);color:var(--tj-green);margin-bottom:var(--tj-space-1);">{mentor.name}</h3>
                <p style="font-size:var(--tj-text-xs);color:var(--tj-gold);font-weight:600;margin-bottom:var(--tj-space-1);">{mentor.company} — {mentor.role}</p>
                <p style="font-size:var(--tj-text-xs);color:var(--tj-text-light);margin-bottom:var(--tj-space-3);">{mentor.specialty} · {mentor.yearsWithEW}y with EW</p>
                <p style="font-size:var(--tj-text-sm);color:var(--tj-text-secondary);line-height:1.65;font-style:italic;">"{mentor.quote}"</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="tj-section tj-section--green" style="text-align:center;">
    <div class="tj-container" data-reveal>
      <h2 style="margin-bottom:var(--tj-space-4);">Join the Journey</h2>
      <p style="color:var(--tj-sage);max-width:420px;margin:0 auto var(--tj-space-6);">Whether as staff, board member, or volunteer mentor — there's a role for you in this story.</p>
      <a href="/designs/the-journey/get-involved/" class="tj-btn tj-btn--gold">Get Involved <span class="tj-btn-arrow">&rarr;</span></a>
    </div>
  </section>

  <Footer />
</TheJourneyLayout>

<style>
  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--tj-space-6);
  }

  .team-card {
    text-align: center;
  }

  .team-card__photo {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    object-fit: cover;
    margin: 0 auto;
    border: 2px solid var(--tj-gold);
    box-shadow: var(--tj-shadow);
  }

  .team-card__photo--sm {
    width: 72px;
    height: 72px;
  }

  @media (max-width: 768px) {
    .team-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
