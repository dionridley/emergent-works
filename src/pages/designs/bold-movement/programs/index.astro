---
import BoldMovementLayout from "../../../../layouts/designs/BoldMovementLayout.astro";
import Header from "../../../../components/designs/bold-movement/Header.astro";
import Footer from "../../../../components/designs/bold-movement/Footer.astro";
import { directPrograms, partnerPrograms } from "../../../../data/programs";
---

<BoldMovementLayout title="Programs">
  <Header currentPath="/designs/bold-movement/programs/" />

  <!-- Hero -->
  <section class="bm-block bm-block--green bm-block--textured" style="padding-top:calc(var(--bm-header-height) + var(--bm-space-16));">
    <div class="bm-container" data-reveal>
      <span class="bm-kicker">Programs</span>
      <h1 class="bm-ultra">
        Three<br />Paths.<br /><span class="bm-gold">Choose<br />Yours.</span>
      </h1>
    </div>
  </section>

  <!-- Each program as a full-width color block -->
  {directPrograms.map((program, i) => (
    <section class:list={["bm-block bm-block--textured", i === 0 ? "bm-block--gold" : i === 1 ? "bm-block--cream" : "bm-block--peach"]}>
      <div class="bm-container">
        <div data-reveal>
          <span class="bm-kicker">{program.type === "direct" ? "Direct Program" : "Partner"}</span>
          <h2 class="bm-mega" style="margin-bottom:var(--bm-space-6);">{program.title}</h2>
          <div class="bm-grid-2">
            <div>
              <p style="font-size:var(--bm-text-md);line-height:1.8;margin-bottom:var(--bm-space-5);">{program.description}</p>
              <a href={`/designs/bold-movement/programs/${program.id === "trap" ? "trap" : "teck"}/`} class:list={["bm-btn", i === 0 ? "bm-btn--primary" : "bm-btn--outline"]}>
                Learn More <span class="bm-btn-arrow">&rarr;</span>
              </a>
            </div>
            <div style="display:flex;flex-direction:column;gap:var(--bm-space-4);">
              <div style={`padding:var(--bm-space-4);border:2px solid ${i === 0 ? 'var(--bm-green-dark)' : 'var(--bm-green)'};`}>
                <strong style="font-family:var(--bm-font-heading);font-size:var(--bm-text-xs);text-transform:uppercase;letter-spacing:0.1em;display:block;margin-bottom:var(--bm-space-1);">Duration</strong>
                <span style="font-size:var(--bm-text-lg);font-weight:600;">{program.duration}</span>
              </div>
              <div style={`padding:var(--bm-space-4);border:2px solid ${i === 0 ? 'var(--bm-green-dark)' : 'var(--bm-green)'};`}>
                <strong style="font-family:var(--bm-font-heading);font-size:var(--bm-text-xs);text-transform:uppercase;letter-spacing:0.1em;display:block;margin-bottom:var(--bm-space-1);">Eligibility</strong>
                <span style="font-size:var(--bm-text-base);">{program.eligibility}</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- Partner Programs -->
  <section class="bm-block bm-block--dark bm-block--textured">
    <div class="bm-container">
      <div data-reveal>
        <span class="bm-kicker">Partner Programs</span>
        <h2 class="bm-display" style="margin-bottom:var(--bm-space-7);">
          Community<br /><span class="bm-gold">Partnerships</span>
        </h2>
      </div>
      <div class="bm-grid-2" data-stagger>
        {partnerPrograms.map((program) => (
          <div style="padding:var(--bm-space-6);border:2px solid rgba(177,211,187,0.15);" data-stagger-child>
            <h3 style="font-size:var(--bm-text-2xl);color:var(--bm-white);margin-bottom:var(--bm-space-2);">{program.title}</h3>
            <span style="font-size:var(--bm-text-sm);color:var(--bm-gold);display:block;margin-bottom:var(--bm-space-3);">{program.duration}</span>
            <p style="color:var(--bm-sage);font-size:var(--bm-text-sm);line-height:1.7;">{program.description.slice(0, 200)}...</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bm-block bm-block--gold bm-block--textured" style="text-align:center;">
    <div class="bm-container" data-reveal>
      <h2 class="bm-mega" style="margin-bottom:var(--bm-space-6);">Ready?</h2>
      <a href="/designs/bold-movement/get-involved/" class="bm-btn bm-btn--primary">Apply Now <span class="bm-btn-arrow">&rarr;</span></a>
    </div>
  </section>

  <Footer />
</BoldMovementLayout>
