---
import BoldMovementLayout from "../../../layouts/designs/BoldMovementLayout.astro";
import Header from "../../../components/designs/bold-movement/Header.astro";
import Footer from "../../../components/designs/bold-movement/Footer.astro";
import { organization } from "../../../data/organization";
import { programs } from "../../../data/programs";
import { primaryStats } from "../../../data/stats";
import { testimonials } from "../../../data/testimonials";
import { donationTiers } from "../../../data/donation";

const nashid = testimonials.find((t) => t.name === "Nashid")!;
const directPrograms = programs.filter((p) => p.type === "direct");
---

<BoldMovementLayout title="Home" description={organization.mission}>
  <Header currentPath="/designs/bold-movement/" />

  <!-- HERO — Massive typographic statement -->
  <section class="bm-block bm-block--green bm-block--hero bm-block--textured">
    <div class="bm-container" style="padding-top:var(--bm-header-height);">
      <div data-reveal>
        <span class="bm-kicker">Emergent Works</span>
        <h1 class="bm-ultra" style="margin-bottom:var(--bm-space-6);">
          Breaking<br />
          <span class="bm-gold">Cycles.</span><br />
          Building<br />
          Futures.
        </h1>
        <p style="font-size:var(--bm-text-lg);color:var(--bm-sage);max-width:500px;line-height:1.7;margin-bottom:var(--bm-space-7);">
          {organization.mission}
        </p>
        <div style="display:flex;gap:var(--bm-space-4);flex-wrap:wrap;">
          <a href="/designs/bold-movement/programs/" class="bm-btn bm-btn--gold">Explore Programs <span class="bm-btn-arrow">&rarr;</span></a>
          <a href="/designs/bold-movement/get-involved/" class="bm-btn bm-btn--outline-white">Join the Movement</a>
        </div>
      </div>
    </div>
  </section>

  <!-- STAT MOMENTS — Each stat gets a full-width section -->
  {primaryStats.slice(0, 3).map((stat, i) => (
    <section class:list={["bm-block bm-stat-block bm-block--textured", i === 0 ? "bm-block--gold" : i === 1 ? "bm-block--cream" : "bm-block--green"]}>
      <div class="bm-container" data-reveal>
        <span class="bm-stat__number">{stat.value}</span>
        <div class="bm-stat__label">{stat.label}</div>
        <p class="bm-stat__context">{stat.description}</p>
      </div>
    </section>
  ))}

  <!-- PROGRAMS — Horizontal scroll -->
  <section class="bm-block bm-block--cream bm-block--textured">
    <div class="bm-container">
      <div data-reveal>
        <span class="bm-kicker" style="color:var(--bm-green);">Programs</span>
        <h2 class="bm-display" style="margin-bottom:var(--bm-space-7);">
          Three Paths.<br />One <span class="bm-gold">Movement.</span>
        </h2>
      </div>
    </div>
    <div class="bm-hscroll">
      {directPrograms.map((program) => (
        <div class="bm-hscroll__item" style="border-color:var(--bm-green);">
          <span class="bm-kicker" style="color:var(--bm-green);">{program.type === "direct" ? "Direct" : "Partner"}</span>
          <h3 style="font-size:var(--bm-text-4xl);color:var(--bm-green);margin-bottom:var(--bm-space-4);">{program.title}</h3>
          <p style="color:var(--bm-text-secondary);font-size:var(--bm-text-base);line-height:1.7;margin-bottom:var(--bm-space-5);">{program.description.slice(0, 200)}...</p>
          <div style="font-size:var(--bm-text-sm);color:var(--bm-text-light);margin-bottom:var(--bm-space-5);">
            <strong style="color:var(--bm-green);">Duration:</strong> {program.duration}
          </div>
          <a href={`/designs/bold-movement/programs/${program.id === "trap" ? "trap" : "teck"}/`} class="bm-btn bm-btn--outline" style="font-size:var(--bm-text-xs);">
            Learn More <span class="bm-btn-arrow">&rarr;</span>
          </a>
        </div>
      ))}
    </div>
  </section>

  <!-- FEATURED QUOTE -->
  <section class="bm-block bm-block--dark bm-block--textured">
    <div class="bm-container" data-reveal>
      <span class="bm-kicker">Voices</span>
      <blockquote class="bm-quote" style="color:var(--bm-white);border-left-color:var(--bm-gold);">
        "{nashid.quote}"
        <cite style="color:var(--bm-sage);">— {nashid.name}, Program Graduate</cite>
      </blockquote>
    </div>
  </section>

  <!-- CTA — Join the movement -->
  <section class="bm-block bm-block--gold bm-block--textured" style="text-align:center;">
    <div class="bm-container" data-reveal>
      <h2 class="bm-mega" style="margin-bottom:var(--bm-space-7);">
        Join the<br />Movement
      </h2>
      <p style="font-size:var(--bm-text-md);max-width:460px;margin:0 auto var(--bm-space-7);color:var(--bm-green);">
        Every person who steps up adds momentum. The movement needs you.
      </p>
      <a href="/designs/bold-movement/get-involved/" class="bm-btn bm-btn--primary">Get Involved <span class="bm-btn-arrow">&rarr;</span></a>
    </div>
  </section>

  <Footer />
</BoldMovementLayout>
