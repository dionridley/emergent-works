---
import MentorshipLayout from "../../../layouts/designs/MentorshipLayout.astro";
import Header from "../../../components/designs/mentorship/Header.astro";
import Footer from "../../../components/designs/mentorship/Footer.astro";
import { staff, boardOfDirectors, advisoryBoard } from "../../../data/team";
import { mentorProfiles } from "../../../data/fabricated";
import { organization } from "../../../data/organization";
---

<MentorshipLayout title="Team">
  <Header currentPath="/designs/mentorship/team/" />

  <section class="mn-section" style="padding-top:calc(var(--mn-header-height) + var(--mn-space-16));">
    <div class="mn-container" data-reveal>
      <span class="mn-kicker">Team</span>
      <h1 style="font-size:var(--mn-text-5xl);font-weight:900;">The People<br />Behind the<br />Connection</h1>
      <p style="font-size:var(--mn-text-md);color:var(--mn-text-secondary);max-width:520px;margin-top:var(--mn-space-5);line-height:1.75;">Our team is built on lived experience. {organization.staffStats.alumni} of our staff are program alumni — proof that connection works.</p>
    </div>
  </section>

  <!-- Staff -->
  <section class="mn-section mn-section--white">
    <div class="mn-container">
      <div class="mn-section-header" data-reveal>
        <span class="mn-kicker">Staff</span>
        <h2>Our Team</h2>
        <div class="mn-divider"></div>
      </div>
      <div class="team-grid" data-reveal="delay-1">
        {staff.map((member) => (
          <div class="team-card">
            <img src={member.image} alt={member.name} class="mn-portrait mn-portrait--lg" />
            <h3 style="font-size:var(--mn-text-base);margin-top:var(--mn-space-4);margin-bottom:var(--mn-space-1);">{member.name}</h3>
            <p style="font-size:var(--mn-text-xs);color:var(--mn-gold);font-weight:600;margin-bottom:var(--mn-space-3);">{member.title}</p>
            {member.bio && <p style="font-size:var(--mn-text-sm);color:var(--mn-text-secondary);line-height:1.65;">{member.bio}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Board -->
  <section class="mn-section mn-section--sage">
    <div class="mn-container">
      <div class="mn-section-header" data-reveal>
        <span class="mn-kicker">Governance</span>
        <h2>Board of Directors</h2>
        <div class="mn-divider"></div>
      </div>
      <div class="board-grid" data-reveal="delay-1">
        {boardOfDirectors.map((member) => (
          <div class="mn-card mn-card--cream" style="text-align:center;">
            <img src={member.image} alt={member.name} class="mn-portrait mn-portrait--md" style="margin:0 auto var(--mn-space-3);" />
            <h3 style="font-size:var(--mn-text-base);margin-bottom:var(--mn-space-1);">{member.name}</h3>
            <p style="font-size:var(--mn-text-xs);color:var(--mn-gold);font-weight:600;">{member.title}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Advisory Board -->
  <section class="mn-section mn-section--white">
    <div class="mn-container">
      <div class="mn-section-header" data-reveal>
        <span class="mn-kicker">Advisory</span>
        <h2>Advisory Board</h2>
        <div class="mn-divider"></div>
      </div>
      <div class="mn-grid-3" data-reveal="delay-1">
        {advisoryBoard.map((member) => (
          <div class="mn-card" style="text-align:center;">
            <img src={member.image} alt={member.name} class="mn-portrait mn-portrait--md" style="margin:0 auto var(--mn-space-3);" />
            <h3 style="font-size:var(--mn-text-base);margin-bottom:var(--mn-space-1);">{member.name}</h3>
            <p style="font-size:var(--mn-text-xs);color:var(--mn-gold);font-weight:600;">{member.title}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Mentors -->
  <section class="mn-section mn-section--peach">
    <div class="mn-container">
      <div class="mn-section-header" style="text-align:center;" data-reveal>
        <span class="mn-kicker">Mentors</span>
        <h2>Our Volunteer Mentors</h2>
        <div class="mn-divider mn-divider--center"></div>
        <p style="max-width:480px;margin:0 auto;">Industry professionals who share their expertise and time to change lives.</p>
      </div>
      <div class="mn-grid-2" data-reveal="delay-1">
        {mentorProfiles.slice(0, 4).map((mentor) => (
          <div class="mn-card">
            <div style="display:flex;align-items:flex-start;gap:var(--mn-space-4);">
              <div style="width:56px;height:56px;min-width:56px;border-radius:50%;background:var(--mn-gold-light);display:flex;align-items:center;justify-content:center;font-family:var(--mn-font-heading);font-weight:800;font-size:var(--mn-text-lg);color:var(--mn-green);">{mentor.name.charAt(0)}</div>
              <div>
                <h3 style="font-size:var(--mn-text-base);margin-bottom:var(--mn-space-1);">{mentor.name}</h3>
                <p style="font-size:var(--mn-text-xs);color:var(--mn-gold);font-weight:600;margin-bottom:var(--mn-space-1);">{mentor.company} — {mentor.role}</p>
                <p style="font-size:var(--mn-text-xs);color:var(--mn-text-light);margin-bottom:var(--mn-space-3);">{mentor.specialty} · {mentor.yearsWithEW} years with EW</p>
                <p style="font-size:var(--mn-text-sm);color:var(--mn-text-secondary);line-height:1.65;font-style:italic;">"{mentor.quote}"</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="mn-section mn-section--green" style="text-align:center;">
    <div class="mn-container" data-reveal>
      <h2 style="margin-bottom:var(--mn-space-5);">Join Our Team</h2>
      <p style="color:var(--mn-sage);max-width:420px;margin:0 auto var(--mn-space-6);">Whether as staff, board member, or volunteer mentor — there's a place for you in our story.</p>
      <a href="/designs/mentorship/get-involved/" class="mn-btn mn-btn--gold">Get Involved <span class="mn-btn-arrow">&rarr;</span></a>
    </div>
  </section>

  <Footer />
</MentorshipLayout>

<style>
  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--mn-space-6);
  }

  .team-card {
    text-align: center;
  }

  .board-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--mn-space-5);
  }

  @media (max-width: 768px) {
    .team-grid {
      grid-template-columns: 1fr;
    }

    .board-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
