---
import MentorshipLayout from "../../../layouts/designs/MentorshipLayout.astro";
import Header from "../../../components/designs/mentorship/Header.astro";
import Footer from "../../../components/designs/mentorship/Footer.astro";
import { organization } from "../../../data/organization";
import { donationTiers, donationTrust } from "../../../data/donation";
import { partnershipTypes } from "../../../data/partners";
import { fabricatedEvents } from "../../../data/fabricated";
---

<MentorshipLayout title="Get Involved">
  <Header currentPath="/designs/mentorship/get-involved/" />

  <section class="mn-section" style="padding-top:calc(var(--mn-header-height) + var(--mn-space-16));">
    <div class="mn-container" data-reveal>
      <span class="mn-kicker">Get Involved</span>
      <h1 style="font-size:var(--mn-text-5xl);font-weight:900;">Your<br />Connection<br />Matters</h1>
      <p style="font-size:var(--mn-text-md);color:var(--mn-text-secondary);max-width:520px;margin-top:var(--mn-space-5);line-height:1.75;">Every mentor, every donation, every partnership creates a ripple of change. Here's how you can be part of it.</p>
    </div>
  </section>

  <!-- Dual CTA — Mentor/Mentee -->
  <section class="mn-section mn-section--white">
    <div class="mn-container">
      <div class="mn-dual-cta" data-split-reveal>
        <div class="mn-dual-cta__side mn-dual-cta__side--mentor">
          <span class="mn-kicker">Volunteer</span>
          <h3 style="color:var(--mn-white);font-size:var(--mn-text-3xl);">Become a<br />Mentor</h3>
          <p style="color:var(--mn-sage);max-width:300px;">Share your expertise one hour a week. You'll gain as much as you give — our mentors say it transforms them too.</p>
          <ul style="color:var(--mn-sage);font-size:var(--mn-text-sm);list-style:none;display:flex;flex-direction:column;gap:var(--mn-space-2);text-align:left;">
            <li>1 hour per week commitment</li>
            <li>Virtual sessions available</li>
            <li>Training & support provided</li>
            <li>Join a community of 100+ mentors</li>
          </ul>
          <a href={`mailto:${organization.contact.email}?subject=Mentor%20Inquiry`} class="mn-btn mn-btn--gold">Apply as Mentor <span class="mn-btn-arrow">&rarr;</span></a>
        </div>
        <div class="mn-dual-cta__side mn-dual-cta__side--mentee">
          <span class="mn-kicker">Apply</span>
          <h3 style="color:var(--mn-green);font-size:var(--mn-text-3xl);">Become a<br />Mentee</h3>
          <p style="color:var(--mn-text-secondary);max-width:300px;">Get matched with a mentor who believes in your potential and will help you build real-world skills.</p>
          <ul style="color:var(--mn-text-secondary);font-size:var(--mn-text-sm);list-style:none;display:flex;flex-direction:column;gap:var(--mn-space-2);text-align:left;">
            <li>Free — no cost to participate</li>
            <li>12-week structured program</li>
            <li>Portfolio-ready projects</li>
            <li>Job readiness support</li>
          </ul>
          <a href={`mailto:${organization.contact.email}?subject=Mentee%20Application`} class="mn-btn mn-btn--primary">Apply Now <span class="mn-btn-arrow">&rarr;</span></a>
        </div>
      </div>
    </div>
  </section>

  <!-- Donate -->
  <section class="mn-section mn-section--gold">
    <div class="mn-container">
      <div class="mn-section-header" style="text-align:center;" data-reveal>
        <span class="mn-kicker" style="background:rgba(32,73,60,0.1);color:var(--mn-green);">Support</span>
        <h2>Fund a Connection</h2>
        <div class="mn-divider mn-divider--center"></div>
        <p style="max-width:440px;margin:0 auto;">Every dollar directly supports mentorship sessions, program materials, and participant stipends.</p>
      </div>
      <div class="mn-grid-4" data-reveal="delay-1">
        {donationTiers.map((tier) => (
          <div class="mn-card" style="text-align:center;">
            <div style="font-family:var(--mn-font-heading);font-size:var(--mn-text-3xl);font-weight:900;color:var(--mn-green);margin-bottom:var(--mn-space-3);">{tier.label}</div>
            <p style="font-size:var(--mn-text-sm);color:var(--mn-text-secondary);line-height:1.65;">{tier.impact}</p>
          </div>
        ))}
      </div>
      <div style="text-align:center;margin-top:var(--mn-space-7);" data-reveal="delay-2">
        <a href="#" class="mn-btn mn-btn--primary">Donate Now <span class="mn-btn-arrow">&rarr;</span></a>
        <p style="font-size:var(--mn-text-xs);color:var(--mn-text-secondary);margin-top:var(--mn-space-3);max-width:400px;margin-left:auto;margin-right:auto;">{donationTrust}</p>
      </div>
    </div>
  </section>

  <!-- Partnership Types -->
  <section class="mn-section mn-section--white">
    <div class="mn-container">
      <div class="mn-section-header" data-reveal>
        <span class="mn-kicker">Partnerships</span>
        <h2>Partner With Us</h2>
        <div class="mn-divider"></div>
        <p>Multiple ways to collaborate and create lasting impact together.</p>
      </div>
      <div class="mn-grid-2" data-reveal="delay-1">
        {partnershipTypes.map((type) => (
          <div class="mn-card mn-card--sage" style="padding:var(--mn-space-6);">
            <h3 style="font-size:var(--mn-text-lg);margin-bottom:var(--mn-space-2);">{type.title}</h3>
            <p style="font-size:var(--mn-text-sm);color:var(--mn-text-secondary);line-height:1.7;">{type.description}</p>
          </div>
        ))}
      </div>
      <div style="text-align:center;margin-top:var(--mn-space-7);" data-reveal="delay-2">
        <a href={`mailto:${organization.contact.email}?subject=Partnership%20Inquiry`} class="mn-btn mn-btn--outline">Inquire About Partnerships <span class="mn-btn-arrow">&rarr;</span></a>
      </div>
    </div>
  </section>

  <!-- Upcoming Events -->
  <section class="mn-section mn-section--peach">
    <div class="mn-container">
      <div class="mn-section-header" style="text-align:center;" data-reveal>
        <span class="mn-kicker">Events</span>
        <h2>Upcoming Events</h2>
        <div class="mn-divider mn-divider--center"></div>
      </div>
      <div class="mn-grid-2" data-reveal="delay-1">
        {fabricatedEvents.slice(0, 4).map((event) => (
          <div class="mn-card">
            <div style="display:flex;align-items:flex-start;gap:var(--mn-space-4);">
              <div style="min-width:56px;text-align:center;">
                <div style="font-family:var(--mn-font-heading);font-size:var(--mn-text-xs);font-weight:700;text-transform:uppercase;color:var(--mn-gold);letter-spacing:0.06em;">{event.type}</div>
              </div>
              <div>
                <h3 style="font-size:var(--mn-text-base);margin-bottom:var(--mn-space-1);">{event.title}</h3>
                <p style="font-size:var(--mn-text-xs);color:var(--mn-gold);font-weight:600;margin-bottom:var(--mn-space-1);">{event.date} · {event.time}</p>
                <p style="font-size:var(--mn-text-xs);color:var(--mn-text-light);margin-bottom:var(--mn-space-2);">{event.location}</p>
                <p style="font-size:var(--mn-text-sm);color:var(--mn-text-secondary);line-height:1.6;">{event.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="mn-section mn-section--green" style="text-align:center;">
    <div class="mn-container" data-reveal>
      <h2 style="margin-bottom:var(--mn-space-4);">Let's Connect</h2>
      <p style="color:var(--mn-sage);max-width:440px;margin:0 auto var(--mn-space-5);">Have questions? Want to learn more? We'd love to hear from you.</p>
      <div style="display:flex;flex-direction:column;align-items:center;gap:var(--mn-space-3);">
        <a href={`mailto:${organization.contact.email}`} class="mn-btn mn-btn--gold">Email Us <span class="mn-btn-arrow">&rarr;</span></a>
        <p style="font-size:var(--mn-text-sm);color:var(--mn-sage);">{organization.contact.address}</p>
      </div>
    </div>
  </section>

  <Footer />
</MentorshipLayout>
