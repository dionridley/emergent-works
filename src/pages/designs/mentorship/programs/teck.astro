---
import MentorshipLayout from "../../../../layouts/designs/MentorshipLayout.astro";
import Header from "../../../../components/designs/mentorship/Header.astro";
import Footer from "../../../../components/designs/mentorship/Footer.astro";
import { programs } from "../../../../data/programs";
import { expandedProgramDetails, alumniStories } from "../../../../data/fabricated";
import { partners } from "../../../../data/partners";

const teck = programs.find((p) => p.id === "teck")!;
const details = expandedProgramDetails.find((d) => d.programId === "teck")!;
const deshawn = alumniStories.find((a) => a.program === "TECK")!;
---

<MentorshipLayout title="TECK Program">
  <Header currentPath="/designs/mentorship/programs/" />

  <section class="mn-section" style="padding-top:calc(var(--mn-header-height) + var(--mn-space-16));">
    <div class="mn-container" data-reveal>
      <span class="mn-kicker">Partner Program</span>
      <h1 style="font-size:var(--mn-text-5xl);font-weight:900;">TECK</h1>
      <p style="font-size:var(--mn-text-md);color:var(--mn-text-secondary);max-width:560px;margin-top:var(--mn-space-5);line-height:1.75;">{teck.description}</p>
    </div>
  </section>

  <!-- Key Details -->
  <section class="mn-section mn-section--white">
    <div class="mn-container">
      <div class="mn-split" data-split-reveal>
        <div class="mn-split__side mn-split__side--mentor">
          <span class="mn-kicker">Details</span>
          <h3 style="margin-bottom:var(--mn-space-5);">Program Overview</h3>
          <div style="display:flex;flex-direction:column;gap:var(--mn-space-4);">
            <div>
              <div style="font-size:var(--mn-text-xs);text-transform:uppercase;letter-spacing:0.1em;color:var(--mn-gold);font-weight:700;margin-bottom:var(--mn-space-1);">Duration</div>
              <div style="color:var(--mn-white);">{teck.duration}</div>
            </div>
            <div>
              <div style="font-size:var(--mn-text-xs);text-transform:uppercase;letter-spacing:0.1em;color:var(--mn-gold);font-weight:700;margin-bottom:var(--mn-space-1);">Eligibility</div>
              <div style="color:var(--mn-sage);">{teck.eligibility}</div>
            </div>
            <div>
              <div style="font-size:var(--mn-text-xs);text-transform:uppercase;letter-spacing:0.1em;color:var(--mn-gold);font-weight:700;margin-bottom:var(--mn-space-1);">Format</div>
              <div style="color:var(--mn-white);">Customized for partner organizations</div>
            </div>
          </div>
        </div>
        <div class="mn-split__side mn-split__side--gold">
          <span class="mn-kicker">Tools</span>
          <h3 style="color:var(--mn-green);margin-bottom:var(--mn-space-5);">What You'll Learn</h3>
          <div style="display:flex;flex-wrap:wrap;gap:var(--mn-space-2);">
            {teck.features.map((feat) => (
              <span style="font-size:var(--mn-text-sm);background:var(--mn-white);color:var(--mn-green);padding:0.4rem 1rem;border-radius:999px;font-weight:600;box-shadow:var(--mn-shadow-sm);">{feat}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Curriculum Modules -->
  <section class="mn-section mn-section--sage">
    <div class="mn-container">
      <div class="mn-section-header" style="text-align:center;" data-reveal>
        <span class="mn-kicker">Curriculum</span>
        <h2>Learning Modules</h2>
        <div class="mn-divider mn-divider--center"></div>
      </div>
      <div class="mn-steps" data-reveal="delay-1">
        {details.curriculumOutline?.map((mod, i) => {
          const [title, ...descParts] = mod.split(": ");
          return (
            <div class="mn-step">
              <div class="mn-step__circle">{i + 1}</div>
              <div class="mn-step__title">{title}</div>
              <p class="mn-step__desc">{descParts.join(": ")}</p>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Tools Covered -->
  <section class="mn-section mn-section--white">
    <div class="mn-container">
      <div class="mn-section-header" data-reveal>
        <span class="mn-kicker">Tools</span>
        <h2>Industry Tools Covered</h2>
        <div class="mn-divider"></div>
      </div>
      <div class="mn-grid-3" data-reveal="delay-1">
        {details.toolsCovered?.map((tool) => (
          <div class="mn-card mn-card--cream" style="text-align:center;padding:var(--mn-space-6) var(--mn-space-4);">
            <div style="font-family:var(--mn-font-heading);font-size:var(--mn-text-lg);font-weight:700;color:var(--mn-green);">{tool}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Graduate Story -->
  <section class="mn-section mn-section--peach">
    <div class="mn-container" data-reveal>
      <div style="text-align:center;max-width:600px;margin:0 auto;">
        <span class="mn-kicker" style="margin:0 auto var(--mn-space-4);">Graduate Story</span>
        <blockquote style="font-size:var(--mn-text-xl);font-weight:600;font-family:var(--mn-font-heading);color:var(--mn-green);line-height:1.5;margin-bottom:var(--mn-space-4);">
          "{deshawn.quote}"
        </blockquote>
        <cite style="font-size:var(--mn-text-sm);font-weight:600;color:var(--mn-green);font-style:normal;">— {deshawn.name}, {deshawn.currentRole}</cite>
      </div>
    </div>
  </section>

  <!-- Partner Logos -->
  <section class="mn-section mn-section--cream">
    <div class="mn-container">
      <div class="mn-section-header" style="text-align:center;" data-reveal>
        <span class="mn-kicker">Trusted By</span>
        <h2>Our Partners</h2>
        <div class="mn-divider mn-divider--center"></div>
      </div>
      <div class="partner-logos" data-reveal="delay-1">
        {partners.slice(0, 6).map((partner) => (
          <div class="partner-logo">
            <img src={partner.logo} alt={partner.name} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="mn-section mn-section--green" style="text-align:center;">
    <div class="mn-container" data-reveal>
      <h2 style="margin-bottom:var(--mn-space-5);">Bring TECK to Your Organization</h2>
      <p style="color:var(--mn-sage);max-width:440px;margin:0 auto var(--mn-space-6);">Custom digital literacy cohorts designed around your community's needs and schedule.</p>
      <a href="/designs/mentorship/get-involved/" class="mn-btn mn-btn--gold">Partner With Us <span class="mn-btn-arrow">&rarr;</span></a>
    </div>
  </section>

  <Footer />
</MentorshipLayout>

<style>
  .partner-logos {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: var(--mn-space-7);
  }

  .partner-logo {
    width: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.7;
    transition: opacity var(--mn-duration);
  }

  .partner-logo:hover {
    opacity: 1;
  }

  .partner-logo img {
    max-height: 48px;
    object-fit: contain;
    filter: grayscale(30%);
  }

  .partner-logo:hover img {
    filter: none;
  }
</style>
