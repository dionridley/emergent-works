---
import MentorshipLayout from "../../../../layouts/designs/MentorshipLayout.astro";
import Header from "../../../../components/designs/mentorship/Header.astro";
import Footer from "../../../../components/designs/mentorship/Footer.astro";
import { programs, directPrograms, partnerPrograms, programApproach } from "../../../../data/programs";
import { primaryStats } from "../../../../data/stats";
---

<MentorshipLayout title="Programs">
  <Header currentPath="/designs/mentorship/programs/" />

  <section class="mn-section" style="padding-top:calc(var(--mn-header-height) + var(--mn-space-16));">
    <div class="mn-container" data-reveal>
      <span class="mn-kicker">Programs</span>
      <h1 style="font-size:var(--mn-text-5xl);font-weight:900;">Where<br />Growth<br />Begins</h1>
      <p style="font-size:var(--mn-text-md);color:var(--mn-text-secondary);max-width:520px;margin-top:var(--mn-space-5);line-height:1.75;">Every program is designed around human connection — pairing participants with mentors, peers, and communities that believe in their potential.</p>
    </div>
  </section>

  <!-- Direct Programs -->
  <section class="mn-section mn-section--white">
    <div class="mn-container">
      <div class="mn-section-header" data-reveal>
        <span class="mn-kicker">Direct Programs</span>
        <h2>Our Flagship Programs</h2>
        <div class="mn-divider"></div>
        <p>Open-enrollment programs directly serving system-impacted individuals.</p>
      </div>
      <div class="mn-grid-2" data-reveal="delay-1">
        {directPrograms.map((program) => (
          <div class="mn-card mn-card--cream" style="display:flex;flex-direction:column;gap:var(--mn-space-3);">
            <span class="mn-kicker" style="align-self:flex-start;">{program.type === "direct" ? "Direct" : "Partner"}</span>
            <h3 style="font-size:var(--mn-text-2xl);margin-bottom:var(--mn-space-1);">{program.title}</h3>
            <p style="color:var(--mn-text-secondary);font-size:var(--mn-text-sm);line-height:1.75;">{program.description}</p>
            <div style="display:flex;flex-wrap:wrap;gap:var(--mn-space-2);margin-top:var(--mn-space-2);">
              {program.features.slice(0, 4).map((feat) => (
                <span style="font-size:var(--mn-text-xs);background:var(--mn-sage-light);color:var(--mn-green);padding:0.2rem 0.6rem;border-radius:999px;font-weight:600;">{feat}</span>
              ))}
            </div>
            <div style="display:flex;gap:var(--mn-space-4);margin-top:auto;padding-top:var(--mn-space-3);font-size:var(--mn-text-sm);color:var(--mn-text-light);">
              <span>Eligibility: {program.eligibility}</span>
            </div>
            <a href={`/designs/mentorship/programs/${program.id === "technical-mentorship" ? "trap" : program.id}/`} class="mn-btn mn-btn--primary" style="align-self:flex-start;margin-top:var(--mn-space-2);">
              Learn More <span class="mn-btn-arrow">&rarr;</span>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Partner Programs -->
  <section class="mn-section mn-section--peach">
    <div class="mn-container">
      <div class="mn-section-header" data-reveal>
        <span class="mn-kicker">Partner Programs</span>
        <h2>Programs for Organizations</h2>
        <div class="mn-divider"></div>
        <p>Custom cohorts designed for partner organizations serving system-impacted communities.</p>
      </div>
      <div class="mn-grid-2" data-reveal="delay-1">
        {partnerPrograms.map((program) => (
          <div class="mn-card" style="display:flex;flex-direction:column;gap:var(--mn-space-3);">
            <span class="mn-kicker" style="align-self:flex-start;background:rgba(249,197,180,0.3);">Partner</span>
            <h3 style="font-size:var(--mn-text-xl);margin-bottom:var(--mn-space-1);">{program.title}</h3>
            <p style="color:var(--mn-text-secondary);font-size:var(--mn-text-sm);line-height:1.75;">{program.description}</p>
            <div style="display:flex;flex-wrap:wrap;gap:var(--mn-space-2);margin-top:var(--mn-space-2);">
              {program.features.slice(0, 4).map((feat) => (
                <span style="font-size:var(--mn-text-xs);background:var(--mn-peach-light);color:var(--mn-green);padding:0.2rem 0.6rem;border-radius:999px;font-weight:600;">{feat}</span>
              ))}
            </div>
            <p style="font-size:var(--mn-text-sm);color:var(--mn-text-light);margin-top:auto;padding-top:var(--mn-space-3);">Duration: {program.duration}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Approach Pillars -->
  <section class="mn-section mn-section--sage">
    <div class="mn-container">
      <div class="mn-section-header" style="text-align:center;" data-reveal>
        <span class="mn-kicker">Our Approach</span>
        <h2>Four Pillars of Growth</h2>
        <div class="mn-divider mn-divider--center"></div>
      </div>
      <div class="mn-grid-4" data-reveal="delay-1">
        {programApproach.map((pillar, i) => (
          <div class="mn-card mn-card--cream" style="text-align:center;padding:var(--mn-space-7) var(--mn-space-4);">
            <div style="width:48px;height:48px;border-radius:50%;background:var(--mn-gold);display:flex;align-items:center;justify-content:center;margin:0 auto var(--mn-space-4);font-family:var(--mn-font-heading);font-weight:800;color:var(--mn-green-dark);font-size:var(--mn-text-lg);">{i + 1}</div>
            <h3 style="font-size:var(--mn-text-base);margin-bottom:var(--mn-space-2);">{pillar.title}</h3>
            <p style="font-size:var(--mn-text-sm);color:var(--mn-text-secondary);line-height:1.65;">{pillar.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Quick Impact -->
  <section class="mn-section mn-section--green" style="text-align:center;">
    <div class="mn-container" data-reveal>
      <span class="mn-kicker">Results</span>
      <h2 style="margin-bottom:var(--mn-space-7);">Connection Creates Impact</h2>
      <div class="mn-grid-3">
        {primaryStats.map((stat) => (
          <div style="padding:var(--mn-space-4);">
            <div style="font-family:var(--mn-font-heading);font-size:var(--mn-text-4xl);font-weight:900;color:var(--mn-gold);line-height:1;">{stat.value}</div>
            <div style="font-family:var(--mn-font-heading);font-size:var(--mn-text-sm);font-weight:700;color:var(--mn-white);margin-top:var(--mn-space-2);text-transform:uppercase;letter-spacing:0.06em;">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="mn-section" style="text-align:center;">
    <div class="mn-container" data-reveal>
      <h2 style="margin-bottom:var(--mn-space-4);">Ready to Connect?</h2>
      <p style="color:var(--mn-text-secondary);max-width:420px;margin:0 auto var(--mn-space-6);">Whether you're looking to grow your skills or share your expertise, there's a place for you here.</p>
      <div style="display:flex;gap:var(--mn-space-3);justify-content:center;flex-wrap:wrap;">
        <a href="/designs/mentorship/get-involved/" class="mn-btn mn-btn--primary">Get Involved <span class="mn-btn-arrow">&rarr;</span></a>
        <a href="/designs/mentorship/about/" class="mn-btn mn-btn--outline">About Us</a>
      </div>
    </div>
  </section>

  <Footer />
</MentorshipLayout>
