---
import MentorshipLayout from "../../../layouts/designs/MentorshipLayout.astro";
import Header from "../../../components/designs/mentorship/Header.astro";
import Footer from "../../../components/designs/mentorship/Footer.astro";
import { organization } from "../../../data/organization";
import { programApproach } from "../../../data/programs";
---

<MentorshipLayout title="About">
  <Header currentPath="/designs/mentorship/about/" />

  <section class="mn-section" style="padding-top:calc(var(--mn-header-height) + var(--mn-space-16));">
    <div class="mn-container" data-reveal>
      <span class="mn-kicker">About</span>
      <h1 style="font-size:var(--mn-text-5xl);font-weight:900;">Where<br />Connection<br />Meets Purpose</h1>
      <p style="font-size:var(--mn-text-md);color:var(--mn-text-secondary);max-width:520px;margin-top:var(--mn-space-5);line-height:1.75;">A 501(c)(3) nonprofit that believes the path out of incarceration runs through human connection and mentorship.</p>
    </div>
  </section>

  <!-- Origin story as split -->
  <section class="mn-section mn-section--white">
    <div class="mn-container">
      <div class="mn-split" data-split-reveal>
        <div class="mn-split__side mn-split__side--mentor">
          <span class="mn-kicker" style="background:rgba(255,203,112,0.2);">The Founder</span>
          <h3 style="margin-bottom:var(--mn-space-4);">Army Armstead's Story</h3>
          <p style="color:var(--mn-sage);line-height:1.8;">
            In 2020, Army Armstead founded Emergent Works with a conviction born from lived experience:
            the people most affected by mass incarceration deserved more than a second chance — they
            deserved the tools to build entirely new futures. Having been mentored himself, Army understood
            that connection changes everything.
          </p>
        </div>
        <div class="mn-split__side mn-split__side--peach">
          <span class="mn-kicker">The Mission</span>
          <h3 style="color:var(--mn-green);margin-bottom:var(--mn-space-4);">What We Believe</h3>
          <p style="color:var(--mn-text-secondary);line-height:1.8;">
            {organization.extendedMission}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Staff Stats -->
  <section class="mn-section mn-section--sage">
    <div class="mn-container">
      <div class="mn-section-header" style="text-align:center;" data-reveal>
        <span class="mn-kicker">Our People</span>
        <h2>Who We Are</h2>
        <div class="mn-divider mn-divider--center"></div>
      </div>
      <div class="mn-grid-4" data-reveal="delay-1">
        {[
          { value: organization.staffStats.alumni, label: "Staff are alumni" },
          { value: organization.staffStats.systemImpacted, label: "System-impacted" },
          { value: organization.staffStats.bipoc, label: "BIPOC" },
          { value: organization.staffStats.femaleIdentifying, label: "Female-identifying" },
        ].map((stat) => (
          <div class="mn-card mn-card--cream" style="text-align:center;padding:var(--mn-space-7) var(--mn-space-4);">
            <div style="font-family:var(--mn-font-heading);font-size:var(--mn-text-4xl);font-weight:900;color:var(--mn-green);line-height:1;">{stat.value}</div>
            <div style="font-family:var(--mn-font-heading);font-size:var(--mn-text-sm);font-weight:600;color:var(--mn-text-secondary);margin-top:var(--mn-space-2);">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Approach -->
  <section class="mn-section mn-section--white">
    <div class="mn-container">
      <div class="mn-section-header" data-reveal>
        <span class="mn-kicker">Approach</span>
        <h2>Four Pillars of Connection</h2>
        <div class="mn-divider"></div>
      </div>
      <div class="mn-grid-2" data-reveal="delay-1">
        {programApproach.map((pillar) => (
          <div class="mn-card">
            <h3 style="color:var(--mn-green);margin-bottom:var(--mn-space-2);">{pillar.title}</h3>
            <p style="color:var(--mn-text-secondary);font-size:var(--mn-text-sm);line-height:1.7;">{pillar.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="mn-section mn-section--green" style="text-align:center;">
    <div class="mn-container" data-reveal>
      <h2 style="margin-bottom:var(--mn-space-5);">Start a Connection</h2>
      <p style="color:var(--mn-sage);max-width:420px;margin:0 auto var(--mn-space-6);">Whether as a mentor, mentee, or supporter — your connection matters.</p>
      <a href="/designs/mentorship/get-involved/" class="mn-btn mn-btn--gold">Get Involved <span class="mn-btn-arrow">&rarr;</span></a>
    </div>
  </section>

  <Footer />
</MentorshipLayout>
