---
import MentorshipLayout from "../../../layouts/designs/MentorshipLayout.astro";
import Header from "../../../components/designs/mentorship/Header.astro";
import Footer from "../../../components/designs/mentorship/Footer.astro";
import ContentSummaryTable from "../../../components/designs/shared/ContentSummaryTable.astro";
import type { ContentItem, StockImage, TypographyDeviation } from "../../../components/designs/shared/ContentSummaryTable.astro";

const contentItems: ContentItem[] = [
  // Real content
  { item: "Organization mission & extended mission", source: "Real", page: "Home, About, Footer", notes: "From organization.ts" },
  { item: "Primary stats (261 graduates, 73% employed, $2+ above min wage)", source: "Real", page: "Home, Programs", notes: "From stats.ts" },
  { item: "Staff stats (100% alumni, 80% system-impacted, etc.)", source: "Real", page: "About", notes: "From organization.ts" },
  { item: "Program descriptions (T.RAP, Technical Mentorship, TECK)", source: "Real", page: "Programs, T.RAP, TECK", notes: "From programs.ts" },
  { item: "Program approach / four pillars", source: "Real", page: "About, Programs", notes: "From programs.ts" },
  { item: "Testimonials (Nashid, Julius)", source: "Real", page: "Home, T.RAP", notes: "From testimonials.ts" },
  { item: "Partner organizations & logos", source: "Real", page: "TECK", notes: "From partners.ts" },
  { item: "Donation tiers & trust statement", source: "Real", page: "Get Involved", notes: "From donation.ts" },
  { item: "Partnership types", source: "Real", page: "Get Involved", notes: "From partners.ts" },
  { item: "Social links & contact info", source: "Real", page: "Footer, Get Involved", notes: "From organization.ts" },
  { item: "Founder origin narrative", source: "Real", page: "About", notes: "Based on real founder story" },

  // Fabricated content
  { item: "Staff bios", source: "Fabricated", page: "Team", notes: "Replace with real staff bios" },
  { item: "Board of Directors bios", source: "Fabricated", page: "Team", notes: "Replace with real board bios" },
  { item: "Advisory Board bios", source: "Fabricated", page: "Team", notes: "Replace with real advisory bios" },
  { item: "Mentor profiles (Priya, James, Lisa, David)", source: "Fabricated", page: "Home, Team", notes: "Replace with real mentor profiles" },
  { item: "Alumni stories (Marcus, Aisha, DeShawn)", source: "Fabricated", page: "Home, T.RAP, TECK", notes: "Replace with real alumni stories" },
  { item: "Expanded program details (weekly schedules, curriculum outlines)", source: "Fabricated", page: "T.RAP, TECK", notes: "Replace with real schedules" },
  { item: "Upcoming events", source: "Fabricated", page: "Get Involved", notes: "Replace with real events" },

  // Stock photos
  { item: "Hero mentor portrait (portrait-1.jpg)", source: "Stock Photo", page: "Home", notes: "Replace with real mentor photo" },
  { item: "Hero mentee portrait (portrait-7.jpg)", source: "Stock Photo", page: "Home", notes: "Replace with real mentee photo" },
];

const stockImages: StockImage[] = [
  {
    filename: "portrait-1.jpg",
    sourceUrl: "https://unsplash.com",
    usedOn: "Home (hero mentor portrait)",
    description: "Professional portrait used as placeholder mentor image in hero section paired portraits",
  },
  {
    filename: "portrait-7.jpg",
    sourceUrl: "https://unsplash.com",
    usedOn: "Home (hero mentee portrait)",
    description: "Professional portrait used as placeholder mentee image in hero section paired portraits",
  },
];

const typographyDeviations: TypographyDeviation[] = [];
---

<MentorshipLayout title="Content Summary">
  <Header currentPath="" />

  <section class="mn-section" style="padding-top:calc(var(--mn-header-height) + var(--mn-space-16));">
    <div class="mn-container" data-reveal>
      <span class="mn-kicker">Internal</span>
      <h1 style="font-size:var(--mn-text-3xl);font-weight:900;">Content Summary</h1>
      <p style="font-size:var(--mn-text-md);color:var(--mn-text-secondary);max-width:560px;margin-top:var(--mn-space-4);line-height:1.75;">Audit of real vs. fabricated content used in the Mentorship design variation. Use this to identify what needs to be replaced before production.</p>
    </div>
  </section>

  <section class="mn-section mn-section--white">
    <ContentSummaryTable
      designName="Mentorship (Warm/Personal)"
      contentItems={contentItems}
      stockImages={stockImages}
      typographyDeviations={typographyDeviations}
    />
  </section>

  <Footer />
</MentorshipLayout>
