---
/**
 * Stories — Content Summary
 * Documents all real vs fabricated content, stock images, and typography deviations.
 */

import StoriesLayout from "../../../layouts/designs/StoriesLayout.astro";
import ContentSummaryTable from "../../../components/designs/shared/ContentSummaryTable.astro";
import type { ContentItem, StockImage, TypographyDeviation } from "../../../components/designs/shared/ContentSummaryTable.astro";

const contentItems: ContentItem[] = [
  // Organization data
  { item: "Organization name, EIN, address", source: "Real", page: "All pages (footer)", notes: "From existing site" },
  { item: "Mission statement", source: "Real", page: "Home, About", notes: "From existing site" },
  { item: "Extended mission statement", source: "Real", page: "About", notes: "From existing site" },
  { item: "Social media links", source: "Real", page: "All pages (footer), Get Involved", notes: "From existing site" },

  // Impact stats
  { item: "261 graduates stat", source: "Real", page: "Home (impact section)", notes: "From existing impact page" },
  { item: "73% employed stat", source: "Real", page: "Home (impact section)", notes: "From existing impact page" },
  { item: "98%+ no re-offense stat", source: "Real", page: "Home (impact section)", notes: "From existing impact page" },
  { item: "$2+ above min wage stat", source: "Real", page: "Home (impact section)", notes: "From existing impact page" },
  { item: "8 contracted graduates stat", source: "Real", page: "Home (impact section)", notes: "From existing impact page" },

  // Programs
  { item: "T.RAP program description, eligibility, duration", source: "Real", page: "Programs, T.RAP detail", notes: "From existing programs page" },
  { item: "Technical Mentorship description", source: "Real", page: "Programs", notes: "From existing programs page" },
  { item: "TECK description", source: "Real", page: "Programs, TECK detail", notes: "From existing programs page" },
  { item: "T.RAP curriculum outline (4 phases)", source: "Fabricated", page: "T.RAP detail", notes: "Plausible progression — needs verification" },
  { item: "TECK curriculum modules", source: "Fabricated", page: "TECK detail", notes: "Based on tools listed in real description — needs verification" },

  // Testimonials
  { item: "Nashid testimonial + image", source: "Real", page: "Home (featured voice)", notes: "From existing site" },
  { item: "Dontay testimonial + image", source: "Real", page: "Home (voice card)", notes: "From existing site" },
  { item: "Sheisty testimonial", source: "Real", page: "Home (voice card), T.RAP detail", notes: "From existing site" },
  { item: "Julius testimonial", source: "Real", page: "T.RAP detail", notes: "From existing site" },
  { item: "Blueberry testimonial", source: "Real", page: "Programs overview (implied)", notes: "From existing site" },

  // Fabricated alumni stories
  { item: "Marcus — alumni story (T.RAP graduate, freelance producer)", source: "Fabricated", page: "Home (featured story), Programs", notes: "Fabricated alumni for editorial narrative — replace with real alumni story" },
  { item: "Aisha — alumni story (T.RAP, songwriter)", source: "Fabricated", page: "T.RAP detail", notes: "Fabricated alumni — replace with real alumni" },
  { item: "DeShawn — alumni story (TECK, IT specialist)", source: "Fabricated", page: "TECK detail", notes: "Fabricated alumni — replace with real alumni" },
  { item: "Priya — fabricated mentor quote", source: "Fabricated", page: "Get Involved (mentor story)", notes: "Fabricated mentor — replace with real mentor testimonial" },

  // Team
  { item: "Staff names and titles (5 people)", source: "Real", page: "Team", notes: "From existing team page" },
  { item: "Board names and titles (5 people)", source: "Real", page: "Team", notes: "From existing team page" },
  { item: "Advisory board names and titles (3 people)", source: "Real", page: "Team", notes: "From existing team page" },
  { item: "All team member bios", source: "Fabricated", page: "Team", notes: "Plausible bios — replace with real bios from team members" },
  { item: "Staff composition stats (100% alumni, 80% system-impacted, etc.)", source: "Real", page: "About", notes: "From existing site" },

  // Partners
  { item: "Partner organization names (13)", source: "Real", page: "Programs overview", notes: "From existing partner page" },
  { item: "Partnership type descriptions", source: "Real", page: "Get Involved", notes: "From existing partner page" },

  // Donation
  { item: "Donation tiers ($50, $100, $200, $1,000)", source: "Real", page: "Get Involved", notes: "From existing donation page" },
  { item: "Donation impact statements", source: "Real", page: "Get Involved", notes: "From existing donation page" },
  { item: "Tax deductibility notice", source: "Real", page: "Get Involved", notes: "From existing donation page" },

  // Narrative content
  { item: "Origin story narrative (Army Armstead founding)", source: "Fabricated", page: "About", notes: "Based on real founder info — narrative details need verification" },
  { item: "Pull quote: 'We don't just talk about reentry...'", source: "Fabricated", page: "About", notes: "Inspirational quote attributed to the team — needs approval" },
  { item: "Program approach pillars (4 pillars)", source: "Real", page: "About", notes: "From existing site programmatic approach" },

  // Photos (real)
  { item: "Team placeholder photos (4 images)", source: "Real", page: "Team", notes: "Existing placeholder images" },
  { item: "Testimonial photos (Dontay, Nashid, Sheisty)", source: "Real", page: "Home", notes: "From existing site" },
  { item: "Program photos (trap-studio, mentorship-library, teck-library)", source: "Real", page: "Programs, T.RAP, TECK", notes: "From existing site" },
  { item: "About page photo (mission-group)", source: "Real", page: "About", notes: "From existing site" },
  { item: "Hero photo (community.jpg)", source: "Real", page: "Home", notes: "From existing site" },

  // Stock photos
  { item: "Stock: portrait-7.jpg (Marcus featured story)", source: "Stock Photo", page: "Home", notes: "Replace with real alumni portrait" },
  { item: "Stock: community-group-4.jpg (CTA background)", source: "Stock Photo", page: "Home", notes: "Replace with real community photo" },
  { item: "Stock: portrait-5.jpg (mentor testimonial)", source: "Stock Photo", page: "Get Involved", notes: "Replace with real mentor photo" },
  { item: "Stock: music-studio-2.jpg (T.RAP story)", source: "Stock Photo", page: "T.RAP detail", notes: "Replace with real studio photo" },
  { item: "Stock: tech-coding-4.jpg (TECK story)", source: "Stock Photo", page: "TECK detail", notes: "Replace with real program photo" },
];

const stockImages: StockImage[] = [
  { filename: "portrait-7.jpg", sourceUrl: "https://unsplash.com", usedOn: "Home (Featured Story)", description: "Portrait used for fabricated alumni Marcus" },
  { filename: "community-group-4.jpg", sourceUrl: "https://unsplash.com", usedOn: "Home (CTA section background)", description: "Community group photo used as cinematic background" },
  { filename: "portrait-5.jpg", sourceUrl: "https://unsplash.com", usedOn: "Get Involved (Mentor testimonial)", description: "Portrait for fabricated mentor Priya" },
  { filename: "music-studio-2.jpg", sourceUrl: "https://unsplash.com", usedOn: "T.RAP detail (Alumni story)", description: "Music studio scene for T.RAP program page" },
  { filename: "tech-coding-4.jpg", sourceUrl: "https://unsplash.com", usedOn: "TECK detail (Alumni story)", description: "Coding scene for TECK program page" },
];

const typographyDeviations: TypographyDeviation[] = [
  {
    element: "Pull quotes (blockquote.st-pullquote)",
    expected: "Plus Jakarta Sans (body font)",
    actual: "Cormorant Garamond (serif)",
    reason: "Editorial/magazine aesthetic requires serif accents for pull quotes to create the high-end editorial feel characteristic of publications like NYT Magazine"
  },
  {
    element: "Chapter markers (.st-chapter)",
    expected: "Outfit or Plus Jakarta Sans",
    actual: "Cormorant Garamond (serif italic)",
    reason: "Serif italic for editorial section markers creates a literary, story-driven navigation feel"
  },
  {
    element: "Footer headings",
    expected: "Outfit (heading font)",
    actual: "Cormorant Garamond (serif italic)",
    reason: "Maintains editorial consistency throughout, including the footer's elegant sign-off aesthetic"
  },
  {
    element: ".st-serif utility class",
    expected: "Plus Jakarta Sans (body font)",
    actual: "Cormorant Garamond (serif)",
    reason: "General-purpose serif class used for editorial accents like roles, captions, and secondary quotes throughout the design"
  },
];
---

<StoriesLayout title="Content Summary">
  <div style="padding-top: calc(var(--st-header-height) + var(--st-space-8));">
    <div class="st-container">
      <div style="margin-bottom: var(--st-space-6);">
        <a href="/designs/stories/" style="font-size: 0.875rem; color: var(--st-green); font-weight: 500;">
          &larr; Back to Stories
        </a>
      </div>
    </div>
    <ContentSummaryTable
      designName="Stories"
      contentItems={contentItems}
      stockImages={stockImages}
      typographyDeviations={typographyDeviations}
    />
  </div>
</StoriesLayout>
