---
/**
 * The Journey — Layout
 * Scroll-driven interactive documentary.
 * Cinematic chapters that transition from darkness to light.
 * Film grain, color interpolation, text reveals, chapter navigation.
 *
 * CSS namespace: --tj-
 * Typography: Outfit (headings), Plus Jakarta Sans (body) — no deviations
 */

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Emergent Works — combating mass incarceration through tech education" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Emergent Works</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400;1,500&display=swap" rel="stylesheet" />
</head>
<body>
  <!-- Scroll Progress Bar -->
  <div class="tj-progress" aria-hidden="true">
    <div class="tj-progress__bar" id="tj-progress-bar"></div>
  </div>

  <!-- Film Grain Overlay -->
  <div class="tj-grain" aria-hidden="true"></div>

  <!-- Chapter Navigation Dots -->
  <nav class="tj-chapter-nav" id="tj-chapter-nav" aria-label="Chapter navigation">
    <div class="tj-chapter-nav__track"></div>
  </nav>

  <slot />

  <script>
    // === SCROLL PROGRESS BAR ===
    const progressBar = document.getElementById("tj-progress-bar");
    const chapterNav = document.getElementById("tj-chapter-nav");

    // === CHAPTER DETECTION & COLOR INTERPOLATION ===
    const chapters = document.querySelectorAll("[data-chapter]");
    const chapterColors: Record<string, { bg: string; text: string }> = {
      before:   { bg: "#1a1a1a", text: "#ffffff" },
      opens:    { bg: "#FFF8ED", text: "#242424" },
      learning: { bg: "#FFF8ED", text: "#242424" },
      growing:  { bg: "#e8f2eb", text: "#20493C" },
      emerging: { bg: "#20493C", text: "#ffffff" },
      yours:    { bg: "#052812", text: "#ffffff" },
    };

    // Build chapter nav dots
    if (chapterNav && chapters.length > 0) {
      const track = chapterNav.querySelector(".tj-chapter-nav__track")!;
      chapters.forEach((ch, i) => {
        const id = (ch as HTMLElement).dataset.chapter || "";
        const label = (ch as HTMLElement).dataset.chapterLabel || `Chapter ${i + 1}`;
        const dot = document.createElement("button");
        dot.className = "tj-chapter-nav__dot";
        dot.dataset.index = String(i);
        dot.setAttribute("aria-label", label);
        dot.title = label;
        dot.addEventListener("click", () => {
          ch.scrollIntoView({ behavior: "smooth" });
        });
        track.appendChild(dot);
      });
    }

    // Hide chapter nav if no chapters exist (inner pages)
    if (chapters.length === 0 && chapterNav) {
      chapterNav.style.display = "none";
    }

    // === SCROLL HANDLER ===
    let ticking = false;

    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const scrollY = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight > 0 ? scrollY / docHeight : 0;

        // Update progress bar
        if (progressBar) {
          progressBar.style.transform = `scaleX(${progress})`;
        }

        // Show/hide chapter nav after first viewport
        if (chapterNav && chapters.length > 0) {
          chapterNav.classList.toggle("tj-chapter-nav--visible", scrollY > window.innerHeight * 0.3);
        }

        // Chapter detection & dot highlighting
        if (chapters.length > 0) {
          const dots = chapterNav?.querySelectorAll(".tj-chapter-nav__dot");
          let activeIndex = 0;

          chapters.forEach((ch, i) => {
            const rect = ch.getBoundingClientRect();
            const threshold = window.innerHeight * 0.5;
            if (rect.top < threshold) {
              activeIndex = i;
            }
          });

          dots?.forEach((dot, i) => {
            dot.classList.toggle("tj-chapter-nav__dot--active", i === activeIndex);
          });

          // Color interpolation between chapters
          const current = chapters[activeIndex] as HTMLElement;
          const currentId = current.dataset.chapter || "";
          const colors = chapterColors[currentId];
          if (colors) {
            document.body.style.setProperty("--tj-bg-current", colors.bg);
            document.body.style.setProperty("--tj-text-current", colors.text);
          }
        }

        // Header scroll state
        const header = document.querySelector(".tj-header") as HTMLElement;
        if (header) {
          header.classList.toggle("tj-header--scrolled", scrollY > 40);

          // On chapter pages (with chapters), adapt header to current bg
          if (chapters.length > 0) {
            const isDark = scrollY > window.innerHeight * 0.1;
            header.classList.toggle("tj-header--dark-bg", false);
          }
        }

        ticking = false;
      });
    }

    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll(); // Initial call

    // === TEXT REVEAL (IntersectionObserver) ===
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("tj-visible");
            revealObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: "0px 0px -60px 0px" }
    );

    document.querySelectorAll("[data-reveal]").forEach((el) => revealObserver.observe(el));

    // === STAGGERED REVEALS ===
    const staggerObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const children = entry.target.querySelectorAll("[data-stagger-child]");
            children.forEach((child, i) => {
              (child as HTMLElement).style.transitionDelay = `${i * 100}ms`;
              child.classList.add("tj-visible");
            });
            staggerObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.08 }
    );

    document.querySelectorAll("[data-stagger]").forEach((el) => staggerObserver.observe(el));

    // === WORD-BY-WORD TEXT REVEAL ===
    const wordRevealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const words = entry.target.querySelectorAll(".tj-word");
            words.forEach((word, i) => {
              setTimeout(() => {
                word.classList.add("tj-word--visible");
              }, i * 60);
            });
            wordRevealObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.3 }
    );

    document.querySelectorAll("[data-word-reveal]").forEach((el) => wordRevealObserver.observe(el));
  </script>
</body>
</html>

<style is:global>
  /* ============================
     THE JOURNEY — DESIGN SYSTEM
     CSS Namespace: --tj-
     Cinematic Scroll Documentary
     ============================ */

  :root {
    /* Brand Colors */
    --tj-green: #20493C;
    --tj-green-dark: #052812;
    --tj-gold: #FFCB70;
    --tj-cream: #FFF8ED;
    --tj-sage: #B1D3BB;
    --tj-peach: #F9C5B4;
    --tj-white: #ffffff;
    --tj-text: #242424;
    --tj-text-secondary: #5f6360;
    --tj-text-light: #8a8e8b;

    /* Documentary dark palette */
    --tj-charcoal: #1a1a1a;
    --tj-slate: #2a3a34;
    --tj-dark-muted: #3a4a44;

    /* Warm tints */
    --tj-cream-warm: #fef6e8;
    --tj-sage-light: #e8f2eb;
    --tj-gold-light: #fff3d6;
    --tj-peach-light: #fde8df;

    /* Dynamic (set by JS for chapter pages) */
    --tj-bg-current: var(--tj-cream);
    --tj-text-current: var(--tj-text);

    /* Typography */
    --tj-font-heading: "Outfit", sans-serif;
    --tj-font-body: "Plus Jakarta Sans", sans-serif;

    /* Type Scale */
    --tj-text-xs: 0.6875rem;
    --tj-text-sm: 0.8125rem;
    --tj-text-base: 1rem;
    --tj-text-md: 1.125rem;
    --tj-text-lg: 1.3125rem;
    --tj-text-xl: 1.625rem;
    --tj-text-2xl: 2.125rem;
    --tj-text-3xl: clamp(2.25rem, 4.5vw, 3.25rem);
    --tj-text-4xl: clamp(3rem, 6vw, 4.5rem);
    --tj-text-5xl: clamp(3.5rem, 8vw, 6rem);
    --tj-text-hero: clamp(4rem, 10vw, 8rem);

    /* Spacing */
    --tj-space-1: 0.25rem;
    --tj-space-2: 0.5rem;
    --tj-space-3: 0.75rem;
    --tj-space-4: 1rem;
    --tj-space-5: 1.5rem;
    --tj-space-6: 2rem;
    --tj-space-7: 2.5rem;
    --tj-space-8: 3rem;
    --tj-space-9: 4rem;
    --tj-space-10: 5rem;
    --tj-space-12: 6rem;
    --tj-space-16: 8rem;
    --tj-space-20: 10rem;

    /* Layout */
    --tj-container: 1080px;
    --tj-container-narrow: 720px;
    --tj-header-height: 64px;

    /* Shadows */
    --tj-shadow-sm: 0 2px 8px rgba(0,0,0,0.06);
    --tj-shadow: 0 4px 20px rgba(0,0,0,0.08);
    --tj-shadow-md: 0 8px 32px rgba(0,0,0,0.10);
    --tj-shadow-lg: 0 16px 56px rgba(0,0,0,0.14);
    --tj-shadow-dramatic: 0 24px 80px rgba(0,0,0,0.2);

    /* Motion */
    --tj-duration: 0.35s;
    --tj-duration-slow: 0.7s;
    --tj-duration-cinematic: 1.2s;
    --tj-ease: cubic-bezier(0.25, 0.46, 0.45, 0.94);
    --tj-ease-cinematic: cubic-bezier(0.16, 1, 0.3, 1);
    --tj-ease-dramatic: cubic-bezier(0.4, 0, 0, 1);
  }

  /* ============================
     RESET
     ============================ */

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    font-family: var(--tj-font-body);
    font-size: var(--tj-text-base);
    line-height: 1.7;
    color: var(--tj-text);
    background: var(--tj-cream);
    overflow-x: hidden;
  }

  img { max-width: 100%; height: auto; display: block; }
  a { text-decoration: none; color: inherit; }

  h1, h2, h3, h4, h5, h6 {
    font-family: var(--tj-font-heading);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.025em;
  }

  p { line-height: 1.8; }

  /* ============================
     SCROLL PROGRESS BAR
     ============================ */

  .tj-progress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    z-index: 200;
    background: rgba(0,0,0,0.06);
  }

  .tj-progress__bar {
    height: 100%;
    background: linear-gradient(90deg, var(--tj-gold), var(--tj-peach), var(--tj-gold));
    transform-origin: left;
    transform: scaleX(0);
    will-change: transform;
    transition: none;
  }

  /* ============================
     FILM GRAIN OVERLAY
     ============================ */

  .tj-grain {
    position: fixed;
    inset: 0;
    z-index: 150;
    pointer-events: none;
    opacity: 0.025;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 256px 256px;
  }

  /* ============================
     CHAPTER NAVIGATION DOTS
     ============================ */

  .tj-chapter-nav {
    position: fixed;
    right: 24px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 120;
    opacity: 0;
    transition: opacity var(--tj-duration-slow) var(--tj-ease);
    pointer-events: none;
  }

  .tj-chapter-nav--visible {
    opacity: 1;
    pointer-events: auto;
  }

  .tj-chapter-nav__track {
    display: flex;
    flex-direction: column;
    gap: 14px;
    align-items: center;
  }

  .tj-chapter-nav__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.35);
    background: transparent;
    cursor: pointer;
    transition: all var(--tj-duration) var(--tj-ease);
    padding: 0;
  }

  .tj-chapter-nav__dot:hover {
    border-color: var(--tj-gold);
    transform: scale(1.3);
  }

  .tj-chapter-nav__dot--active {
    background: var(--tj-gold);
    border-color: var(--tj-gold);
    transform: scale(1.2);
  }

  /* ============================
     CONTAINER
     ============================ */

  .tj-container {
    width: 100%;
    max-width: var(--tj-container);
    margin: 0 auto;
    padding: 0 var(--tj-space-5);
  }

  .tj-container--narrow {
    max-width: var(--tj-container-narrow);
  }

  /* ============================
     HEADER
     ============================ */

  .tj-header {
    position: fixed;
    top: 3px; /* below progress bar */
    left: 0;
    right: 0;
    z-index: 110;
    height: var(--tj-header-height);
    display: flex;
    align-items: center;
    transition: background var(--tj-duration-slow) var(--tj-ease),
                box-shadow var(--tj-duration-slow) var(--tj-ease);
  }

  .tj-header--scrolled {
    background: rgba(255,248,237,0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: var(--tj-shadow-sm);
  }

  .tj-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: var(--tj-container);
    margin: 0 auto;
    padding: 0 var(--tj-space-5);
  }

  .tj-header__logo {
    display: flex;
    align-items: center;
    gap: var(--tj-space-3);
    font-family: var(--tj-font-heading);
    font-weight: 700;
    font-size: var(--tj-text-md);
    color: var(--tj-green);
    letter-spacing: -0.01em;
  }

  .tj-header__logo img {
    height: 32px;
    width: auto;
  }

  .tj-header__nav {
    display: flex;
    align-items: center;
    gap: var(--tj-space-5);
    list-style: none;
  }

  .tj-header__nav a {
    font-family: var(--tj-font-body);
    font-size: var(--tj-text-sm);
    font-weight: 600;
    color: var(--tj-text-secondary);
    transition: color var(--tj-duration);
    position: relative;
  }

  .tj-header__nav a:hover {
    color: var(--tj-green);
  }

  .tj-header__nav a.tj-active {
    color: var(--tj-green);
  }

  .tj-header__nav a.tj-active::after {
    content: "";
    position: absolute;
    bottom: -4px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--tj-gold);
    border-radius: 1px;
  }

  /* ============================
     CHAPTERS — Full viewport sections
     ============================ */

  .tj-chapter {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    transition: background-color 0.8s var(--tj-ease-dramatic);
  }

  .tj-chapter__inner {
    width: 100%;
    max-width: var(--tj-container);
    margin: 0 auto;
    padding: var(--tj-space-16) var(--tj-space-5);
    position: relative;
    z-index: 2;
  }

  .tj-chapter__inner--narrow {
    max-width: var(--tj-container-narrow);
  }

  /* Chapter color themes */
  .tj-chapter--dark {
    background: var(--tj-charcoal);
    color: var(--tj-white);
  }

  .tj-chapter--dark h1, .tj-chapter--dark h2, .tj-chapter--dark h3, .tj-chapter--dark h4 {
    color: var(--tj-white);
  }

  .tj-chapter--slate {
    background: var(--tj-slate);
    color: rgba(255,255,255,0.85);
  }

  .tj-chapter--slate h1, .tj-chapter--slate h2, .tj-chapter--slate h3 {
    color: var(--tj-white);
  }

  .tj-chapter--cream {
    background: var(--tj-cream);
    color: var(--tj-text);
  }

  .tj-chapter--cream h1, .tj-chapter--cream h2, .tj-chapter--cream h3 {
    color: var(--tj-green);
  }

  .tj-chapter--warm {
    background: var(--tj-cream-warm);
    color: var(--tj-text);
  }

  .tj-chapter--warm h1, .tj-chapter--warm h2, .tj-chapter--warm h3 {
    color: var(--tj-green);
  }

  .tj-chapter--sage {
    background: var(--tj-sage-light);
    color: var(--tj-green);
  }

  .tj-chapter--sage h1, .tj-chapter--sage h2 {
    color: var(--tj-green);
  }

  .tj-chapter--green {
    background: var(--tj-green);
    color: var(--tj-white);
  }

  .tj-chapter--green h1, .tj-chapter--green h2, .tj-chapter--green h3 {
    color: var(--tj-white);
  }

  .tj-chapter--deep {
    background: var(--tj-green-dark);
    color: var(--tj-white);
  }

  .tj-chapter--deep h1, .tj-chapter--deep h2, .tj-chapter--deep h3 {
    color: var(--tj-white);
  }

  .tj-chapter--gold {
    background: var(--tj-gold-light);
    color: var(--tj-text);
  }

  .tj-chapter--gold h1, .tj-chapter--gold h2 {
    color: var(--tj-green);
  }

  /* ============================
     CHAPTER MARKER
     ============================ */

  .tj-chapter-marker {
    font-family: var(--tj-font-heading);
    font-size: var(--tj-text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--tj-gold);
    margin-bottom: var(--tj-space-6);
    display: flex;
    align-items: center;
    gap: var(--tj-space-3);
  }

  .tj-chapter-marker::before {
    content: "";
    width: 32px;
    height: 1px;
    background: var(--tj-gold);
  }

  .tj-chapter--dark .tj-chapter-marker,
  .tj-chapter--slate .tj-chapter-marker,
  .tj-chapter--green .tj-chapter-marker,
  .tj-chapter--deep .tj-chapter-marker {
    color: var(--tj-gold);
  }

  /* ============================
     CHAPTER TITLE
     ============================ */

  .tj-chapter-title {
    font-size: var(--tj-text-hero);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -0.04em;
    margin-bottom: var(--tj-space-6);
  }

  .tj-chapter-title--gold {
    color: var(--tj-gold);
  }

  /* ============================
     STANDARD SECTIONS (inner pages)
     ============================ */

  .tj-section {
    padding: var(--tj-space-12) 0;
  }

  .tj-section--cream { background: var(--tj-cream); }
  .tj-section--white { background: var(--tj-white); }
  .tj-section--sage { background: var(--tj-sage-light); }
  .tj-section--peach { background: var(--tj-peach-light); }
  .tj-section--gold { background: var(--tj-gold-light); }

  .tj-section--green {
    background: var(--tj-green);
    color: var(--tj-white);
  }
  .tj-section--green h2, .tj-section--green h3, .tj-section--green h4 {
    color: var(--tj-white);
  }

  .tj-section--dark {
    background: var(--tj-charcoal);
    color: var(--tj-white);
  }
  .tj-section--dark h2, .tj-section--dark h3 {
    color: var(--tj-white);
  }

  .tj-section--deep {
    background: var(--tj-green-dark);
    color: var(--tj-white);
  }
  .tj-section--deep h2, .tj-section--deep h3 {
    color: var(--tj-white);
  }

  /* ============================
     SECTION HEADER
     ============================ */

  .tj-section-header {
    margin-bottom: var(--tj-space-7);
  }

  .tj-kicker {
    display: inline-flex;
    align-items: center;
    gap: var(--tj-space-3);
    font-family: var(--tj-font-heading);
    font-size: var(--tj-text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--tj-gold);
    margin-bottom: var(--tj-space-4);
  }

  .tj-kicker::before {
    content: "";
    width: 24px;
    height: 1px;
    background: currentColor;
  }

  .tj-section-header h2 {
    font-size: var(--tj-text-4xl);
    font-weight: 800;
    color: var(--tj-green);
    margin-bottom: var(--tj-space-3);
  }

  .tj-section--green .tj-section-header h2,
  .tj-section--dark .tj-section-header h2,
  .tj-section--deep .tj-section-header h2 {
    color: var(--tj-white);
  }

  .tj-section-header p {
    font-size: var(--tj-text-md);
    color: var(--tj-text-secondary);
    max-width: 540px;
    line-height: 1.8;
  }

  .tj-section--green .tj-section-header p {
    color: var(--tj-sage);
  }

  /* ============================
     DIVIDER
     ============================ */

  .tj-divider {
    width: 40px;
    height: 2px;
    background: var(--tj-gold);
    margin: var(--tj-space-4) 0;
  }

  .tj-divider--center {
    margin-left: auto;
    margin-right: auto;
  }

  /* ============================
     WORD-BY-WORD TEXT REVEAL
     ============================ */

  .tj-word {
    display: inline-block;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.4s var(--tj-ease-cinematic),
                transform 0.4s var(--tj-ease-cinematic);
  }

