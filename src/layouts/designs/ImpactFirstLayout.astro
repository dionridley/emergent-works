---
/**
 * Impact First — Layout
 * Data-driven, tech-forward, institutional credibility design.
 * Aesthetic: Premium institutional report meets modern tech company.
 * Think: McKinsey impact report designed by Stripe's design team.
 */

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Emergent Works empowers system-impacted individuals through technology, creativity, and community." } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Emergent Works</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="if-page">
      <slot />
    </div>

    <script>
      // Sticky header scroll behavior
      const header = document.querySelector('[data-if-header]');
      if (header) {
        let lastScroll = 0;
        const onScroll = () => {
          const scrollY = window.scrollY;
          if (scrollY > 48) {
            header.classList.add('if-header--solid');
          } else {
            header.classList.remove('if-header--solid');
          }
          lastScroll = scrollY;
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      }

      // Reveal-on-scroll for sections
      const revealEls = document.querySelectorAll('[data-reveal]');
      if (revealEls.length > 0) {
        const revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('if-revealed');
                revealObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
        );
        revealEls.forEach((el) => revealObserver.observe(el));
      }
    </script>

    <style is:global>
      /* ============================================
         IMPACT FIRST — DESIGN SYSTEM
         ============================================ */

      :root {
        /* Brand Colors */
        --if-green: #20493C;
        --if-green-dark: #052812;
        --if-green-medium: #24582A;
        --if-green-muted: #445E4D;
        --if-sage: #B1D3BB;
        --if-gold: #FFCB70;
        --if-gold-light: #FFE4A8;
        --if-cream: #FFF8ED;
        --if-peach: #F9C5B4;
        --if-text: #242424;
        --if-text-secondary: #5f6360;
        --if-text-light: #8a8d8b;
        --if-white: #FFFFFF;
        --if-border: #E2E5E3;
        --if-border-light: #F0F2F1;

        /* Typography */
        --if-font-heading: 'Outfit', system-ui, sans-serif;
        --if-font-body: 'Plus Jakarta Sans', system-ui, sans-serif;

        /* Spacing (8px grid) */
        --if-space-1: 0.25rem;   /* 4px */
        --if-space-2: 0.5rem;    /* 8px */
        --if-space-3: 0.75rem;   /* 12px */
        --if-space-4: 1rem;      /* 16px */
        --if-space-5: 1.5rem;    /* 24px */
        --if-space-6: 2rem;      /* 32px */
        --if-space-7: 2.5rem;    /* 40px */
        --if-space-8: 3rem;      /* 48px */
        --if-space-9: 4rem;      /* 64px */
        --if-space-10: 5rem;     /* 80px */
        --if-space-11: 6rem;     /* 96px */
        --if-space-12: 8rem;     /* 128px */

        /* Layout */
        --if-max-width: 1200px;
        --if-max-width-narrow: 800px;
        --if-gutter: clamp(1.25rem, 4vw, 3rem);
        --if-header-height: 72px;

        /* Transitions */
        --if-ease: cubic-bezier(0.25, 0.46, 0.45, 0.94);
        --if-ease-out: cubic-bezier(0.16, 1, 0.3, 1);
        --if-duration: 0.3s;
        --if-duration-slow: 0.6s;

        /* Shadows */
        --if-shadow-sm: 0 1px 2px rgba(32, 73, 60, 0.04);
        --if-shadow-md: 0 2px 8px rgba(32, 73, 60, 0.06), 0 1px 2px rgba(32, 73, 60, 0.04);
        --if-shadow-lg: 0 8px 24px rgba(32, 73, 60, 0.08), 0 2px 8px rgba(32, 73, 60, 0.04);
        --if-shadow-xl: 0 16px 48px rgba(32, 73, 60, 0.1), 0 4px 12px rgba(32, 73, 60, 0.06);

        /* Radii */
        --if-radius-sm: 6px;
        --if-radius-md: 10px;
        --if-radius-lg: 16px;
        --if-radius-xl: 24px;
      }

      /* ============================================
         RESET & BASE
         ============================================ */

      *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
      }

      body {
        font-family: var(--if-font-body);
        font-size: 1rem;
        font-weight: 400;
        line-height: 1.65;
        color: var(--if-text);
        background-color: var(--if-cream);
        overflow-x: hidden;
      }

      img {
        max-width: 100%;
        height: auto;
        display: block;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button {
        font-family: inherit;
        cursor: pointer;
        border: none;
        background: none;
      }

      /* ============================================
         TYPOGRAPHY SCALE
         ============================================ */

      .if-page h1, .if-page h2, .if-page h3,
      .if-page h4, .if-page h5, .if-page h6 {
        font-family: var(--if-font-heading);
        line-height: 1.15;
        color: var(--if-text);
        letter-spacing: -0.02em;
      }

      .if-page h1 {
        font-size: clamp(2.5rem, 6vw, 4.25rem);
        font-weight: 700;
      }

      .if-page h2 {
        font-size: clamp(1.75rem, 4vw, 2.75rem);
        font-weight: 700;
      }

      .if-page h3 {
        font-size: clamp(1.25rem, 2.5vw, 1.625rem);
        font-weight: 600;
      }

      .if-page h4 {
        font-size: 1.125rem;
        font-weight: 600;
      }

      .if-page p {
        max-width: 68ch;
      }

      /* ============================================
         LAYOUT UTILITIES
         ============================================ */

      .if-container {
        width: 100%;
        max-width: var(--if-max-width);
        margin-left: auto;
        margin-right: auto;
        padding-left: var(--if-gutter);
        padding-right: var(--if-gutter);
      }

      .if-container--narrow {
        max-width: var(--if-max-width-narrow);
      }

      .if-section {
        padding-top: var(--if-space-11);
        padding-bottom: var(--if-space-11);
      }

      .if-section--compact {
        padding-top: var(--if-space-9);
        padding-bottom: var(--if-space-9);
      }

      .if-section--green {
        background-color: var(--if-green);
        color: var(--if-white);
      }

      .if-section--green h2,
      .if-section--green h3,
      .if-section--green h4 {
        color: var(--if-white);
      }

      .if-section--green p {
        color: var(--if-sage);
      }

      .if-section--dark {
        background-color: var(--if-green-dark);
        color: var(--if-white);
      }

      .if-section--dark h2,
      .if-section--dark h3,
      .if-section--dark h4 {
        color: var(--if-white);
      }

      .if-section--white {
        background-color: var(--if-white);
      }

      /* ============================================
         COMPONENT PRIMITIVES
         ============================================ */

      /* Section eyebrow label */
      .if-eyebrow {
        font-family: var(--if-font-body);
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--if-gold);
        display: flex;
        align-items: center;
        gap: 0.625rem;
        margin-bottom: var(--if-space-4);
      }

      .if-eyebrow::before {
        content: '';
        display: block;
        width: 24px;
        height: 2px;
        background-color: var(--if-gold);
        flex-shrink: 0;
      }

      /* Green-on-green variant */
      .if-section--green .if-eyebrow,
      .if-section--dark .if-eyebrow {
        color: var(--if-gold);
      }

      .if-section--green .if-eyebrow::before,
      .if-section--dark .if-eyebrow::before {
        background-color: var(--if-gold);
      }

      /* Primary CTA */
      .if-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--if-font-body);
        font-size: 0.9375rem;
        font-weight: 600;
        padding: 0.8125rem 1.75rem;
        border-radius: var(--if-radius-sm);
        transition: all var(--if-duration) var(--if-ease);
        white-space: nowrap;
      }

      .if-btn--primary {
        background-color: var(--if-green);
        color: var(--if-white);
      }

      .if-btn--primary:hover {
        background-color: var(--if-green-dark);
        transform: translateY(-1px);
        box-shadow: var(--if-shadow-md);
      }

      .if-btn--gold {
        background-color: var(--if-gold);
        color: var(--if-green-dark);
      }

      .if-btn--gold:hover {
        background-color: var(--if-gold-light);
        transform: translateY(-1px);
        box-shadow: var(--if-shadow-md);
      }

      .if-btn--outline {
        background-color: transparent;
        color: var(--if-green);
        border: 1.5px solid var(--if-green);
      }

      .if-btn--outline:hover {
        background-color: var(--if-green);
        color: var(--if-white);
      }

      .if-btn--outline-white {
        background-color: transparent;
        color: var(--if-white);
        border: 1.5px solid rgba(255, 255, 255, 0.4);
      }

      .if-btn--outline-white:hover {
        background-color: var(--if-white);
        color: var(--if-green);
      }

      .if-btn--sm {
        font-size: 0.8125rem;
        padding: 0.5625rem 1.25rem;
      }

      .if-btn-arrow {
        transition: transform var(--if-duration) var(--if-ease);
      }

      .if-btn:hover .if-btn-arrow {
        transform: translateX(3px);
      }

      /* Card base */
      .if-card {
        background: var(--if-white);
        border-radius: var(--if-radius-md);
        padding: var(--if-space-6);
        box-shadow: var(--if-shadow-sm);
        border: 1px solid var(--if-border-light);
        transition: transform var(--if-duration) var(--if-ease),
                    box-shadow var(--if-duration) var(--if-ease);
      }

      .if-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--if-shadow-md);
      }

      /* Divider */
      .if-divider {
        width: 100%;
        height: 1px;
        background: var(--if-border);
        margin: var(--if-space-8) 0;
      }

      /* ============================================
         REVEAL ANIMATIONS
         ============================================ */

      [data-reveal] {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.7s var(--if-ease-out),
                    transform 0.7s var(--if-ease-out);
      }

      [data-reveal].if-revealed {
        opacity: 1;
        transform: translateY(0);
      }

      [data-reveal="delay-1"] { transition-delay: 0.1s; }
      [data-reveal="delay-2"] { transition-delay: 0.2s; }
      [data-reveal="delay-3"] { transition-delay: 0.3s; }
      [data-reveal="delay-4"] { transition-delay: 0.4s; }

      /* ============================================
         HEADER
         ============================================ */

      .if-header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        height: var(--if-header-height);
        display: flex;
        align-items: center;
        transition: background-color var(--if-duration) var(--if-ease),
                    box-shadow var(--if-duration) var(--if-ease),
                    backdrop-filter var(--if-duration) var(--if-ease);
      }

      .if-header--solid {
        background-color: rgba(255, 248, 237, 0.92);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        box-shadow: 0 1px 0 rgba(32, 73, 60, 0.06);
      }

      .if-header__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        max-width: var(--if-max-width);
        margin: 0 auto;
        padding: 0 var(--if-gutter);
      }

      .if-header__logo {
        display: flex;
        align-items: center;
        gap: 0.625rem;
        font-family: var(--if-font-heading);
        font-weight: 700;
        font-size: 1.125rem;
        color: var(--if-green);
        text-decoration: none;
      }

      .if-header__logo img {
        height: 32px;
        width: auto;
      }

      .if-header__nav {
        display: flex;
        align-items: center;
        gap: var(--if-space-6);
      }

      .if-header__link {
        font-family: var(--if-font-body);
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--if-text-secondary);
        text-decoration: none;
        padding: 0.25rem 0;
        position: relative;
        transition: color var(--if-duration) var(--if-ease);
      }

      .if-header__link:hover,
      .if-header__link--active {
        color: var(--if-green);
      }

      .if-header__link::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 0;
        height: 2px;
        background-color: var(--if-gold);
        transition: width var(--if-duration) var(--if-ease);
      }

      .if-header__link:hover::after,
      .if-header__link--active::after {
        width: 100%;
      }

      .if-header__cta {
        margin-left: var(--if-space-2);
      }

      /* Mobile nav toggle */
      .if-header__toggle {
        display: none;
        width: 40px;
        height: 40px;
        align-items: center;
        justify-content: center;
        background: none;
        border: none;
        cursor: pointer;
      }

      .if-header__toggle-icon {
        display: flex;
        flex-direction: column;
        gap: 5px;
        width: 22px;
      }

      .if-header__toggle-icon span {
        display: block;
        height: 2px;
        background: var(--if-green);
        border-radius: 1px;
        transition: all var(--if-duration) var(--if-ease);
      }

      /* Mobile nav overlay */
      .if-mobile-nav {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 99;
        background: rgba(255, 248, 237, 0.98);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: var(--if-space-6);
        opacity: 0;
        visibility: hidden;
        transition: opacity var(--if-duration) var(--if-ease),
                    visibility var(--if-duration) var(--if-ease);
      }

      .if-mobile-nav--open {
        opacity: 1;
        visibility: visible;
      }

      .if-mobile-nav a {
        font-family: var(--if-font-heading);
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--if-green);
        text-decoration: none;
        padding: 0.5rem 1rem;
      }

      @media (max-width: 768px) {
        .if-header__nav {
          display: none;
        }

        .if-header__toggle {
          display: flex;
        }

        .if-mobile-nav {
          display: flex;
        }
      }

      /* ============================================
         FOOTER
         ============================================ */

      .if-footer {
        background-color: var(--if-green-dark);
        color: var(--if-sage);
        padding: var(--if-space-10) 0 var(--if-space-8);
      }

      .if-footer__grid {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: var(--if-space-8);
        max-width: var(--if-max-width);
        margin: 0 auto;
        padding: 0 var(--if-gutter);
      }

      .if-footer__brand p {
        font-size: 0.9375rem;
        line-height: 1.7;
        max-width: 320px;
        margin-top: var(--if-space-4);
        color: var(--if-sage);
      }

      .if-footer__logo {
        font-family: var(--if-font-heading);
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--if-white);
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .if-footer__logo img {
        height: 28px;
        width: auto;
        filter: brightness(0) invert(1);
      }

      .if-footer__heading {
        font-family: var(--if-font-body);
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--if-gold);
        margin-bottom: var(--if-space-5);
      }

      .if-footer__links {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: var(--if-space-3);
      }

      .if-footer__links a {
        font-size: 0.875rem;
        color: var(--if-sage);
        transition: color var(--if-duration) var(--if-ease);
      }

      .if-footer__links a:hover {
        color: var(--if-white);
      }

      .if-footer__bottom {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: var(--if-max-width);
        margin: var(--if-space-8) auto 0;
        padding: var(--if-space-6) var(--if-gutter) 0;
        border-top: 1px solid rgba(177, 211, 187, 0.15);
        flex-wrap: wrap;
        gap: var(--if-space-4);
      }

      .if-footer__copy {
        font-size: 0.8125rem;
        color: var(--if-text-light);
      }

      .if-footer__social {
        display: flex;
        gap: var(--if-space-4);
      }

      .if-footer__social a {
        font-size: 0.8125rem;
        color: var(--if-sage);
        transition: color var(--if-duration) var(--if-ease);
      }

      .if-footer__social a:hover {
        color: var(--if-gold);
      }

      @media (max-width: 768px) {
        .if-footer__grid {
          grid-template-columns: 1fr 1fr;
          gap: var(--if-space-6);
        }

        .if-footer__brand {
          grid-column: 1 / -1;
        }

        .if-footer__bottom {
          flex-direction: column;
          align-items: flex-start;
        }
      }

      @media (max-width: 480px) {
        .if-footer__grid {
          grid-template-columns: 1fr;
        }
      }

      /* ============================================
         RESPONSIVE ADJUSTMENTS
         ============================================ */

      @media (max-width: 768px) {
        .if-section {
          padding-top: var(--if-space-9);
          padding-bottom: var(--if-space-9);
        }
      }
    </style>
  </body>
</html>
