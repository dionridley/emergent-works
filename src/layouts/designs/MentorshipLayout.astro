---
/**
 * Mentorship — Layout
 * Warm, personal, relationship-focused design.
 * Split-screen pairs, circular portraits with gold rings, soft rounded corners.
 *
 * CSS namespace: --mn-
 * Typography: Outfit (headings), Plus Jakarta Sans (body) — no deviations
 */

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Emergent Works — combating mass incarceration through tech education" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Emergent Works</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400;1,500&display=swap" rel="stylesheet" />
</head>
<body>
  <slot />

  <script>
    // Gentle scroll reveals
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("mn-visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
    );

    document.querySelectorAll("[data-reveal]").forEach((el) => observer.observe(el));

    // Split-screen reveals — left/right sides animate toward center
    const splitObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("mn-split-visible");
            splitObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );

    document.querySelectorAll("[data-split-reveal]").forEach((el) => splitObserver.observe(el));

    // Header scroll state
    const header = document.querySelector(".mn-header") as HTMLElement;
    if (header) {
      let ticking = false;
      window.addEventListener("scroll", () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            header.classList.toggle("mn-header--scrolled", window.scrollY > 40);
            ticking = false;
          });
          ticking = true;
        }
      });
    }
  </script>
</body>
</html>

<style is:global>
  /* ============================
     MENTORSHIP — DESIGN SYSTEM
     CSS Namespace: --mn-
     Warm, Personal, Connection-Focused
     ============================ */

  :root {
    /* Brand Colors */
    --mn-green: #20493C;
    --mn-green-dark: #052812;
    --mn-gold: #FFCB70;
    --mn-cream: #FFF8ED;
    --mn-sage: #B1D3BB;
    --mn-peach: #F9C5B4;
    --mn-white: #ffffff;
    --mn-text: #242424;
    --mn-text-secondary: #5f6360;
    --mn-text-light: #8a8e8b;
    --mn-border: #e8e2d8;

    /* Warm tints */
    --mn-peach-light: #fde8df;
    --mn-sage-light: #e8f2eb;
    --mn-gold-light: #fff3d6;
    --mn-cream-warm: #fef6e8;

    /* Typography */
    --mn-font-heading: "Outfit", sans-serif;
    --mn-font-body: "Plus Jakarta Sans", sans-serif;

    /* Type Scale */
    --mn-text-xs: 0.6875rem;
    --mn-text-sm: 0.8125rem;
    --mn-text-base: 0.9375rem;
    --mn-text-md: 1.0625rem;
    --mn-text-lg: 1.25rem;
    --mn-text-xl: 1.5rem;
    --mn-text-2xl: 2rem;
    --mn-text-3xl: clamp(2rem, 4vw, 2.75rem);
    --mn-text-4xl: clamp(2.5rem, 5vw, 3.75rem);
    --mn-text-5xl: clamp(3rem, 7vw, 5rem);

    /* Spacing */
    --mn-space-1: 0.25rem;
    --mn-space-2: 0.5rem;
    --mn-space-3: 0.75rem;
    --mn-space-4: 1rem;
    --mn-space-5: 1.5rem;
    --mn-space-6: 2rem;
    --mn-space-7: 2.5rem;
    --mn-space-8: 3rem;
    --mn-space-9: 4rem;
    --mn-space-10: 5rem;
    --mn-space-12: 6rem;
    --mn-space-16: 8rem;

    /* Layout */
    --mn-container: 1120px;
    --mn-header-height: 72px;
    --mn-radius: 16px;
    --mn-radius-sm: 12px;
    --mn-radius-lg: 24px;

    /* Shadows — soft, warm */
    --mn-shadow-sm: 0 2px 8px rgba(32,73,60,0.04);
    --mn-shadow: 0 4px 16px rgba(32,73,60,0.06);
    --mn-shadow-md: 0 8px 32px rgba(32,73,60,0.08);
    --mn-shadow-lg: 0 16px 48px rgba(32,73,60,0.1);

    /* Motion */
    --mn-duration: 0.35s;
    --mn-duration-slow: 0.6s;
    --mn-ease: cubic-bezier(0.25, 0.46, 0.45, 0.94);
    --mn-ease-gentle: cubic-bezier(0.4, 0, 0.2, 1);
    --mn-ease-bounce: cubic-bezier(0.34, 1.3, 0.64, 1);
  }

  /* ============================
     RESET
     ============================ */

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    font-family: var(--mn-font-body);
    font-size: var(--mn-text-base);
    line-height: 1.65;
    color: var(--mn-text);
    background: var(--mn-cream);
    overflow-x: hidden;
  }

  img { max-width: 100%; height: auto; display: block; }
  a { text-decoration: none; color: inherit; }

  h1, h2, h3, h4, h5, h6 {
    font-family: var(--mn-font-heading);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--mn-green);
  }

  p { line-height: 1.75; }

  /* ============================
     CONTAINER
     ============================ */

  .mn-container {
    width: 100%;
    max-width: var(--mn-container);
    margin: 0 auto;
    padding: 0 var(--mn-space-5);
  }

  /* ============================
     HEADER
     ============================ */

  .mn-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--mn-header-height);
    display: flex;
    align-items: center;
    transition: background var(--mn-duration-slow) var(--mn-ease),
                box-shadow var(--mn-duration-slow) var(--mn-ease);
  }

  .mn-header--scrolled {
    background: rgba(255,248,237,0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: var(--mn-shadow-sm);
  }

  .mn-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: var(--mn-container);
    margin: 0 auto;
    padding: 0 var(--mn-space-5);
  }

  .mn-header__logo {
    display: flex;
    align-items: center;
    gap: var(--mn-space-3);
    font-family: var(--mn-font-heading);
    font-weight: 700;
    font-size: var(--mn-text-md);
    color: var(--mn-green);
  }

  .mn-header__logo img {
    height: 34px;
    width: auto;
  }

  .mn-header__nav {
    display: flex;
    align-items: center;
    gap: var(--mn-space-5);
    list-style: none;
  }

  .mn-header__nav a {
    font-family: var(--mn-font-body);
    font-size: var(--mn-text-sm);
    font-weight: 600;
    color: var(--mn-text-secondary);
    transition: color var(--mn-duration);
    border-radius: 999px;
    padding: 0.3rem 0.75rem;
  }

  .mn-header__nav a:hover {
    color: var(--mn-green);
  }

  .mn-header__nav a.mn-active {
    color: var(--mn-green);
    background: var(--mn-sage-light);
  }

  /* ============================
     SECTIONS
     ============================ */

  .mn-section {
    padding: var(--mn-space-12) 0;
  }

  .mn-section--cream { background: var(--mn-cream); }
  .mn-section--white { background: var(--mn-white); }
  .mn-section--peach { background: var(--mn-peach-light); }
  .mn-section--sage { background: var(--mn-sage-light); }
  .mn-section--gold { background: var(--mn-gold-light); }
  .mn-section--green {
    background: var(--mn-green);
    color: var(--mn-white);
  }
  .mn-section--green h2, .mn-section--green h3, .mn-section--green h4 {
    color: var(--mn-white);
  }
  .mn-section--dark {
    background: var(--mn-green-dark);
    color: var(--mn-white);
  }
  .mn-section--dark h2, .mn-section--dark h3 {
    color: var(--mn-white);
  }

  /* ============================
     SECTION HEADER
     ============================ */

  .mn-section-header {
    margin-bottom: var(--mn-space-7);
  }

  .mn-kicker {
    display: inline-flex;
    align-items: center;
    gap: var(--mn-space-2);
    font-family: var(--mn-font-heading);
    font-size: var(--mn-text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--mn-gold);
    margin-bottom: var(--mn-space-3);
    background: rgba(255,203,112,0.15);
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
  }

  .mn-section--green .mn-kicker {
    background: rgba(255,203,112,0.2);
  }

  .mn-section-header h2 {
    font-size: var(--mn-text-4xl);
    font-weight: 800;
    margin-bottom: var(--mn-space-3);
  }

  .mn-section-header p {
    font-size: var(--mn-text-md);
    color: var(--mn-text-secondary);
    max-width: 520px;
    line-height: 1.75;
  }

  /* ============================
     SPLIT SCREEN
     ============================ */

  .mn-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 400px;
    border-radius: var(--mn-radius-lg);
    overflow: hidden;
    box-shadow: var(--mn-shadow-md);
  }

  .mn-split__side {
    padding: var(--mn-space-9) var(--mn-space-7);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .mn-split__side--mentor {
    background: var(--mn-green);
    color: var(--mn-white);
  }

  .mn-split__side--mentor h3,
  .mn-split__side--mentor h4 {
    color: var(--mn-white);
  }

  .mn-split__side--mentee {
    background: var(--mn-cream-warm);
  }

  .mn-split__side--peach {
    background: var(--mn-peach-light);
  }

  .mn-split__side--gold {
    background: var(--mn-gold-light);
  }

  /* Split reveal animation */
  [data-split-reveal] .mn-split__side:first-child {
    opacity: 0;
    transform: translateX(-30px);
    transition: opacity var(--mn-duration-slow) var(--mn-ease-gentle),
                transform var(--mn-duration-slow) var(--mn-ease-gentle);
  }

  [data-split-reveal] .mn-split__side:last-child {
    opacity: 0;
    transform: translateX(30px);
    transition: opacity var(--mn-duration-slow) var(--mn-ease-gentle) 0.15s,
                transform var(--mn-duration-slow) var(--mn-ease-gentle) 0.15s;
  }

  [data-split-reveal].mn-split-visible .mn-split__side {
    opacity: 1;
    transform: translateX(0);
  }

  /* ============================
     CIRCULAR PORTRAIT — Signature motif
     ============================ */

  .mn-portrait {
    border-radius: 50%;
    border: 3px solid var(--mn-gold);
    object-fit: cover;
    box-shadow: var(--mn-shadow);
    transition: transform var(--mn-duration) var(--mn-ease-bounce),
                box-shadow var(--mn-duration) var(--mn-ease);
  }

  .mn-portrait:hover {
    transform: scale(1.03);
    box-shadow: var(--mn-shadow-md);
  }

  .mn-portrait--sm { width: 56px; height: 56px; }
  .mn-portrait--md { width: 80px; height: 80px; }
  .mn-portrait--lg { width: 120px; height: 120px; }
  .mn-portrait--xl { width: 160px; height: 160px; }

  .mn-portrait--peach-ring {
    border-color: var(--mn-peach);
  }

  .mn-portrait--sage-ring {
    border-color: var(--mn-sage);
  }

  /* ============================
     WARM CARD
     ============================ */

  .mn-card {
    background: var(--mn-white);
    border-radius: var(--mn-radius);
    padding: var(--mn-space-6);
    box-shadow: var(--mn-shadow);
    transition: transform var(--mn-duration) var(--mn-ease-bounce),
                box-shadow var(--mn-duration) var(--mn-ease);
  }

  .mn-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--mn-shadow-md);
  }

  .mn-card--cream { background: var(--mn-cream-warm); box-shadow: none; }
  .mn-card--peach { background: var(--mn-peach-light); box-shadow: none; }
  .mn-card--sage { background: var(--mn-sage-light); box-shadow: none; }
  .mn-card--gold { background: var(--mn-gold-light); box-shadow: none; }

  .mn-card--green {
    background: var(--mn-green);
    color: var(--mn-white);
  }

  .mn-card--green h3, .mn-card--green h4 {
    color: var(--mn-white);
  }

  .mn-card--static:hover {
    transform: none;
    box-shadow: var(--mn-shadow);
  }

  /* ============================
     PAIR QUOTE — Two people, side by side
     ============================ */

  .mn-pair-quote {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--mn-space-6);
  }

  .mn-pair-quote__side {
    padding: var(--mn-space-6);
    border-radius: var(--mn-radius);
    text-align: center;
  }

  .mn-pair-quote__side--mentor {
    background: var(--mn-sage-light);
  }

  .mn-pair-quote__side--mentee {
    background: var(--mn-peach-light);
  }

  .mn-pair-quote__text {
    font-size: var(--mn-text-md);
    font-weight: 500;
    line-height: 1.7;
    margin: var(--mn-space-4) 0;
    font-style: italic;
  }

  .mn-pair-quote__name {
    font-family: var(--mn-font-heading);
    font-size: var(--mn-text-sm);
    font-weight: 700;
    color: var(--mn-green);
  }

  .mn-pair-quote__role {
    font-size: var(--mn-text-xs);
    color: var(--mn-text-light);
  }

  /* ============================
     JOURNEY STEPS
     ============================ */

  .mn-steps {
    display: flex;
    gap: var(--mn-space-5);
    counter-reset: step-counter;
  }

  .mn-step {
    flex: 1;
    text-align: center;
    position: relative;
    counter-increment: step-counter;
  }

  .mn-step__circle {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--mn-gold);
    color: var(--mn-green-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--mn-font-heading);
    font-size: var(--mn-text-xl);
    font-weight: 800;
    margin: 0 auto var(--mn-space-4);
    box-shadow: var(--mn-shadow);
    transition: transform var(--mn-duration) var(--mn-ease-bounce);
  }

  .mn-step:hover .mn-step__circle {
    transform: scale(1.1);
  }

  .mn-step__title {
    font-family: var(--mn-font-heading);
    font-size: var(--mn-text-base);
    font-weight: 700;
    color: var(--mn-green);
    margin-bottom: var(--mn-space-2);
  }

  .mn-step__desc {
    font-size: var(--mn-text-sm);
    color: var(--mn-text-secondary);
    line-height: 1.6;
  }

  /* Connector line between steps */
  .mn-step:not(:last-child)::after {
    content: "";
    position: absolute;
    top: 32px;
    left: calc(50% + 40px);
    width: calc(100% - 80px);
    height: 2px;
    background: linear-gradient(to right, var(--mn-gold), var(--mn-peach));
  }

  /* ============================
     BUTTONS
     ============================ */

  .mn-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--mn-space-2);
    font-family: var(--mn-font-heading);
    font-size: var(--mn-text-sm);
    font-weight: 700;
    padding: 0.75rem 1.75rem;
    border-radius: 999px;
    border: 2px solid transparent;
    transition: all var(--mn-duration) var(--mn-ease);
    cursor: pointer;
  }

  .mn-btn--primary {
    background: var(--mn-green);
    color: var(--mn-white);
    border-color: var(--mn-green);
  }

  .mn-btn--primary:hover {
    background: var(--mn-green-dark);
    border-color: var(--mn-green-dark);
    transform: translateY(-2px);
    box-shadow: var(--mn-shadow-md);
  }

  .mn-btn--gold {
    background: var(--mn-gold);
    color: var(--mn-green-dark);
    border-color: var(--mn-gold);
  }

  .mn-btn--gold:hover {
    background: #ffd68a;
    transform: translateY(-2px);
    box-shadow: var(--mn-shadow-md);
  }

  .mn-btn--outline {
    background: transparent;
    color: var(--mn-green);
    border-color: var(--mn-green);
  }

  .mn-btn--outline:hover {
    background: var(--mn-green);
    color: var(--mn-white);
  }

  .mn-btn--outline-white {
    background: transparent;
    color: var(--mn-white);
    border-color: rgba(255,255,255,0.4);
  }

  .mn-btn--outline-white:hover {
    background: rgba(255,255,255,0.1);
    border-color: var(--mn-white);
  }

  .mn-btn-arrow {
    display: inline-block;
    transition: transform var(--mn-duration) var(--mn-ease-bounce);
  }

  .mn-btn:hover .mn-btn-arrow {
    transform: translateX(4px);
  }

  /* ============================
     DUAL CTA — Two CTAs side by side
     ============================ */

  .mn-dual-cta {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--mn-space-5);
    border-radius: var(--mn-radius-lg);
    overflow: hidden;
  }

  .mn-dual-cta__side {
    padding: var(--mn-space-9) var(--mn-space-7);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--mn-space-4);
    transition: transform var(--mn-duration) var(--mn-ease);
  }

  .mn-dual-cta__side:hover {
    transform: scale(1.01);
  }

  .mn-dual-cta__side--mentor {
    background: var(--mn-green);
    color: var(--mn-white);
    border-radius: var(--mn-radius-lg) 0 0 var(--mn-radius-lg);
  }

  .mn-dual-cta__side--mentor h3 {
    color: var(--mn-white);
  }

  .mn-dual-cta__side--mentee {
    background: var(--mn-peach-light);
    border-radius: 0 var(--mn-radius-lg) var(--mn-radius-lg) 0;
  }

  /* ============================
     GRID
     ============================ */

  .mn-grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--mn-space-6);
  }

  .mn-grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--mn-space-5);
  }

  .mn-grid-4 {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--mn-space-5);
  }

  /* ============================
     DIVIDER
     ============================ */

  .mn-divider {
    width: 48px;
    height: 3px;
    background: var(--mn-gold);
    border-radius: 2px;
    margin: var(--mn-space-4) 0;
  }

  .mn-divider--center {
    margin-left: auto;
    margin-right: auto;
  }

  /* ============================
     FOOTER
     ============================ */

  .mn-footer {
    background: var(--mn-green-dark);
    color: var(--mn-sage);
    padding: var(--mn-space-10) 0 var(--mn-space-6);
    border-radius: var(--mn-radius-lg) var(--mn-radius-lg) 0 0;
  }

  .mn-footer__grid {
    display: grid;
    grid-template-columns: 1.5fr repeat(3, 1fr);
    gap: var(--mn-space-8);
    margin-bottom: var(--mn-space-8);
  }

  .mn-footer__brand h3 {
    font-family: var(--mn-font-heading);
    color: var(--mn-white);
    font-size: var(--mn-text-lg);
    margin-bottom: var(--mn-space-3);
  }

  .mn-footer__brand p {
    font-size: var(--mn-text-sm);
    line-height: 1.7;
    color: var(--mn-sage);
    max-width: 280px;
  }

  .mn-footer__col h4 {
    font-family: var(--mn-font-heading);
    font-size: var(--mn-text-xs);
    font-weight: 700;
    color: var(--mn-gold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--mn-space-4);
  }

  .mn-footer__col ul { list-style: none; }

  .mn-footer__col li { margin-bottom: var(--mn-space-2); }

  .mn-footer__col a {
    font-size: var(--mn-text-sm);
    color: var(--mn-sage);
    transition: color var(--mn-duration);
  }

  .mn-footer__col a:hover { color: var(--mn-white); }

  .mn-footer__bottom {
    padding-top: var(--mn-space-5);
    border-top: 1px solid rgba(177,211,187,0.12);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: var(--mn-text-xs);
    color: rgba(177,211,187,0.4);
    flex-wrap: wrap;
    gap: var(--mn-space-3);
  }

  .mn-footer__social {
    display: flex;
    gap: var(--mn-space-4);
  }

  .mn-footer__social a {
    color: var(--mn-sage);
    font-size: var(--mn-text-sm);
    transition: color var(--mn-duration);
  }

  .mn-footer__social a:hover { color: var(--mn-gold); }

  /* ============================
     SCROLL REVEAL
     ============================ */

  [data-reveal] {
    opacity: 0;
    transform: translateY(20px);
