---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  image: ImageMetadata;
  imageAlt: string;
  kicker?: string;
  title: string;
  subtitle?: string;
  align?: "left" | "center";
}

const { image, imageAlt, kicker, title, subtitle, align = "left" } = Astro.props;
---

<section class:list={["page-hero", `page-hero--${align}`]}>
  <div class="page-hero__bg">
    <Image src={image} alt={imageAlt} layout="full-width" priority />
    <div class="page-hero__overlay"></div>
  </div>
  <div class="st-container page-hero__content">
    <div data-reveal>
      {kicker && <span class="st-chapter page-hero__kicker">{kicker}</span>}
      <h1 class="page-hero__title" set:html={title}></h1>
      {subtitle && <p class="page-hero__sub" set:html={subtitle}></p>}
    </div>
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    min-height: 60vh;
    display: flex;
    align-items: flex-end;
    padding: calc(var(--st-header-height) + var(--st-space-12)) 0 var(--st-space-10);
    overflow: hidden;
  }

  .page-hero--center {
    align-items: center;
    text-align: center;
  }

  .page-hero__bg {
    position: absolute;
    inset: 0;
  }

  .page-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .page-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(5, 40, 18, 0.92) 0%,
      rgba(5, 40, 18, 0.78) 50%,
      rgba(5, 40, 18, 0.6) 100%
    );
  }

  .page-hero__content {
    position: relative;
    z-index: 1;
  }

  .page-hero__kicker {
    color: var(--st-gold);
  }

  .page-hero--center .page-hero__kicker {
    justify-content: center;
  }

  .page-hero__title {
    color: var(--st-white);
    font-size: clamp(3rem, 8vw, 6rem);
    margin-bottom: var(--st-space-5);
  }

  .page-hero__sub {
    font-size: 1.125rem;
    color: var(--st-sage);
    max-width: 560px;
    margin-top: var(--st-space-5);
    line-height: 1.75;
  }

  .page-hero--center .page-hero__sub {
    margin-left: auto;
    margin-right: auto;
  }

  @media (max-width: 768px) {
    .page-hero {
      min-height: 50vh;
      padding-top: calc(var(--st-header-height) + var(--st-space-9));
      padding-bottom: var(--st-space-8);
    }

    .page-hero__title {
      font-size: clamp(2.5rem, 10vw, 4rem);
    }

    .page-hero__sub {
      font-size: 1rem;
    }
  }
</style>
