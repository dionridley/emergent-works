---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const navLinks = [
  { label: "Home", href: "/designs/bold-movement/" },
  { label: "About", href: "/designs/bold-movement/about/" },
  { label: "Programs", href: "/designs/bold-movement/programs/" },
  { label: "Team", href: "/designs/bold-movement/team/" },
  { label: "Get Involved", href: "/designs/bold-movement/get-involved/" },
];

function isActive(href: string): boolean {
  const clean = href.replace(/\/$/, "");
  if (clean === "/designs/bold-movement") return currentPath.replace(/\/$/, "") === clean;
  return currentPath.startsWith(clean);
}
---

<header class="bm-header">
  <div class="bm-header__inner">
    <a href="/designs/bold-movement/" class="bm-header__logo">
      <img src="/images/header-logo.png" alt="Emergent Works" />
      <span>Emergent Works</span>
    </a>
    <nav>
      <ul class="bm-header__nav">
        {navLinks.map((link) => (
          <li>
            <a href={link.href} class:list={[{ "bm-active": isActive(link.href) }]}>
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
