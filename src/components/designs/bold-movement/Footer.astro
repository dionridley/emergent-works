---
import { organization } from "../../../data/organization";
---

<footer class="bm-footer">
  <div class="bm-container">
    <div class="bm-footer__cta" aria-hidden="true">Join the Movement</div>
    <div class="bm-footer__top">
      <div class="bm-footer__brand">
        <h3>Emergent Works</h3>
        <p>{organization.mission}</p>
      </div>
      <div class="bm-footer__links">
        <div class="bm-footer__col">
          <h4>Programs</h4>
          <ul>
            <li><a href="/designs/bold-movement/programs/">All Programs</a></li>
            <li><a href="/designs/bold-movement/programs/trap/">T.RAP</a></li>
            <li><a href="/designs/bold-movement/programs/teck/">TECK</a></li>
          </ul>
        </div>
        <div class="bm-footer__col">
          <h4>Organization</h4>
          <ul>
            <li><a href="/designs/bold-movement/about/">About</a></li>
            <li><a href="/designs/bold-movement/team/">Team</a></li>
            <li><a href="/designs/bold-movement/get-involved/">Get Involved</a></li>
          </ul>
        </div>
        <div class="bm-footer__col">
          <h4>Connect</h4>
          <ul>
            <li><a href={`mailto:${organization.contact.email}`}>{organization.contact.email}</a></li>
            <li><a href={organization.social.instagram} target="_blank" rel="noopener noreferrer">Instagram</a></li>
            <li><a href={organization.social.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a></li>
          </ul>
        </div>
      </div>
    </div>
    <div class="bm-footer__bottom">
      <span>&copy; {new Date().getFullYear()} {organization.name}. {organization.legalName} — EIN: {organization.ein}</span>
      <div class="bm-footer__social">
        <a href={organization.social.instagram} target="_blank" rel="noopener noreferrer">IG</a>
        <a href={organization.social.linkedin} target="_blank" rel="noopener noreferrer">LI</a>
        <a href={organization.social.youtube} target="_blank" rel="noopener noreferrer">YT</a>
      </div>
    </div>
  </div>
</footer>
