---
/**
 * Community Mosaic — Header
 * Compact grid-inspired nav with "Emergent Works" title and Home link.
 */

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const navLinks = [
  { label: "Home", href: "/designs/community-mosaic/" },
  { label: "About", href: "/designs/community-mosaic/about/" },
  { label: "Programs", href: "/designs/community-mosaic/programs/" },
  { label: "Team", href: "/designs/community-mosaic/team/" },
  { label: "Get Involved", href: "/designs/community-mosaic/get-involved/" },
];

function isActive(href: string): boolean {
  const clean = href.replace(/\/$/, "");
  if (clean === "/designs/community-mosaic") return currentPath.replace(/\/$/, "") === clean;
  return currentPath.startsWith(clean);
}
---

<header class="cm-header">
  <div class="cm-header__inner">
    <a href="/designs/community-mosaic/" class="cm-header__logo">
      <img src="/images/header-logo.png" alt="Emergent Works" />
      <span>Emergent Works</span>
    </a>
    <nav>
      <ul class="cm-header__nav">
        {navLinks.map((link) => (
          <li>
            <a href={link.href} class:list={[{ "cm-active": isActive(link.href) }]}>
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
