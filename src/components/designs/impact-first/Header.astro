---
/**
 * Impact First — Header
 * Minimal nav with transparent-to-solid scroll behavior.
 * Logo left, nav center-right, CTA right.
 */

interface Props {
  currentPath?: string;
}

const { currentPath = "" } = Astro.props;

const navLinks = [
  { label: "Home", href: "/designs/impact-first/" },
  { label: "About", href: "/designs/impact-first/about/" },
  { label: "Programs", href: "/designs/impact-first/programs/" },
  { label: "Team", href: "/designs/impact-first/team/" },
  { label: "Get Involved", href: "/designs/impact-first/get-involved/" },
];

function isActive(href: string): boolean {
  const clean = href.replace(/\/$/, "");
  // Exact match for Home, prefix match for others
  if (clean === "/designs/impact-first") {
    return currentPath.replace(/\/$/, "") === clean;
  }
  return currentPath.startsWith(clean);
}
---

<header class="if-header" data-if-header>
  <div class="if-header__inner">
    <a href="/designs/impact-first/" class="if-header__logo">
      <img src="/images/header-logo.png" alt="Emergent Works" />
      <span>Emergent Works</span>
    </a>

    <nav class="if-header__nav">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={["if-header__link", { "if-header__link--active": isActive(link.href) }]}
        >
          {link.label}
        </a>
      ))}
      <a href="/designs/impact-first/get-involved/#donate" class="if-btn if-btn--primary if-btn--sm if-header__cta">
        Donate
      </a>
    </nav>

    <button class="if-header__toggle" aria-label="Open menu" data-if-menu-toggle>
      <span class="if-header__toggle-icon">
        <span></span>
        <span></span>
        <span></span>
      </span>
    </button>
  </div>
</header>

<nav class="if-mobile-nav" data-if-mobile-nav>
  <a href="/designs/impact-first/">Home</a>
  {navLinks.map((link) => (
    <a href={link.href}>{link.label}</a>
  ))}
  <a href="/designs/impact-first/get-involved/#donate" class="if-btn if-btn--gold" style="margin-top: 1rem;">
    Donate
  </a>
</nav>

<script>
  const toggle = document.querySelector('[data-if-menu-toggle]');
  const mobileNav = document.querySelector('[data-if-mobile-nav]');

  if (toggle && mobileNav) {
    toggle.addEventListener('click', () => {
      mobileNav.classList.toggle('if-mobile-nav--open');
      const isOpen = mobileNav.classList.contains('if-mobile-nav--open');
      toggle.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
      document.body.style.overflow = isOpen ? 'hidden' : '';
    });

    mobileNav.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        mobileNav.classList.remove('if-mobile-nav--open');
        document.body.style.overflow = '';
      });
    });
  }
</script>
