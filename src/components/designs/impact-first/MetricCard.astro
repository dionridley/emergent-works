---
/**
 * Impact First — MetricCard
 * Individual metric with large number, label, and context.
 */

interface Props {
  value: string;
  label: string;
  description?: string;
  accent?: boolean;
}

const { value, label, description, accent = false } = Astro.props;
---

<div class:list={["metric-card", { "metric-card--accent": accent }]}>
  <div class="metric-card__value">{value}</div>
  <div class="metric-card__label">{label}</div>
  {description && <p class="metric-card__desc">{description}</p>}
</div>

<style>
  .metric-card {
    background: var(--if-white);
    border-radius: var(--if-radius-md);
    padding: var(--if-space-6);
    border: 1px solid var(--if-border-light);
    text-align: center;
    transition: transform var(--if-duration) var(--if-ease),
                box-shadow var(--if-duration) var(--if-ease);
  }

  .metric-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--if-shadow-md);
  }

  .metric-card--accent {
    background: var(--if-green);
    border-color: transparent;
  }

  .metric-card__value {
    font-family: var(--if-font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--if-green);
    margin-bottom: var(--if-space-2);
  }

  .metric-card--accent .metric-card__value {
    color: var(--if-gold);
  }

  .metric-card__label {
    font-family: var(--if-font-heading);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--if-text);
    margin-bottom: var(--if-space-2);
  }

  .metric-card--accent .metric-card__label {
    color: var(--if-white);
  }

  .metric-card__desc {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--if-text-secondary);
  }

  .metric-card--accent .metric-card__desc {
    color: var(--if-sage);
  }
</style>
