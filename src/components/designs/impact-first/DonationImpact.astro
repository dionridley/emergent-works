---
/**
 * Impact First — DonationImpact
 * Visual breakdown of how donations translate to real outcomes.
 */

import { donationTiers, donationTrust } from "../../../data/donation";
---

<section class="donation-impact if-section" id="donate">
  <div class="if-container">
    <div class="donation-impact__header" data-reveal>
      <span class="if-eyebrow">Support Our Mission</span>
      <h2>Your Investment<br />Creates Real Change</h2>
      <p class="donation-impact__sub">
        Every dollar directly funds programming for system-impacted individuals.
        Here's how your contribution translates to impact.
      </p>
    </div>

    <div class="donation-impact__grid" data-reveal="delay-1">
      {donationTiers.map((tier, i) => (
        <div class="donation-impact__tier" data-reveal={`delay-${i + 1}`}>
          <div class="donation-impact__amount">{tier.label}</div>
          <div class="donation-impact__line" />
          <p class="donation-impact__desc">{tier.impact}</p>
        </div>
      ))}
    </div>

    <div class="donation-impact__cta" data-reveal="delay-3">
      <a href="/designs/impact-first/get-involved/" class="if-btn if-btn--gold">
        Make a Donation
        <span class="if-btn-arrow">&rarr;</span>
      </a>
      <p class="donation-impact__trust">{donationTrust}</p>
    </div>
  </div>
</section>

<style>
  .donation-impact {
    background: var(--if-white);
  }

  .donation-impact__header {
    text-align: center;
    margin-bottom: var(--if-space-9);
  }

  .donation-impact__header h2 {
    color: var(--if-green);
    margin-bottom: var(--if-space-4);
  }

  .donation-impact__header .if-eyebrow {
    justify-content: center;
  }

  .donation-impact__header .if-eyebrow::before {
    display: none;
  }

  .donation-impact__sub {
    font-size: 1.0625rem;
    color: var(--if-text-secondary);
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .donation-impact__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--if-space-5);
    margin-bottom: var(--if-space-9);
  }

  .donation-impact__tier {
    text-align: center;
    padding: var(--if-space-6) var(--if-space-4);
    border-radius: var(--if-radius-md);
    border: 1px solid var(--if-border-light);
    background: var(--if-cream);
    transition: transform var(--if-duration) var(--if-ease),
                box-shadow var(--if-duration) var(--if-ease),
                border-color var(--if-duration) var(--if-ease);
  }

  .donation-impact__tier:hover {
    transform: translateY(-3px);
    box-shadow: var(--if-shadow-lg);
    border-color: var(--if-gold);
  }

  .donation-impact__amount {
    font-family: var(--if-font-heading);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    color: var(--if-green);
    letter-spacing: -0.02em;
  }

  .donation-impact__line {
    width: 32px;
    height: 2px;
    background: var(--if-gold);
    margin: var(--if-space-4) auto;
  }

  .donation-impact__desc {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--if-text-secondary);
  }

  .donation-impact__cta {
    text-align: center;
  }

  .donation-impact__trust {
    font-size: 0.75rem;
    color: var(--if-text-light);
    margin-top: var(--if-space-4);
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (max-width: 768px) {
    .donation-impact__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .donation-impact__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
