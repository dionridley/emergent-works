---
/**
 * Impact First — ImpactHero
 * Hero section with animated statistics as the centerpiece.
 * The data IS the design — numbers are treated as hero elements.
 */
---

<section class="impact-hero">
  <div class="impact-hero__bg">
    <div class="impact-hero__grid-pattern" />
  </div>
  <div class="if-container">
    <div class="impact-hero__content">
      <div class="impact-hero__eyebrow" data-reveal>
        <span class="impact-hero__eyebrow-line" />
        <span>Emergent Works</span>
        <span class="impact-hero__eyebrow-line" />
      </div>
      <h1 class="impact-hero__title" data-reveal="delay-1">
        Rewriting Futures<br />Through Technology
      </h1>
      <p class="impact-hero__subtitle" data-reveal="delay-2">
        We empower system-impacted Black and Brown youth and adults to reclaim
        their futures through technology, creativity, and community.
      </p>
      <div class="impact-hero__actions" data-reveal="delay-3">
        <a href="/designs/impact-first/programs/" class="if-btn if-btn--gold">
          Explore Programs
          <span class="if-btn-arrow">&rarr;</span>
        </a>
        <a href="/designs/impact-first/about/" class="if-btn if-btn--outline-white">
          Our Story
        </a>
      </div>
    </div>

    <div class="impact-hero__stats" data-reveal="delay-3">
      <div class="impact-hero__stat">
        <div class="impact-hero__stat-value" data-count-to="261">0</div>
        <div class="impact-hero__stat-label">Graduates</div>
        <div class="impact-hero__stat-context">system-impacted individuals</div>
      </div>
      <div class="impact-hero__stat-divider" />
      <div class="impact-hero__stat">
        <div class="impact-hero__stat-value" data-count-to="73" data-suffix="%">0%</div>
        <div class="impact-hero__stat-label">Employed</div>
        <div class="impact-hero__stat-context">after program completion</div>
      </div>
      <div class="impact-hero__stat-divider" />
      <div class="impact-hero__stat">
        <div class="impact-hero__stat-value" data-count-to="98" data-prefix="<" data-suffix="%">0%</div>
        <div class="impact-hero__stat-label">No Re-Offense</div>
        <div class="impact-hero__stat-context">post-program recidivism rate</div>
      </div>
    </div>
  </div>

  <div class="impact-hero__scroll-hint" data-reveal="delay-4">
    <span>Scroll to explore</span>
    <svg width="16" height="24" viewBox="0 0 16 24" fill="none">
      <rect x="1" y="1" width="14" height="22" rx="7" stroke="currentColor" stroke-width="1.5"/>
      <circle class="impact-hero__scroll-dot" cx="8" cy="7" r="2" fill="currentColor"/>
    </svg>
  </div>
</section>

<script>
  // Hero counter animation
  function easeOutExpo(t: number): number {
    return t === 1 ? 1 : 1 - Math.pow(2, -10 * t);
  }

  const heroCounters = document.querySelectorAll('[data-count-to]');
  const heroObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const end = parseInt(el.dataset.countTo || '0', 10);
          const prefix = el.dataset.prefix || '';
          const suffix = el.dataset.suffix || '';
          const duration = 2200;
          const startTime = performance.now();

          const step = (currentTime: number) => {
            const elapsed = currentTime - startTime;
            const progress = Math.min(elapsed / duration, 1);
            const current = Math.round(easeOutExpo(progress) * end);
            el.textContent = `${prefix}${current.toLocaleString()}${suffix}`;
            if (progress < 1) requestAnimationFrame(step);
          };

          requestAnimationFrame(step);
          heroObserver.unobserve(el);
        }
      });
    },
    { threshold: 0.3 }
  );
  heroCounters.forEach((el) => heroObserver.observe(el));
</script>

<style>
  .impact-hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--if-green-dark);
    color: var(--if-white);
    overflow: hidden;
    padding: calc(var(--if-header-height) + var(--if-space-9)) 0 var(--if-space-9);
  }

  /* Subtle grid pattern overlay */
  .impact-hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .impact-hero__grid-pattern {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(177, 211, 187, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(177, 211, 187, 0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, black, transparent);
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, black, transparent);
  }

  .impact-hero__content {
    text-align: center;
    position: relative;
    z-index: 1;
    margin-bottom: var(--if-space-10);
  }

  .impact-hero__eyebrow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-family: var(--if-font-body);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--if-gold);
    margin-bottom: var(--if-space-6);
  }

  .impact-hero__eyebrow-line {
    display: block;
    width: 40px;
    height: 1px;
    background: var(--if-gold);
    opacity: 0.5;
  }

  .impact-hero__title {
    font-family: var(--if-font-heading);
    font-size: clamp(2.75rem, 7vw, 5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--if-white);
    margin-bottom: var(--if-space-5);
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .impact-hero__subtitle {
    font-size: clamp(1rem, 1.5vw, 1.1875rem);
    line-height: 1.7;
    color: var(--if-sage);
    max-width: 560px;
    margin: 0 auto var(--if-space-7);
  }

  .impact-hero__actions {
    display: flex;
    gap: var(--if-space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Stats bar at bottom of hero */
  .impact-hero__stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--if-space-8);
    padding: var(--if-space-7) var(--if-space-8);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(177, 211, 187, 0.1);
    border-radius: var(--if-radius-lg);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    max-width: 720px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .impact-hero__stat {
    text-align: center;
    flex: 1;
  }

  .impact-hero__stat-value {
    font-family: var(--if-font-heading);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 800;
    color: var(--if-gold);
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 0.375rem;
  }

  .impact-hero__stat-label {
    font-family: var(--if-font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--if-white);
    margin-bottom: 0.125rem;
  }

  .impact-hero__stat-context {
    font-size: 0.6875rem;
    color: var(--if-sage);
    opacity: 0.7;
  }

  .impact-hero__stat-divider {
    width: 1px;
    height: 48px;
    background: rgba(177, 211, 187, 0.15);
    flex-shrink: 0;
  }

  /* Scroll hint */
  .impact-hero__scroll-hint {
    position: absolute;
    bottom: var(--if-space-6);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: var(--if-sage);
    opacity: 0.5;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .impact-hero__scroll-dot {
    animation: scrollDotBounce 2s ease-in-out infinite;
  }

  @keyframes scrollDotBounce {
    0%, 100% { cy: 7; }
    50% { cy: 15; }
  }

  @media (max-width: 640px) {
    .impact-hero__stats {
      flex-direction: column;
      gap: var(--if-space-5);
      padding: var(--if-space-6);
    }

    .impact-hero__stat-divider {
      width: 60px;
      height: 1px;
    }

    .impact-hero__scroll-hint {
      display: none;
    }
  }
</style>
