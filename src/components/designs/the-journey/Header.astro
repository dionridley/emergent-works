---
interface Props { currentPath: string; }
const { currentPath } = Astro.props;

const navLinks = [
  { label: "Home", href: "/designs/the-journey/" },
  { label: "About", href: "/designs/the-journey/about/" },
  { label: "Programs", href: "/designs/the-journey/programs/" },
  { label: "Team", href: "/designs/the-journey/team/" },
  { label: "Get Involved", href: "/designs/the-journey/get-involved/" },
];

function isActive(href: string): boolean {
  const clean = href.replace(/\/$/, "");
  if (clean === "/designs/the-journey") return currentPath.replace(/\/$/, "") === clean;
  return currentPath.startsWith(clean);
}
---

<header class="tj-header">
  <div class="tj-header__inner">
    <a href="/designs/the-journey/" class="tj-header__logo">
      <img src="/images/header-logo.png" alt="Emergent Works" />
      <span>Emergent Works</span>
    </a>
    <nav>
      <ul class="tj-header__nav">
        {navLinks.map((link) => (
          <li><a href={link.href} class:list={[{ "tj-active": isActive(link.href) }]}>{link.label}</a></li>
        ))}
      </ul>
    </nav>
  </div>
</header>
