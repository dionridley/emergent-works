---
/**
 * Visual indicator for fabricated content (dev reference only).
 * Renders a small badge next to content that is fabricated.
 * Only visible in development or when explicitly toggled.
 */

interface Props {
  label?: string;
}

const { label = "Fabricated" } = Astro.props;
---

<span class="fabricated-badge" data-fabricated="true" title="This content is fabricated for design purposes and needs real replacement">
  {label}
</span>

<style>
  .fabricated-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.125rem 0.5rem;
    border-radius: 4px;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: #FFCB70;
    color: #242424;
    vertical-align: super;
    line-height: 1;
  }
</style>
