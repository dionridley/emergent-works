---
import { organization } from "../../../data/organization";
---

<footer class="mn-footer">
  <div class="mn-container">
    <div class="mn-footer__grid">
      <div class="mn-footer__brand">
        <h3>Emergent Works</h3>
        <p>{organization.mission}</p>
      </div>
      <div class="mn-footer__col">
        <h4>Programs</h4>
        <ul>
          <li><a href="/designs/mentorship/programs/">Overview</a></li>
          <li><a href="/designs/mentorship/programs/trap/">T.RAP</a></li>
          <li><a href="/designs/mentorship/programs/teck/">TECK</a></li>
        </ul>
      </div>
      <div class="mn-footer__col">
        <h4>Organization</h4>
        <ul>
          <li><a href="/designs/mentorship/about/">About</a></li>
          <li><a href="/designs/mentorship/team/">Team</a></li>
          <li><a href="/designs/mentorship/get-involved/">Get Involved</a></li>
        </ul>
      </div>
      <div class="mn-footer__col">
        <h4>Connect</h4>
        <ul>
          <li><a href={`mailto:${organization.contact.email}`}>{organization.contact.email}</a></li>
          <li><a href={organization.social.instagram} target="_blank" rel="noopener noreferrer">Instagram</a></li>
          <li><a href={organization.social.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a></li>
          <li><a href={organization.social.youtube} target="_blank" rel="noopener noreferrer">YouTube</a></li>
        </ul>
      </div>
    </div>
    <div class="mn-footer__bottom">
      <span>&copy; {new Date().getFullYear()} {organization.name}. {organization.legalName} — EIN: {organization.ein}</span>
      <div class="mn-footer__social">
        <a href={organization.social.instagram} target="_blank" rel="noopener noreferrer">Instagram</a>
        <a href={organization.social.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a href={organization.social.youtube} target="_blank" rel="noopener noreferrer">YouTube</a>
      </div>
    </div>
  </div>
</footer>
